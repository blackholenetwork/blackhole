package storage

import (
	"context"
	"fmt"
	"path/filepath"
	"strings"
	"time"
	"unicode"
)

// DirectoryCreationOptions controls how directories are created
type DirectoryCreationOptions struct {
	AutoCreateParents bool  // Create missing parent directories
	MaxDepth          int   // Maximum directory depth allowed
	StrictMode        bool  // Require explicit directory creation
	ValidateNames     bool  // Validate directory names
}

// DefaultDirectoryOptions returns user-friendly defaults
func DefaultDirectoryOptions() DirectoryCreationOptions {
	return DirectoryCreationOptions{
		AutoCreateParents: true,  // Like modern cloud storage
		MaxDepth:          20,    // Reasonable limit
		StrictMode:        false, // User-friendly by default
		ValidateNames:     true,  // Prevent problematic names
	}
}

// ensureParentDirectories creates all missing parent directories for a given path
func (pvfs *PrivateVFS) ensureParentDirectories(ctx context.Context, filePath string, options DirectoryCreationOptions) error {
	// Skip if auto-creation disabled
	if !options.AutoCreateParents {
		return nil
	}

	// Get parent directory path
	parentDir := filepath.Dir(filePath)
	if parentDir == "." || parentDir == "/" {
		return nil // No parent to create
	}

	// Normalize parent directory path
	parentDir = pvfs.normalizePath(parentDir)
	if !strings.HasSuffix(parentDir, "/") {
		parentDir += "/"
	}

	// Validate the full path structure
	if err := pvfs.validateDirectoryPath(parentDir, options); err != nil {
		return fmt.Errorf("invalid directory path: %w", err)
	}

	// Create parent directories recursively
	return pvfs.createDirectoryPath(ctx, parentDir, options)
}

// createDirectoryPath creates a directory and all its parents
func (pvfs *PrivateVFS) createDirectoryPath(ctx context.Context, dirPath string, options DirectoryCreationOptions) error {
	// Check if directory already exists
	if pvfs.directoryExists(ctx, dirPath) {
		return nil
	}

	// Get parent of this directory
	parentDir := filepath.Dir(strings.TrimSuffix(dirPath, "/"))
	if parentDir != "." && parentDir != "/" {
		parentDir = pvfs.normalizePath(parentDir) + "/"

		// Recursively ensure parent exists
		if err := pvfs.createDirectoryPath(ctx, parentDir, options); err != nil {
			return fmt.Errorf("failed to create parent directory %s: %w", parentDir, err)
		}
	}

	// Check permissions for creating this directory
	if err := pvfs.checkWritePermission(ctx, dirPath); err != nil {
		return fmt.Errorf("permission denied for directory creation %s: %w", dirPath, err)
	}

	// Create the directory metadata
	return pvfs.createDirectory(ctx, dirPath)
}

// createDirectory creates a single directory with proper metadata
func (pvfs *PrivateVFS) createDirectory(ctx context.Context, dirPath string) error {
	// Create directory metadata
	dirMetadata := &DirectoryMetadata{
		Path:      dirPath,
		Type:      "directory",
		Updated:   time.Now(),
		CreatedBy: pvfs.userDID,
		Permissions: map[string]PermissionInfo{
			pvfs.userDID: {
				Level:     "admin",
				GrantedBy: pvfs.userDID,
				GrantedAt: time.Now(),
			},
		},
		Entries: make(map[string]EntryInfo),
	}

	// Store directory metadata
	if err := pvfs.storeDirectoryMetadata(ctx, dirPath, dirMetadata); err != nil {
		return fmt.Errorf("failed to store directory metadata: %w", err)
	}

	// Update parent directory to include this directory
	parentDir := filepath.Dir(strings.TrimSuffix(dirPath, "/"))
	if parentDir != "." && parentDir != "/" {
		parentDir = pvfs.normalizePath(parentDir) + "/"
		dirName := filepath.Base(strings.TrimSuffix(dirPath, "/"))

		entryInfo := EntryInfo{
			Name:      dirName,
			Type:      "directory",
			Size:      0,
			Modified:  time.Now(),
			CreatedBy: pvfs.userDID,
		}

		if err := pvfs.updateDirectoryMetadata(ctx, parentDir, entryInfo); err != nil {
			pvfs.logger.Warn().Err(err).Str("parent", parentDir).Msg("Failed to update parent directory")
			// Don't fail the operation, directory was created successfully
		}
	}

	pvfs.logger.Info().
		Str("directory", dirPath).
		Str("created_by", pvfs.userDID).
		Msg("Created directory")

	return nil
}

// directoryExists checks if a directory already exists
func (pvfs *PrivateVFS) directoryExists(ctx context.Context, dirPath string) bool {
	_, err := pvfs.loadDirectoryMetadata(ctx, dirPath)
	return err == nil
}

// validateDirectoryPath validates a directory path for safety and correctness
func (pvfs *PrivateVFS) validateDirectoryPath(dirPath string, options DirectoryCreationOptions) error {
	if !options.ValidateNames {
		return nil
	}

	// Check overall path length
	if len(dirPath) > 1000 {
		return fmt.Errorf("path too long: %d characters (max 1000)", len(dirPath))
	}

	// Split path into components
	components := strings.Split(strings.Trim(dirPath, "/"), "/")

	// Check depth limit
	if len(components) > options.MaxDepth {
		return fmt.Errorf("path too deep: %d levels (max %d)", len(components), options.MaxDepth)
	}

	// Validate each path component
	for i, component := range components {
		if component == "" && i > 0 { // Allow empty first component for absolute paths
			return fmt.Errorf("empty path component at level %d", i)
		}

		if component == "" {
			continue
		}

		if err := pvfs.validatePathComponent(component); err != nil {
			return fmt.Errorf("invalid path component '%s' at level %d: %w", component, i, err)
		}
	}

	return nil
}

// validatePathComponent validates a single path component (directory/file name)
func (pvfs *PrivateVFS) validatePathComponent(component string) error {
	// Check length
	if len(component) > 255 {
		return fmt.Errorf("component too long: %d characters (max 255)", len(component))
	}

	// Check for dangerous patterns
	if component == "." || component == ".." {
		return fmt.Errorf("dangerous path component: %s", component)
	}

	// Check for invalid characters
	invalidChars := []rune{'<', '>', ':', '"', '|', '?', '*', '\x00'}
	for _, char := range component {
		// Check for control characters
		if unicode.IsControl(char) {
			return fmt.Errorf("control character not allowed: U+%04X", char)
		}

		// Check for explicitly invalid characters
		for _, invalid := range invalidChars {
			if char == invalid {
				return fmt.Errorf("invalid character: %c", char)
			}
		}
	}

	// Check for Windows reserved names (for cross-platform compatibility)
	reserved := []string{"CON", "PRN", "AUX", "NUL", "COM1", "COM2", "COM3", "COM4", "COM5", "COM6", "COM7", "COM8", "COM9", "LPT1", "LPT2", "LPT3", "LPT4", "LPT5", "LPT6", "LPT7", "LPT8", "LPT9"}
	upperComponent := strings.ToUpper(component)
	for _, reservedName := range reserved {
		if upperComponent == reservedName {
			return fmt.Errorf("reserved name not allowed: %s", component)
		}
	}

	// Check for trailing dots or spaces (Windows compatibility)
	if strings.HasSuffix(component, ".") || strings.HasSuffix(component, " ") {
		return fmt.Errorf("component cannot end with dot or space: %s", component)
	}

	return nil
}

// CreateDirectoryExplicit creates a directory explicitly (like mkdir)
func (pvfs *PrivateVFS) CreateDirectoryExplicit(ctx context.Context, dirPath string, recursive bool) error {
	// Normalize path
	dirPath = pvfs.normalizePath(dirPath)
	if !strings.HasSuffix(dirPath, "/") {
		dirPath += "/"
	}

	// Validate path
	if err := pvfs.validatePath(dirPath); err != nil {
		return fmt.Errorf("invalid path: %w", err)
	}

	// Check if directory already exists
	if pvfs.directoryExists(ctx, dirPath) {
		return fmt.Errorf("directory already exists: %s", dirPath)
	}

	// Configure options based on recursive flag
	options := DefaultDirectoryOptions()
	options.AutoCreateParents = recursive

	if recursive {
		// Create parent directories if needed
		return pvfs.createDirectoryPath(ctx, dirPath, options)
	} else {
		// Check that parent exists
		parentDir := filepath.Dir(strings.TrimSuffix(dirPath, "/"))
		if parentDir != "." && parentDir != "/" {
			parentDir = pvfs.normalizePath(parentDir) + "/"
			if !pvfs.directoryExists(ctx, parentDir) {
				return fmt.Errorf("parent directory does not exist: %s", parentDir)
			}
		}

		// Create just this directory
		return pvfs.createDirectory(ctx, dirPath)
	}
}

// GetDirectoryCreationStats returns statistics about directory creation
func (pvfs *PrivateVFS) GetDirectoryCreationStats(ctx context.Context, basePath string) (DirectoryStats, error) {
	stats := DirectoryStats{
		BasePath:      basePath,
		TotalDirs:     0,
		MaxDepth:      0,
		CreatedBy:     make(map[string]int),
		LastModified:  time.Time{},
	}

	// Walk directory tree and collect stats
	err := pvfs.walkDirectoryTree(ctx, basePath, 0, &stats)
	return stats, err
}

// DirectoryStats is defined in service.go

// walkDirectoryTree recursively walks a directory tree for statistics
func (pvfs *PrivateVFS) walkDirectoryTree(ctx context.Context, dirPath string, depth int, stats *DirectoryStats) error {
	// Update max depth
	if depth > stats.MaxDepth {
		stats.MaxDepth = depth
	}

	// Load directory metadata
	metadata, err := pvfs.loadDirectoryMetadata(ctx, dirPath)
	if err != nil {
		return nil // Skip inaccessible directories
	}

	// Update stats
	stats.TotalDirs++
	stats.CreatedBy[metadata.CreatedBy]++
	if metadata.Updated.After(stats.LastModified) {
		stats.LastModified = metadata.Updated
	}

	// Walk subdirectories
	for _, entry := range metadata.Entries {
		if entry.Type == "directory" {
			subDirPath := dirPath + entry.Name + "/"
			if err := pvfs.walkDirectoryTree(ctx, subDirPath, depth+1, stats); err != nil {
				pvfs.logger.Warn().Err(err).Str("subdir", subDirPath).Msg("Failed to walk subdirectory")
			}
		}
	}

	return nil
}
