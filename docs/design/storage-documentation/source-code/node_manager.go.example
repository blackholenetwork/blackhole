package storage

import (
	"fmt"
	"sync"
	"time"
)

// NodeManager handles node registration, position claiming, and reputation management
type NodeManager struct {
	nodes           map[NodeID]*NodeDetails
	positionOwners  map[GlobalPosition]NodeID
	positionClaims  map[NodeID][]GlobalPosition
	reputations     map[NodeID]*NodeReputation
	mutex           sync.RWMutex
	bucketSystem    *SimpleBucketSystem
	localNodeID     NodeID
	
	// Advanced negotiation engine for mature networks
	negotiationEngine *PositionNegotiationEngine
	
	// Position health monitoring
	healthMonitor *PositionHealthMonitor
}

// NodeDetails contains complete information about a node
type NodeDetails struct {
	ID                    NodeID                `json:"id"`
	Address               string                `json:"address"`
	AvailableStorage      int64                 `json:"available_storage"`
	ClaimedPositions      []GlobalPosition      `json:"claimed_positions"`
	PositionStrategy      PositionStrategy      `json:"position_strategy"`
	LastSeen              time.Time             `json:"last_seen"`
	OnlineTime            time.Duration         `json:"online_time"`
	TotalUptime           time.Duration         `json:"total_uptime"`
	JoinedAt              time.Time             `json:"joined_at"`
	StorageCapacity       int64                 `json:"storage_capacity"`
	ChunksServed          int64                 `json:"chunks_served"`
	AverageResponseTime   time.Duration         `json:"average_response_time"`
	FailureCount          int                   `json:"failure_count"`
	SuccessCount          int                   `json:"success_count"`
}

// NodeReputation tracks node reliability and performance metrics
type NodeReputation struct {
	OnlineTime           float64       `json:"online_time"`           // Uptime percentage (0.0-1.0)
	StorageCapacity      int64         `json:"storage_capacity"`      // Total storage capacity in bytes
	ChunksServed         int64         `json:"chunks_served"`         // Total chunks served
	ResponseTime         time.Duration `json:"response_time"`         // Average response time
	ReliabilityScore     float64       `json:"reliability_score"`     // Overall reliability (0.0-1.0)
	PerformanceScore     float64       `json:"performance_score"`     // Performance score (0.0-1.0)
	TotalScore           float64       `json:"total_score"`           // Combined reputation score
	LastUpdated          time.Time     `json:"last_updated"`
	PositionCount        int           `json:"position_count"`        // Number of positions claimed
	SuccessRate          float64       `json:"success_rate"`          // Success rate percentage
}

// PositionStrategy defines how a node claims positions
type PositionStrategy struct {
	Type                 StrategyType  `json:"type"`
	StoragePerPosition   int64         `json:"storage_per_position"`   // Bytes per position
	MaxPositions         int           `json:"max_positions"`          // Maximum positions to claim
	FillRateThreshold    float64       `json:"fill_rate_threshold"`    // When to stop claiming (0.0-1.0)
	ExpansionRate        int           `json:"expansion_rate"`         // Positions to add when expanding
	ConservativeBuffer   float64       `json:"conservative_buffer"`    // Extra capacity buffer (multiplier)
}

// StrategyType defines the position claiming strategy
type StrategyType string

const (
	ConservativeStrategy StrategyType = "conservative" // 10GB per position, high buffer
	AggressiveStrategy   StrategyType = "aggressive"   // 1GB per position, low buffer
	DynamicStrategy      StrategyType = "dynamic"      // Adjusts based on fill rate
	ReputationStrategy   StrategyType = "reputation"   // Claims based on reputation level
)

// PositionClaimResult represents the result of a position claiming attempt
type PositionClaimResult struct {
	Success          bool              `json:"success"`
	ClaimedPositions []GlobalPosition  `json:"claimed_positions"`
	FailedPositions  []GlobalPosition  `json:"failed_positions"`
	Reason           string            `json:"reason"`
	CompetingNode    *NodeID           `json:"competing_node,omitempty"`
}

// NewNodeManager creates a new node manager
func NewNodeManager(bucketSystem *SimpleBucketSystem, localNodeID NodeID) *NodeManager {
	nm := &NodeManager{
		nodes:          make(map[NodeID]*NodeDetails),
		positionOwners: make(map[GlobalPosition]NodeID),
		positionClaims: make(map[NodeID][]GlobalPosition),
		reputations:    make(map[NodeID]*NodeReputation),
		bucketSystem:   bucketSystem,
		localNodeID:    localNodeID,
	}
	
	// Initialize health monitor
	nm.healthMonitor = NewPositionHealthMonitor(nm)
	
	// Initialize negotiation engine
	nm.negotiationEngine = NewPositionNegotiationEngine(nm)
	
	return nm
}

// RegisterNode registers a new node with the network
func (nm *NodeManager) RegisterNode(nodeInfo *NodeDetails) error {
	nm.mutex.Lock()
	defer nm.mutex.Unlock()

	// Initialize node if not exists
	if _, exists := nm.nodes[nodeInfo.ID]; !exists {
		nodeInfo.JoinedAt = time.Now()
		nodeInfo.LastSeen = time.Now()
		
		// Initialize reputation
		nm.reputations[nodeInfo.ID] = &NodeReputation{
			OnlineTime:       1.0, // Start with perfect uptime
			StorageCapacity:  nodeInfo.StorageCapacity,
			ChunksServed:     0,
			ResponseTime:     100 * time.Millisecond, // Default response time
			ReliabilityScore: 0.5, // Neutral starting score
			PerformanceScore: 0.5, // Neutral starting score
			TotalScore:       0.5, // Neutral starting score
			LastUpdated:      time.Now(),
			SuccessRate:      1.0, // Start with perfect success rate
		}
		
		// Initialize empty position claims
		nm.positionClaims[nodeInfo.ID] = make([]GlobalPosition, 0)
	}
	
	nm.nodes[nodeInfo.ID] = nodeInfo
	return nil
}

// ClaimPositions attempts to claim positions for a node based on its strategy
func (nm *NodeManager) ClaimPositions(nodeID NodeID) (*PositionClaimResult, error) {
	nm.mutex.Lock()
	defer nm.mutex.Unlock()

	node, exists := nm.nodes[nodeID]
	if !exists {
		return nil, fmt.Errorf("node %s not found", nodeID)
	}

	// Calculate how many positions to claim based on strategy
	positionsToClaimCount := nm.calculatePositionsToClaim(node)
	if positionsToClaimCount <= 0 {
		return &PositionClaimResult{
			Success: false,
			Reason:  "no positions needed based on current strategy",
		}, nil
	}

	// Generate candidate positions to claim
	candidatePositions := nm.generateCandidatePositions(node, positionsToClaimCount)
	
	claimedPositions := make([]GlobalPosition, 0)
	failedPositions := make([]GlobalPosition, 0)

	// Attempt to claim each position
	for _, position := range candidatePositions {
		if nm.tryClaimPosition(nodeID, position) {
			claimedPositions = append(claimedPositions, position)
			nm.positionOwners[position] = nodeID
			nm.positionClaims[nodeID] = append(nm.positionClaims[nodeID], position)
		} else {
			failedPositions = append(failedPositions, position)
		}
	}

	// Update node's claimed positions
	node.ClaimedPositions = nm.positionClaims[nodeID]

	return &PositionClaimResult{
		Success:          len(claimedPositions) > 0,
		ClaimedPositions: claimedPositions,
		FailedPositions:  failedPositions,
		Reason:           fmt.Sprintf("claimed %d/%d positions", len(claimedPositions), len(candidatePositions)),
	}, nil
}

// calculatePositionsToClaim determines how many positions a node should claim
func (nm *NodeManager) calculatePositionsToClaim(node *NodeDetails) int {
	currentPositions := len(node.ClaimedPositions)
	
	switch node.PositionStrategy.Type {
	case ConservativeStrategy:
		// Conservative: 10GB per position with 50% buffer
		targetPositions := int(node.AvailableStorage / (10 * 1024 * 1024 * 1024)) // 10GB
		targetPositions = int(float64(targetPositions) * 0.5) // 50% buffer
		return max(0, targetPositions - currentPositions)
		
	case AggressiveStrategy:
		// Aggressive: 1GB per position with 10% buffer
		targetPositions := int(node.AvailableStorage / (1 * 1024 * 1024 * 1024)) // 1GB
		targetPositions = int(float64(targetPositions) * 0.9) // 10% buffer
		return max(0, targetPositions - currentPositions)
		
	case DynamicStrategy:
		// Dynamic: Adjust based on current fill rate
		usedStorage := node.StorageCapacity - node.AvailableStorage
		fillRate := float64(usedStorage) / float64(node.StorageCapacity)
		
		if fillRate < 0.5 {
			// Under-utilized, claim more aggressively
			targetPositions := int(node.AvailableStorage / (2 * 1024 * 1024 * 1024)) // 2GB
			return min(100, max(0, targetPositions - currentPositions)) // Max 100 at once
		} else if fillRate > 0.8 {
			// Getting full, stop claiming
			return 0
		} else {
			// Moderate usage, claim conservatively
			targetPositions := int(node.AvailableStorage / (5 * 1024 * 1024 * 1024)) // 5GB
			return max(0, targetPositions - currentPositions)
		}
		
	case ReputationStrategy:
		// Reputation-based: Claim based on reputation level
		reputation := nm.reputations[node.ID]
		if reputation == nil {
			return 0
		}
		
		// Higher reputation allows more positions
		var maxPositions int
		if reputation.TotalScore >= 0.9 {
			maxPositions = 100000 // Network veteran
		} else if reputation.TotalScore >= 0.7 {
			maxPositions = 10000  // High reputation
		} else if reputation.TotalScore >= 0.5 {
			maxPositions = 1000   // Proven reliability
		} else {
			maxPositions = 100    // New node
		}
		
		targetPositions := int(node.AvailableStorage / (5 * 1024 * 1024 * 1024)) // 5GB default
		targetPositions = min(targetPositions, maxPositions)
		return max(0, targetPositions - currentPositions)
	}
	
	return 0
}

// generateCandidatePositions creates a list of positions the node could claim
func (nm *NodeManager) generateCandidatePositions(node *NodeDetails, count int) []GlobalPosition {
	candidates := make([]GlobalPosition, 0, count)
	
	// Use node ID as seed for deterministic but unique position selection
	nodeHash := hashString(string(node.ID))
	
	// Generate positions starting from node's hash
	for i := 0; i < count && len(candidates) < count; i++ {
		candidate := GlobalPosition((nodeHash + uint64(i)) % TotalPositions)
		candidates = append(candidates, candidate)
	}
	
	return candidates
}

// tryClaimPosition attempts to claim a specific position
func (nm *NodeManager) tryClaimPosition(nodeID NodeID, position GlobalPosition) bool {
	// Check if position is already claimed
	if existingOwner, exists := nm.positionOwners[position]; exists {
		// Position is claimed, check if we can compete for it
		return nm.competeForPosition(nodeID, existingOwner, position)
	}
	
	// Position is available
	return true
}

// competeForPosition handles advanced position negotiation in both bootstrap and mature networks
func (nm *NodeManager) competeForPosition(challengerID, currentOwnerID NodeID, position GlobalPosition) bool {
	// Use the negotiation engine for sophisticated position competition
	negotiationResult, err := nm.negotiationEngine.NegotiatePositionClaim(challengerID, position)
	if err != nil {
		return false // Failed to negotiate, challenger doesn't get position
	}
	
	// Check if challenger won the negotiation
	if negotiationResult.WinningNode == challengerID {
		// Transfer position to challenger
		nm.transferPosition(currentOwnerID, challengerID, position)
		return true
	}
	
	return false // Owner keeps position
}

// transferPosition transfers a position from one node to another
func (nm *NodeManager) transferPosition(fromNodeID, toNodeID NodeID, position GlobalPosition) {
	// Remove from old owner
	if claims, exists := nm.positionClaims[fromNodeID]; exists {
		for i, pos := range claims {
			if pos == position {
				nm.positionClaims[fromNodeID] = append(claims[:i], claims[i+1:]...)
				break
			}
		}
	}
	
	// Add to new owner
	nm.positionClaims[toNodeID] = append(nm.positionClaims[toNodeID], position)
	nm.positionOwners[position] = toNodeID
	
	// Update node info
	if fromNode := nm.nodes[fromNodeID]; fromNode != nil {
		fromNode.ClaimedPositions = nm.positionClaims[fromNodeID]
	}
	if toNode := nm.nodes[toNodeID]; toNode != nil {
		toNode.ClaimedPositions = nm.positionClaims[toNodeID]
	}
}

// GetNodeForPosition returns the node that owns a specific position
func (nm *NodeManager) GetNodeForPosition(position GlobalPosition) (NodeID, bool) {
	nm.mutex.RLock()
	defer nm.mutex.RUnlock()
	
	nodeID, exists := nm.positionOwners[position]
	return nodeID, exists
}

// GetNodesForChunk returns nodes that can store a chunk (primary, secondary, tertiary)
func (nm *NodeManager) GetNodesForChunk(chunkID ChunkCID) []NodeID {
	locations := nm.bucketSystem.GetStorageLocations(chunkID)
	
	nodes := make([]NodeID, 0, 3)
	if nodeID, exists := nm.GetNodeForPosition(locations.Primary.Global); exists {
		nodes = append(nodes, nodeID)
	}
	if nodeID, exists := nm.GetNodeForPosition(locations.Secondary.Global); exists {
		nodes = append(nodes, nodeID)
	}
	if nodeID, exists := nm.GetNodeForPosition(locations.Tertiary.Global); exists {
		nodes = append(nodes, nodeID)
	}
	
	return nodes
}

// UpdateNodeReputation updates a node's reputation based on performance
func (nm *NodeManager) UpdateNodeReputation(nodeID NodeID, success bool, responseTime time.Duration) {
	nm.mutex.Lock()
	defer nm.mutex.Unlock()
	
	rep, exists := nm.reputations[nodeID]
	if !exists {
		return
	}
	
	node := nm.nodes[nodeID]
	if node == nil {
		return
	}
	
	// Update counters
	if success {
		node.SuccessCount++
	} else {
		node.FailureCount++
	}
	
	// Update reputation metrics
	totalOperations := node.SuccessCount + node.FailureCount
	rep.SuccessRate = float64(node.SuccessCount) / float64(totalOperations)
	rep.ChunksServed = int64(node.SuccessCount)
	
	// Update response time (moving average)
	if responseTime > 0 {
		rep.ResponseTime = (rep.ResponseTime + responseTime) / 2
		node.AverageResponseTime = rep.ResponseTime
	}
	
	// Calculate performance score (0.0-1.0)
	// Based on success rate and response time
	successScore := rep.SuccessRate
	responseScore := 1.0 - minFloat(1.0, float64(rep.ResponseTime.Milliseconds())/1000.0) // 1s = 0.0 score
	rep.PerformanceScore = (successScore + responseScore) / 2.0
	
	// Calculate reliability score based on uptime and consistency
	uptime := time.Since(node.JoinedAt)
	node.TotalUptime = uptime // Simplified - in real system would track actual uptime
	rep.OnlineTime = 1.0 // Simplified - would track real uptime percentage
	rep.ReliabilityScore = rep.OnlineTime * rep.SuccessRate
	
	// Calculate total reputation score
	rep.TotalScore = (rep.ReliabilityScore + rep.PerformanceScore) / 2.0
	rep.PositionCount = len(node.ClaimedPositions)
	rep.LastUpdated = time.Now()
}

// GetNodeStats returns comprehensive statistics for a node
func (nm *NodeManager) GetNodeStats(nodeID NodeID) (*NodeDetails, *NodeReputation, error) {
	nm.mutex.RLock()
	defer nm.mutex.RUnlock()
	
	node, exists := nm.nodes[nodeID]
	if !exists {
		return nil, nil, fmt.Errorf("node %s not found", nodeID)
	}
	
	reputation := nm.reputations[nodeID]
	return node, reputation, nil
}

// ListNodes returns all registered nodes
func (nm *NodeManager) ListNodes() map[NodeID]*NodeDetails {
	nm.mutex.RLock()
	defer nm.mutex.RUnlock()
	
	// Return copy to avoid race conditions
	nodes := make(map[NodeID]*NodeDetails)
	for id, node := range nm.nodes {
		nodeCopy := *node
		nodes[id] = &nodeCopy
	}
	return nodes
}

// GetLocalNode returns information about the local node
func (nm *NodeManager) GetLocalNode() (*NodeDetails, error) {
	node, _, err := nm.GetNodeStats(nm.localNodeID)
	return node, err
}

// GetNetworkState returns the current network state for monitoring
func (nm *NodeManager) GetNetworkState() *NetworkState {
	return nm.negotiationEngine.GetNetworkState()
}

// GetNegotiationStats returns detailed statistics about position negotiations
func (nm *NodeManager) GetNegotiationStats() map[string]interface{} {
	return nm.negotiationEngine.GetNegotiationStats()
}

// NegotiatePositionClaim performs a position negotiation and returns the result
func (nm *NodeManager) NegotiatePositionClaim(challengerID NodeID, position GlobalPosition) (*NegotiationResult, error) {
	return nm.negotiationEngine.NegotiatePositionClaim(challengerID, position)
}

// Position Health Monitoring Methods

// RecordPositionOperation records an operation performed on a position for health tracking
func (nm *NodeManager) RecordPositionOperation(position GlobalPosition, ownerNode NodeID, success bool, responseTime time.Duration) {
	nm.healthMonitor.RecordPositionOperation(position, ownerNode, success, responseTime)
}

// RecordNodeDowntime records downtime for a node's positions
func (nm *NodeManager) RecordNodeDowntime(nodeID NodeID, downtime time.Duration) {
	nm.healthMonitor.RecordNodeDowntime(nodeID, downtime)
}

// GetPositionHealth returns health metrics for a specific position
func (nm *NodeManager) GetPositionHealth(position GlobalPosition) (*PositionHealthMetrics, bool) {
	return nm.healthMonitor.GetPositionHealth(position)
}

// GetAllPositionHealth returns health metrics for all monitored positions
func (nm *NodeManager) GetAllPositionHealth() map[GlobalPosition]*PositionHealthMetrics {
	return nm.healthMonitor.GetAllPositionHealth()
}

// GetHealthSummary returns a summary of health across all positions
func (nm *NodeManager) GetHealthSummary() map[string]interface{} {
	return nm.healthMonitor.GetHealthSummary()
}

// CheckForHealthTriggeredNegotiations checks for positions that need health-based negotiations
func (nm *NodeManager) CheckForHealthTriggeredNegotiations() []*HealthTriggeredNegotiation {
	return nm.healthMonitor.CheckForNegotiationTriggers()
}

// Helper functions

func max(a, b int) int {
	if a > b {
		return a
	}
	return b
}

func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}

func minFloat(a, b float64) float64 {
	if a < b {
		return a
	}
	return b
}

// CanClaimMorePositions checks if a node can claim more positions based on its strategy
func (nm *NodeManager) CanClaimMorePositions(nodeID NodeID) bool {
	nm.mutex.RLock()
	defer nm.mutex.RUnlock()
	
	node, exists := nm.nodes[nodeID]
	if !exists {
		return false
	}
	
	positionsToClaimCount := nm.calculatePositionsToClaim(node)
	return positionsToClaimCount > 0
}

// ClaimSpecificPosition attempts to claim a specific position for a node
func (nm *NodeManager) ClaimSpecificPosition(nodeID NodeID, position GlobalPosition) error {
	nm.mutex.Lock()
	defer nm.mutex.Unlock()
	
	node, exists := nm.nodes[nodeID]
	if !exists {
		return fmt.Errorf("node %s not found", nodeID)
	}
	
	// Check if position is already claimed by this node
	for _, claimedPos := range nm.positionClaims[nodeID] {
		if claimedPos == position {
			return nil // Already claimed by this node
		}
	}
	
	// Try to claim the position
	if nm.tryClaimPosition(nodeID, position) {
		nm.positionOwners[position] = nodeID
		nm.positionClaims[nodeID] = append(nm.positionClaims[nodeID], position)
		node.ClaimedPositions = nm.positionClaims[nodeID]
		return nil
	}
	
	return fmt.Errorf("failed to claim position %d", position)
}

func hashString(s string) uint64 {
	// Simple hash function for deterministic position generation
	var hash uint64 = 5381
	for _, c := range s {
		hash = ((hash << 5) + hash) + uint64(c)
	}
	return hash
}