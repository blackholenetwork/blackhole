package storage

import (
	"context"
	"fmt"
	"io"
	"strings"
	"time"

	"github.com/blackholenetwork/blackhole/pkg/data/schema"
)

// NetworkSchemaAwareStoreRequest contains all information needed for network schema-integrated storage
type NetworkSchemaAwareStoreRequest struct {
	// Required fields
	Content     io.Reader `json:"-"`           // File content
	ContentType string    `json:"content_type"` // MIME type
	
	// Network-wide use case selection
	UseCase      string                 `json:"use_case,omitempty"`       // Standard or user-defined use case ID
	UserMetadata map[string]interface{} `json:"user_metadata,omitempty"`  // User-provided metadata
	Filename     string                 `json:"filename,omitempty"`       // Original filename for extraction
	
	// User context
	OwnerDID     string                      `json:"owner_did"`               // Content owner
	AppID        string                      `json:"app_id,omitempty"`        // App identifier for user-defined use cases
	Permissions  map[string]schema.FieldPermission `json:"permissions,omitempty"` // Field-level permissions
}

// NetworkSchemaAwareStoreResult contains comprehensive storage and metadata information
type NetworkSchemaAwareStoreResult struct {
	// Storage result
	ContentCID ContentCID `json:"content_cid"`  // Content identifier
	Size       int64      `json:"size"`         // File size
	
	// Schema processing result
	MetadataContainer *schema.MetadataContainer `json:"metadata"`      // Rich metadata
	SchemaUsed        schema.SchemaID           `json:"schema_used"`   // Schema that was applied
	QualityScore      float64                   `json:"quality_score"` // Metadata quality
	CompletenessScore float64                   `json:"completeness"`  // Metadata completeness
	
	// Network policy information
	UseCase        string `json:"use_case"`         // Use case that was applied
	PolicyApplied  string `json:"policy_applied"`   // Which policy was used
	IsUserDefined  bool   `json:"is_user_defined"`  // Whether use case is user-defined
	
	// Processing information
	AutoDetectedUseCase bool     `json:"auto_detected_use_case"` // Whether use case was auto-detected
	Suggestions        []string `json:"suggestions,omitempty"`  // Suggestions for improvement
}

// StoreWithNetworkPolicy performs schema-integrated storage using network-wide policies
func (nsis *NetworkSchemaIntegratedService) StoreWithNetworkPolicy(ctx context.Context, req *NetworkSchemaAwareStoreRequest) (*NetworkSchemaAwareStoreResult, error) {
	nsis.logger.Info().
		Str("content_type", req.ContentType).
		Str("owner", req.OwnerDID).
		Str("use_case", req.UseCase).
		Str("app_id", req.AppID).
		Msg("Starting network schema-integrated storage")
	
	// Step 1: Read content into memory for processing
	content, err := io.ReadAll(req.Content)
	if err != nil {
		return nil, fmt.Errorf("failed to read content: %w", err)
	}
	
	// Step 2: Detect/validate content type
	if req.ContentType == "" {
		req.ContentType = nsis.detectContentType(req.Filename, content)
	}
	
	// Step 3: Determine use case and get policy
	useCase, policy, isUserDefined, autoDetected, err := nsis.determineUseCaseAndPolicy(req)
	if err != nil {
		return nil, fmt.Errorf("failed to determine use case policy: %w", err)
	}
	
	nsis.logger.Info().
		Str("use_case", useCase).
		Bool("is_user_defined", isUserDefined).
		Bool("auto_detected", autoDetected).
		Str("enforcement_level", policy.EnforcementLevel).
		Msg("Use case policy determined")
	
	// Step 4: Check if schema is required and determine appropriate schema
	schemaID := nsis.determineSchema(req, policy)
	if schemaID == "" {
		if nsis.requiresSchema(req.ContentType, policy) {
			return nil, fmt.Errorf("no suitable schema found for content type %s with use case %s", req.ContentType, useCase)
		}
		schemaID = schema.SchemaID("generic/v1")
	}
	
	// Step 5: Extract metadata from multiple sources
	extractionResult := nsis.extractNetworkMetadata(req.ContentType, content, req.Filename, policy)
	
	// Step 6: Merge user-provided metadata with auto-extracted metadata
	finalMetadata, autoExtracted := nsis.mergeMetadata(extractionResult.ExtractedData, req.UserMetadata, policy)
	
	// Step 7: Create metadata creation request
	metadataReq := &schema.CreateMetadataRequest{
		ContentHash: "", // Will be set after storage
		SchemaID:    schemaID,
		OwnerDID:    req.OwnerDID,
		UserData:    finalMetadata,
		Permissions: req.Permissions,
		Content:     content,
		ContentType: req.ContentType,
	}
	
	// Step 8: Store content in underlying storage
	contentReader := strings.NewReader(string(content))
	contentCID, err := nsis.storage.Store(ctx, contentReader)
	if err != nil {
		return nil, fmt.Errorf("failed to store content: %w", err)
	}
	
	// Step 9: Update metadata with content hash and create metadata container
	metadataReq.ContentHash = string(contentCID)
	metadataContainer, err := nsis.schemaService.CreateMetadata(ctx, metadataReq)
	if err != nil {
		// Storage succeeded but metadata creation failed - create minimal container
		nsis.logger.Warn().Err(err).Str("cid", string(contentCID)).Msg("Content stored but metadata creation failed")
		
		metadataContainer = &schema.MetadataContainer{
			ContentHash:       string(contentCID),
			SchemaID:          schemaID,
			OwnerDID:          req.OwnerDID,
			Data:              finalMetadata,
			Permissions:       req.Permissions,
			QualityScore:      0.5, // Default score
			CompletenessScore: 0.3, // Default score
			AutoExtracted:     autoExtracted,
		}
	}
	
	// Step 10: Quality validation based on policy
	if err := nsis.validateQualityWithPolicy(metadataContainer, policy); err != nil {
		nsis.logger.Warn().Err(err).Float64("quality", metadataContainer.QualityScore).Msg("Quality check failed")
		
		// Handle quality failure based on enforcement level
		if policy.EnforcementLevel == "strict" {
			// Delete the stored content and return error
			nsis.storage.Delete(ctx, contentCID)
			return nil, fmt.Errorf("content rejected due to insufficient metadata quality: %w", err)
		}
		// For "moderate" and "lenient", just log warning and continue
	}
	
	// Step 11: Get storage info for response
	storageInfo, err := nsis.storage.GetContentInfo(ctx, contentCID)
	if err != nil {
		nsis.logger.Warn().Err(err).Msg("Failed to get content info")
	}
	
	var size int64
	if storageInfo.Size > 0 {
		size = int64(storageInfo.Size)
	}
	
	// Step 12: Generate suggestions based on policy and quality
	suggestions := nsis.generatePolicySuggestions(metadataContainer, policy, useCase, isUserDefined)
	
	// Step 13: Record use case usage if user-defined
	if isUserDefined {
		nsis.recordUserUseCaseUsage(useCase, req.AppID)
	}
	
	// Step 14: Return comprehensive result
	result := &NetworkSchemaAwareStoreResult{
		ContentCID:          contentCID,
		Size:               size,
		MetadataContainer:  metadataContainer,
		SchemaUsed:         schemaID,
		QualityScore:       metadataContainer.QualityScore,
		CompletenessScore:  metadataContainer.CompletenessScore,
		UseCase:            useCase,
		PolicyApplied:      policy.Name,
		IsUserDefined:      isUserDefined,
		AutoDetectedUseCase: autoDetected,
		Suggestions:        suggestions,
	}
	
	nsis.logger.Info().
		Str("cid", string(contentCID)).
		Str("schema", string(schemaID)).
		Str("use_case", useCase).
		Float64("quality", result.QualityScore).
		Bool("is_user_defined", isUserDefined).
		Msg("Network schema-integrated storage completed")
	
	return result, nil
}

// determineUseCaseAndPolicy determines which use case and policy to apply
func (nsis *NetworkSchemaIntegratedService) determineUseCaseAndPolicy(req *NetworkSchemaAwareStoreRequest) (string, *SchemaPolicy, bool, bool, error) {
	// Ensure policy is loaded before proceeding
	nsis.ensurePolicyLoaded()
	
	nsis.policyMutex.RLock()
	defer nsis.policyMutex.RUnlock()
	
	var useCase string
	var autoDetected bool
	
	// 1. Use explicitly specified use case
	if req.UseCase != "" {
		useCase = req.UseCase
		
		// Check if it's a standard use case
		if policy, exists := nsis.networkPolicy.StandardUseCases[useCase]; exists {
			return useCase, &policy, false, false, nil
		}
		
		// Check if it's a user-defined use case
		if userUseCase, exists := nsis.getUserDefinedUseCase(useCase); exists {
			if userUseCase.IsActive && (userUseCase.AppIdentifier == req.AppID || req.AppID == "") {
				return useCase, &userUseCase.SchemaPolicy, true, false, nil
			}
		}
		
		return "", nil, false, false, fmt.Errorf("use case '%s' not found or not accessible", useCase)
	}
	
	// 2. Auto-detect based on content type mapping
	for contentPattern, mappedUseCase := range nsis.networkPolicy.ContentTypeMapping {
		if nsis.matchesContentType(req.ContentType, contentPattern) {
			useCase = mappedUseCase
			autoDetected = true
			break
		}
	}
	
	// 3. Fall back to network default
	if useCase == "" {
		useCase = nsis.networkPolicy.NetworkDefaults.DefaultUseCase
		autoDetected = true
	}
	
	// Get the policy for the determined use case
	if policy, exists := nsis.networkPolicy.StandardUseCases[useCase]; exists {
		return useCase, &policy, false, autoDetected, nil
	}
	
	return "", nil, false, false, fmt.Errorf("default use case '%s' not found in standard use cases", useCase)
}

// determineSchema determines which schema to use based on request and policy
func (nsis *NetworkSchemaIntegratedService) determineSchema(req *NetworkSchemaAwareStoreRequest, policy *SchemaPolicy) schema.SchemaID {
	// Use user-specified schema if provided and allowed
	if req.UserMetadata != nil {
		if userSchema, exists := req.UserMetadata["schema_id"]; exists {
			if schemaStr, ok := userSchema.(string); ok && schemaStr != "" {
				return schema.SchemaID(schemaStr)
			}
		}
	}
	
	// Use recommended schemas from policy
	if len(policy.RecommendedSchemas) > 0 {
		// Pick the first recommended schema that matches content type
		for _, recommendedSchema := range policy.RecommendedSchemas {
			if nsis.schemaMatchesContentType(recommendedSchema, req.ContentType) {
				return schema.SchemaID(recommendedSchema)
			}
		}
		// If none match exactly, use the first recommended schema
		return schema.SchemaID(policy.RecommendedSchemas[0])
	}
	
	// Fall back to content type-based suggestion
	return nsis.suggestSchemaFromContentType(req.ContentType)
}

// requiresSchema checks if schema is required based on policy
func (nsis *NetworkSchemaIntegratedService) requiresSchema(contentType string, policy *SchemaPolicy) bool {
	if policy.RequireSchemaForAllFiles {
		return true
	}
	
	for _, required := range policy.RequiredContentTypes {
		if nsis.matchesContentType(contentType, required) {
			return true
		}
	}
	
	return false
}

// extractNetworkMetadata extracts metadata according to network policy
func (nsis *NetworkSchemaIntegratedService) extractNetworkMetadata(contentType string, content []byte, filename string, policy *SchemaPolicy) *schema.ExtractionResult {
	// Use existing extraction logic but enhance based on policy
	extractionResult := &schema.ExtractionResult{
		ExtractedData: nsis.extractBasicMetadata(contentType, content),
		Confidence:    make(map[string]float64),
	}
	
	// Set confidence for basic extracted fields
	for field := range extractionResult.ExtractedData {
		extractionResult.Confidence[field] = 0.8
	}
	
	// Enhanced extraction based on policy auto-classification
	if policy.AutoClassification {
		// Add content classification metadata
		extractionResult.ExtractedData["content_classification"] = nsis.classifyContent(contentType, content)
		extractionResult.Confidence["content_classification"] = 0.9
		
		// Add use case specific metadata
		useCaseMetadata := nsis.extractUseCaseSpecificMetadata(contentType, content, policy)
		for field, value := range useCaseMetadata {
			extractionResult.ExtractedData[field] = value
			extractionResult.Confidence[field] = 0.7
		}
	}
	
	// Extract metadata from filename if provided
	if filename != "" {
		filenameMetadata := nsis.extractMetadataFromFilename(filename)
		for field, value := range filenameMetadata {
			if _, exists := extractionResult.ExtractedData[field]; !exists {
				extractionResult.ExtractedData[field] = value
				extractionResult.Confidence[field] = 0.9
			}
		}
	}
	
	return extractionResult
}

// mergeMetadata merges auto-extracted and user-provided metadata according to policy
func (nsis *NetworkSchemaIntegratedService) mergeMetadata(autoExtracted map[string]interface{}, userMetadata map[string]interface{}, policy *SchemaPolicy) (map[string]interface{}, map[string]bool) {
	finalMetadata := make(map[string]interface{})
	autoExtractedFlags := make(map[string]bool)
	
	// Start with auto-extracted data
	for field, value := range autoExtracted {
		finalMetadata[field] = value
		autoExtractedFlags[field] = true
	}
	
	// Override with user-provided data if policy allows
	if policy.AllowUserMetadataOverride && userMetadata != nil {
		for field, value := range userMetadata {
			finalMetadata[field] = value
			autoExtractedFlags[field] = false // User provided
		}
	}
	
	return finalMetadata, autoExtractedFlags
}

// validateQualityWithPolicy validates metadata quality according to policy
func (nsis *NetworkSchemaIntegratedService) validateQualityWithPolicy(metadata *schema.MetadataContainer, policy *SchemaPolicy) error {
	if metadata.QualityScore < policy.MinQualityScore {
		return fmt.Errorf("quality score %.2f below policy minimum %.2f", metadata.QualityScore, policy.MinQualityScore)
	}
	if metadata.CompletenessScore < policy.MinCompletenessScore {
		return fmt.Errorf("completeness score %.2f below policy minimum %.2f", metadata.CompletenessScore, policy.MinCompletenessScore)
	}
	return nil
}

// generatePolicySuggestions generates improvement suggestions based on policy
func (nsis *NetworkSchemaIntegratedService) generatePolicySuggestions(metadata *schema.MetadataContainer, policy *SchemaPolicy, useCase string, isUserDefined bool) []string {
	var suggestions []string
	
	// Policy-specific suggestions
	if metadata.QualityScore < policy.MinQualityScore {
		suggestions = append(suggestions, fmt.Sprintf("Quality score %.2f is below %s policy requirement of %.2f", 
			metadata.QualityScore, policy.Name, policy.MinQualityScore))
	}
	
	if metadata.CompletenessScore < policy.MinCompletenessScore {
		suggestions = append(suggestions, fmt.Sprintf("Completeness score %.2f is below %s policy requirement of %.2f", 
			metadata.CompletenessScore, policy.Name, policy.MinCompletenessScore))
	}
	
	// Field-specific suggestions
	if _, hasTitle := metadata.Data["title"]; !hasTitle {
		suggestions = append(suggestions, "Add a title to improve discoverability")
	}
	
	if _, hasTags := metadata.Data["tags"]; !hasTags && policy.AutoClassification {
		suggestions = append(suggestions, "Add tags to improve content classification")
	}
	
	// Use case specific suggestions
	if isUserDefined {
		suggestions = append(suggestions, fmt.Sprintf("Using custom use case '%s' - consider if a standard use case would be more appropriate", useCase))
	}
	
	// Policy improvement suggestions
	if policy.EnforcementLevel == "lenient" && metadata.QualityScore > 0.7 {
		suggestions = append(suggestions, "Content quality is high - consider using a stricter use case for better validation")
	}
	
	return suggestions
}

// getUserDefinedUseCase retrieves a user-defined use case
func (nsis *NetworkSchemaIntegratedService) getUserDefinedUseCase(useCaseID string) (*UserDefinedUseCase, bool) {
	nsis.cacheMutex.RLock()
	defer nsis.cacheMutex.RUnlock()
	
	useCase, exists := nsis.userUseCaseCache[useCaseID]
	return useCase, exists
}

// recordUserUseCaseUsage records usage statistics for user-defined use cases
func (nsis *NetworkSchemaIntegratedService) recordUserUseCaseUsage(useCaseID, appID string) {
	go func() {
		// Update usage statistics in background
		nsis.cacheMutex.Lock()
		defer nsis.cacheMutex.Unlock()
		
		if useCase, exists := nsis.userUseCaseCache[useCaseID]; exists {
			useCase.UsageCount++
			useCase.LastUsed = time.Now()
			
			// Save back to VFS
			nsis.saveUserDefinedUseCase(useCaseID, useCase)
		}
	}()
}

// Helper methods from the original implementation
func (nsis *NetworkSchemaIntegratedService) detectContentType(filename string, content []byte) string {
	// Use the existing implementation from schema_integrated_service.go
	// (This would be the same detectContentType method)
	return "application/octet-stream" // Placeholder
}

func (nsis *NetworkSchemaIntegratedService) suggestSchemaFromContentType(contentType string) schema.SchemaID {
	// Use the existing implementation from schema_integrated_service.go
	// (This would be the same suggestSchemaFromContentType method)
	return schema.SchemaID("generic/v1") // Placeholder
}

func (nsis *NetworkSchemaIntegratedService) extractBasicMetadata(contentType string, content []byte) map[string]interface{} {
	// Use the existing implementation from schema_integrated_service.go
	// (This would be the same extractBasicMetadata method)
	return map[string]interface{}{
		"content_type": contentType,
		"size":         len(content),
	}
}

func (nsis *NetworkSchemaIntegratedService) extractMetadataFromFilename(filename string) map[string]interface{} {
	// Use the existing implementation from schema_integrated_service.go
	// (This would be the same extractMetadataFromFilename method)
	return map[string]interface{}{
		"original_filename": filename,
	}
}

// New helper methods for network-wide functionality
func (nsis *NetworkSchemaIntegratedService) schemaMatchesContentType(schemaID, contentType string) bool {
	// Basic matching logic - could be enhanced
	if strings.Contains(schemaID, "image") && strings.HasPrefix(contentType, "image/") {
		return true
	}
	if strings.Contains(schemaID, "video") && strings.HasPrefix(contentType, "video/") {
		return true
	}
	return false
}

func (nsis *NetworkSchemaIntegratedService) classifyContent(contentType string, content []byte) string {
	// Basic content classification - could be enhanced with ML
	switch {
	case strings.HasPrefix(contentType, "image/"):
		return "visual_media"
	case strings.HasPrefix(contentType, "video/"):
		return "video_media"
	case strings.HasPrefix(contentType, "audio/"):
		return "audio_media"
	case strings.HasPrefix(contentType, "text/"):
		return "text_document"
	default:
		return "binary_data"
	}
}

func (nsis *NetworkSchemaIntegratedService) extractUseCaseSpecificMetadata(contentType string, content []byte, policy *SchemaPolicy) map[string]interface{} {
	metadata := make(map[string]interface{})
	
	// Add use case specific metadata based on policy
	metadata["use_case_type"] = policy.Name
	metadata["enforcement_level"] = policy.EnforcementLevel
	metadata["extraction_timestamp"] = time.Now().Format(time.RFC3339)
	
	return metadata
}

