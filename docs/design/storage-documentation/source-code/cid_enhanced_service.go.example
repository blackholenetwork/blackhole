package storage

import (
	"context"
	"fmt"
	"io"
	"sync"
	"time"

	"github.com/blackholenetwork/blackhole/pkg/core"
	"github.com/rs/zerolog"
)

// CIDEnhancedStorageService implements the Storage Service interface with pure content-based CIDs
type CIDEnhancedStorageService struct {
	*core.BaseService

	config *Config
	logger zerolog.Logger

	// Core CID system
	cidSystem    *CIDSystem
	erasureCoder *AdaptiveErasureCoder

	// Storage components
	chunkStore   *ChunkStore

	// Virtual bucket system with node management
	bucketSystem     *SimpleBucketSystem
	nodeManager      *NodeManager
	negotiationEngine *PositionNegotiationEngine
	healthMonitor    *PositionHealthMonitor

	// Local node information
	localNodeID   NodeID
	localNodeInfo *NodeDetails

	// Minimal operational tracking (optional)
	accessTracker *AccessTracker
	accessMutex   sync.RWMutex

	// CID to chunk mapping cache
	cidChunkCache map[ContentCID][]ChunkCID
	cacheMutex    sync.RWMutex

	// Virtual filesystem
	vfs        *VirtualFilesystem
	privateVFS *PrivateVFS
}

// AccessTracker provides minimal operational data for optimization
type AccessTracker struct {
	lastAccess   map[ContentCID]time.Time
	accessCount  map[ContentCID]int64
	chunkAccess  map[ChunkCID]time.Time
}

// NewCIDEnhancedStorageService creates a new CID-based enhanced storage service
func NewCIDEnhancedStorageService(config *Config, logger zerolog.Logger, metrics core.MetricsCollector) (*CIDEnhancedStorageService, error) {
	// Create core systems
	cidSystem := NewCIDSystem()
	erasureCoder := NewAdaptiveErasureCoder(config.Erasure.BaselineDataShards)
	chunkStore := NewChunkStore(config.DataDir + "/chunks")

	// Create local node ID (in real system would use network service node ID)
	localNodeID := NodeID("cid-node-" + fmt.Sprintf("%d", time.Now().Unix()))

	// Create virtual bucket system
	bucketSystem := NewSimpleBucketSystem()
	nodeManager := NewNodeManager(bucketSystem, localNodeID)
	negotiationEngine := NewPositionNegotiationEngine(nodeManager)
	healthMonitor := NewPositionHealthMonitor(nodeManager)

	// Create local node info
	localNodeInfo := &NodeDetails{
		ID:               localNodeID,
		Address:          "127.0.0.1:8080",
		AvailableStorage: 100 * 1024 * 1024 * 1024, // 100GB
		StorageCapacity:  100 * 1024 * 1024 * 1024, // 100GB
		ClaimedPositions: make([]GlobalPosition, 0),
		PositionStrategy: CreateDefaultStrategies()[DynamicStrategy],
		LastSeen:         time.Now(),
		JoinedAt:         time.Now(),
	}

	// Optional access tracking
	accessTracker := &AccessTracker{
		lastAccess:  make(map[ContentCID]time.Time),
		accessCount: make(map[ContentCID]int64),
		chunkAccess: make(map[ChunkCID]time.Time),
	}

	// Create storage service first
	service := &CIDEnhancedStorageService{
		BaseService:       core.NewBaseService("storage"),
		config:            config,
		logger:            logger.With().Str("service", "cid_enhanced_storage").Str("node_id", string(localNodeID)).Logger(),
		cidSystem:         cidSystem,
		erasureCoder:      erasureCoder,
		chunkStore:        chunkStore,
		bucketSystem:      bucketSystem,
		nodeManager:       nodeManager,
		negotiationEngine: negotiationEngine,
		healthMonitor:     healthMonitor,
		localNodeID:       localNodeID,
		localNodeInfo:     localNodeInfo,
		accessTracker:     accessTracker,
		cidChunkCache:     make(map[ContentCID][]ChunkCID),
	}

	// Initialize VFS with this service
	vfsConfig := config.VFS
	if vfsConfig == nil {
		vfsConfig = DefaultVFSConfig()
	}

	vfs, err := NewVirtualFilesystem(service, vfsConfig, logger)
	if err != nil {
		return nil, fmt.Errorf("failed to create virtual filesystem: %w", err)
	}
	service.vfs = vfs

	// Initialize PrivateVFS if user DID is provided
	if config.UserDID != "" {
		privateVFS, err := NewPrivateVFSWithExistingVFS(vfs, logger, config.UserDID)
		if err != nil {
			return nil, fmt.Errorf("failed to create private virtual filesystem: %w", err)
		}

		// Load or generate user secret
		if config.UserSecret != "" {
			if err := privateVFS.LoadUserSecret(config.UserSecret); err != nil {
				return nil, fmt.Errorf("failed to load user secret: %w", err)
			}
		} else {
			// Generate new secret
			secret, err := privateVFS.GenerateUserSecret()
			if err != nil {
				return nil, fmt.Errorf("failed to generate user secret: %w", err)
			}
			logger.Info().
				Str("user_did", config.UserDID).
				Str("user_secret", secret).
				Msg("Generated new user secret for private VFS - SAVE THIS SECRET!")
		}

		service.privateVFS = privateVFS
	}

	return service, nil
}

// Start starts the CID enhanced storage service
func (ces *CIDEnhancedStorageService) Start(ctx context.Context) error {
	ces.logger.Info().Msg("Starting CID enhanced storage service")

	// Initialize chunk store
	if err := ces.chunkStore.Initialize(); err != nil {
		return fmt.Errorf("failed to initialize chunk store: %w", err)
	}

	// Register local node
	if err := ces.nodeManager.RegisterNode(ces.localNodeInfo); err != nil {
		return fmt.Errorf("failed to register local node: %w", err)
	}

	// Claim initial positions
	claimResult, err := ces.nodeManager.ClaimPositions(ces.localNodeID)
	if err != nil {
		ces.logger.Warn().Err(err).Msg("Failed to claim initial positions")
	} else if claimResult.Success {
		ces.logger.Info().
			Int("positions_claimed", len(claimResult.ClaimedPositions)).
			Str("strategy", string(ces.localNodeInfo.PositionStrategy.Type)).
			Msg("Successfully claimed initial positions")
	}

	// Start VFS
	if ces.vfs != nil {
		if err := ces.vfs.Start(ctx); err != nil {
			return fmt.Errorf("failed to start virtual filesystem: %w", err)
		}
	}

	// Start PrivateVFS
	if ces.privateVFS != nil {
		if err := ces.privateVFS.Start(ctx); err != nil {
			return fmt.Errorf("failed to start private virtual filesystem: %w", err)
		}
	}

	ces.MarkStarted()
	ces.logger.Info().
		Str("node_id", string(ces.localNodeID)).
		Int("claimed_positions", len(ces.localNodeInfo.ClaimedPositions)).
		Msg("CID enhanced storage service started with pure content-based addressing")

	return nil
}

// Stop stops the CID enhanced storage service
func (ces *CIDEnhancedStorageService) Stop(ctx context.Context) error {
	ces.logger.Info().Msg("Stopping CID enhanced storage service")

	// Stop PrivateVFS
	if ces.privateVFS != nil {
		if err := ces.privateVFS.Stop(ctx); err != nil {
			ces.logger.Warn().Err(err).Msg("Failed to stop private virtual filesystem")
		}
	}

	// Stop VFS
	if ces.vfs != nil {
		if err := ces.vfs.Stop(ctx); err != nil {
			ces.logger.Warn().Err(err).Msg("Failed to stop virtual filesystem")
		}
	}

	ces.chunkStore.Close()

	ces.logger.Info().Msg("CID enhanced storage service stopped")
	return nil
}

// Store stores content and returns only the CID (no metadata needed)
func (ces *CIDEnhancedStorageService) Store(ctx context.Context, reader io.Reader) (ContentCID, error) {
	startTime := time.Now()

	// Generate CID from content
	cid, content, err := ces.cidSystem.GenerateFileCIDFromReader(reader)
	if err != nil {
		return "", fmt.Errorf("failed to generate CID: %w", err)
	}

	// Check if content already exists (deduplication)
	if ces.HasContent(ctx, cid) {
		ces.logger.Info().
			Str("cid", string(cid)).
			Msg("Content already exists - deduplication applied")
		return cid, nil
	}

	ces.logger.Info().
		Str("cid", string(cid)).
		Int("size", len(content)).
		Msg("Storing new content by CID")

	// Calculate file properties
	fileProps := ces.cidSystem.CalculateFileProperties(content)

	// Chunk the content using content-based IDs
	chunks := ces.chunkContentToCIDs(content)

	// Store all data chunks with position claiming
	for _, chunk := range chunks {
		if err := ces.storeChunkWithPositionClaiming(chunk); err != nil {
			return "", fmt.Errorf("failed to store chunk %s: %w", chunk.CID, err)
		}
	}

	// Generate and store parity chunks
	if err := ces.generateAndStoreParityChunks(chunks, cid, fileProps); err != nil {
		ces.logger.Warn().Err(err).Str("cid", string(cid)).Msg("Failed to generate parity chunks")
	}

	// Cache chunk CIDs for this content CID
	chunkCIDs := make([]ChunkCID, len(chunks))
	for i, chunk := range chunks {
		chunkCIDs[i] = chunk.CID
	}
	ces.cacheMutex.Lock()
	ces.cidChunkCache[cid] = chunkCIDs
	ces.cacheMutex.Unlock()

	// Track access
	ces.trackContentAccess(cid)

	duration := time.Since(startTime)
	ces.logger.Info().
		Str("cid", string(cid)).
		Int("chunks", len(chunks)).
		Int("blocks", fileProps.BlockCount).
		Dur("duration", duration).
		Msg("Content stored successfully with CID-based addressing")

	return cid, nil
}

// Retrieve reconstructs content from CID with virtual bucket system
func (ces *CIDEnhancedStorageService) Retrieve(ctx context.Context, cid ContentCID) (io.ReadCloser, error) {
	startTime := time.Now()

	ces.logger.Info().Str("cid", string(cid)).Msg("Retrieving content by CID")

	// Track access
	ces.trackContentAccess(cid)

	// Create pipe for streaming
	reader, writer := io.Pipe()

	// Start reconstruction in background
	go func() {
		defer writer.Close()

		if err := ces.reconstructContentFromCID(cid, writer); err != nil {
			ces.logger.Error().Err(err).Str("cid", string(cid)).Msg("Failed to reconstruct content")
			writer.CloseWithError(err)
			return
		}

		duration := time.Since(startTime)
		ces.logger.Info().
			Str("cid", string(cid)).
			Dur("duration", duration).
			Msg("Content retrieved successfully by CID")
	}()

	return reader, nil
}

// Delete removes all chunks for a CID
func (ces *CIDEnhancedStorageService) Delete(ctx context.Context, cid ContentCID) error {
	ces.logger.Info().Str("cid", string(cid)).Msg("Deleting content by CID")

	// Get chunk CIDs for this content
	chunkCIDs, err := ces.getChunkCIDsForContent(ctx, cid)
	if err != nil {
		return fmt.Errorf("failed to get chunks for content: %w", err)
	}
	if len(chunkCIDs) == 0 {
		return fmt.Errorf("content not found: %s", cid)
	}

	// Delete all chunks
	deletedCount := 0
	for _, chunkCID := range chunkCIDs {
		if err := ces.chunkStore.Delete(chunkCID); err != nil {
			ces.logger.Warn().Err(err).Str("chunk_cid", string(chunkCID)).Msg("Failed to delete chunk")
		} else {
			deletedCount++
		}
	}

	// Remove from cache
	ces.cacheMutex.Lock()
	delete(ces.cidChunkCache, cid)
	ces.cacheMutex.Unlock()

	// Remove from access tracking
	ces.accessMutex.Lock()
	delete(ces.accessTracker.lastAccess, cid)
	delete(ces.accessTracker.accessCount, cid)
	ces.accessMutex.Unlock()

	ces.logger.Info().
		Str("cid", string(cid)).
		Int("chunks_deleted", deletedCount).
		Int("total_chunks", len(chunkCIDs)).
		Msg("Content deleted by CID")

	return nil
}

// HasContent checks if content is available by CID
func (ces *CIDEnhancedStorageService) HasContent(ctx context.Context, cid ContentCID) bool {
	chunkCIDs, err := ces.getChunkCIDsForContent(ctx, cid)
	if err != nil || len(chunkCIDs) == 0 {
		return false
	}

	// Check if we have enough chunks to reconstruct (need at least k data chunks per block)
	availableChunks := 0
	for _, chunkCID := range chunkCIDs {
		if ces.chunkStore.Has(chunkCID) {
			availableChunks++
		}
	}

	// Simplified check: if we have any chunks, consider content available
	// In practice, this would be more sophisticated with erasure coding awareness
	return availableChunks > 0
}

// GetContentInfo returns minimal derivable information about content
func (ces *CIDEnhancedStorageService) GetContentInfo(ctx context.Context, cid ContentCID) (ContentInfo, error) {
	info := ContentInfo{
		CID:       cid,
		Available: ces.HasContent(ctx, cid),
	}

	// Add access information if tracked
	ces.accessMutex.RLock()
	if lastAccess, exists := ces.accessTracker.lastAccess[cid]; exists {
		info.LastAccess = &lastAccess
		info.AccessCount = ces.accessTracker.accessCount[cid]
	}
	ces.accessMutex.RUnlock()

	// Try to derive size from chunks if available
	chunkCIDs, err := ces.getChunkCIDsForContent(ctx, cid)
	if err == nil && len(chunkCIDs) > 0 {
		totalSize := uint64(0)
		for _, chunkCID := range chunkCIDs {
			if chunk, err := ces.chunkStore.Retrieve(chunkCID); err == nil {
				totalSize += uint64(len(chunk.Data))
			}
		}
		if totalSize > 0 {
			info.Size = totalSize
			info.ChunkCount = len(chunkCIDs)
			info.BlockCount = (len(chunkCIDs) + ces.config.BlockSize - 1) / ces.config.BlockSize
			info.ParityLevel = fmt.Sprintf("%d+%d", ces.config.Erasure.BaselineDataShards, ces.config.Erasure.BaselineParityShards)
		}
	}

	return info, nil
}

// Virtual bucket system operations implementation

// GetChunkStorageLocation returns deterministic storage locations for a chunk CID
func (ces *CIDEnhancedStorageService) GetChunkStorageLocation(chunkCID ChunkCID) (StorageLocation, bool) {
	location := ces.cidSystem.DeriveStorageLocations(chunkCID)
	return location, true
}

// FindChunkNodes returns nodes that should store a specific chunk
func (ces *CIDEnhancedStorageService) FindChunkNodes(chunkCID ChunkCID) ([]*NodeInfo, error) {
	// Get storage locations for the chunk
	locations := ces.cidSystem.DeriveStorageLocations(chunkCID)

	var nodes []*NodeInfo
	positions := []GlobalPosition{locations.Primary.Global, locations.Secondary.Global, locations.Tertiary.Global}

	for _, position := range positions {
		if nodeID, claimed := ces.nodeManager.GetNodeForPosition(position); claimed {
			if nodeDetails, _, err := ces.nodeManager.GetNodeStats(nodeID); err == nil {
				nodes = append(nodes, &NodeInfo{ID: string(nodeDetails.ID)})
			}
		}
	}

	return nodes, nil
}

// GetBucketSystemStats returns bucket system statistics
func (ces *CIDEnhancedStorageService) GetBucketSystemStats() BucketSystemStats {
	return ces.bucketSystem.GetBucketSystemStats()
}

// GetVFS returns the virtual filesystem interface
func (ces *CIDEnhancedStorageService) GetVFS() VirtualFilesystemInterface {
	return ces.vfs
}

// GetPrivateVFS returns the private virtual filesystem interface
func (ces *CIDEnhancedStorageService) GetPrivateVFS() PrivateVFSInterface {
	return ces.privateVFS
}

// StoreChunkInBucket stores data as a chunk in a specific bucket (for VFS use)
func (ces *CIDEnhancedStorageService) StoreChunkInBucket(bucketID int, chunkID string, data []byte) error {
	// Create a content-based chunk for storage
	chunk := &ContentBasedChunk{
		CID:      ChunkCID(chunkID),
		Data:     data,
		IsParity: false,
	}

	// Store chunk using existing chunk storage
	return ces.chunkStore.Store(chunk)
}

// RetrieveChunkFromBucket retrieves data from a specific bucket by chunk ID (for VFS use)
func (ces *CIDEnhancedStorageService) RetrieveChunkFromBucket(bucketID int, chunkID string) ([]byte, error) {
	// Retrieve chunk by ID
	chunk, err := ces.chunkStore.Retrieve(ChunkCID(chunkID))
	if err != nil {
		return nil, fmt.Errorf("chunk not found: %s", chunkID)
	}

	return chunk.Data, nil
}

