// Helper methods for CIDEnhancedStorageService

// chunkContentToCIDs converts content into content-based chunks
func (ces *CIDEnhancedStorageService) chunkContentToCIDs(content []byte) []*ContentBasedChunk {
	var chunks []*ContentBasedChunk

	chunkSize := ces.cidSystem.chunkSize
	for i := 0; i < len(content); i += chunkSize {
		end := i + chunkSize
		if end > len(content) {
			end = len(content)
		}

		chunkData := content[i:end]
		chunkCID := ces.cidSystem.GenerateChunkCID(chunkData)

		chunk := &ContentBasedChunk{
			CID:      chunkCID,
			Data:     chunkData,
			IsParity: false,
		}

		chunks = append(chunks, chunk)
	}

	return chunks
}

// storeChunkWithPositionClaiming stores a chunk and handles position claiming
func (ces *CIDEnhancedStorageService) storeChunkWithPositionClaiming(chunk *ContentBasedChunk) error {
	// Validate chunk
	if !ces.cidSystem.ValidateChunk(chunk) {
		return fmt.Errorf("chunk CID validation failed: %s", chunk.CID)
	}

	// Get deterministic storage locations
	locations := ces.cidSystem.DeriveStorageLocations(chunk.CID)

	// Handle position claiming for chunk storage
	if err := ces.handleChunkPositionClaiming(chunk.CID, locations); err != nil {
		ces.logger.Warn().Err(err).Str("chunk_cid", string(chunk.CID)).Msg("Position claiming failed")
	}

	// Store the chunk directly (no conversion needed)
	if err := ces.chunkStore.Store(chunk); err != nil {
		return fmt.Errorf("failed to store chunk in chunk store: %w", err)
	}

	// Record chunk access for health monitoring
	ces.trackChunkAccess(chunk.CID)

	return nil
}

// handleChunkPositionClaiming handles position claiming for chunk storage
func (ces *CIDEnhancedStorageService) handleChunkPositionClaiming(chunkCID ChunkCID, locations StorageLocation) error {
	positions := []GlobalPosition{locations.Primary.Global, locations.Secondary.Global, locations.Tertiary.Global}

	for _, position := range positions {
		// Check if position is claimed
		if ownerID, claimed := ces.nodeManager.GetNodeForPosition(position); claimed {
			// Position already claimed
			if ownerID == ces.localNodeID {
				// We own this position - perfect
				ces.logger.Debug().
					Str("chunk_cid", string(chunkCID)).
					Uint64("position", uint64(position)).
					Msg("Chunk maps to our owned position")
				return nil
			} else {
				// Another node owns this position - could negotiate
				ces.logger.Debug().
					Str("chunk_cid", string(chunkCID)).
					Uint64("position", uint64(position)).
					Str("owner", string(ownerID)).
					Msg("Chunk maps to position owned by another node")
			}
		} else {
			// Position unclaimed - try to claim it
			if ces.nodeManager.CanClaimMorePositions(ces.localNodeID) {
				if err := ces.nodeManager.ClaimSpecificPosition(ces.localNodeID, position); err != nil {
					ces.logger.Debug().Err(err).
						Str("chunk_cid", string(chunkCID)).
						Uint64("position", uint64(position)).
						Msg("Failed to claim position for chunk")
				} else {
					ces.logger.Debug().
						Str("chunk_cid", string(chunkCID)).
						Uint64("position", uint64(position)).
						Msg("Successfully claimed position for chunk")
					return nil
				}
			}
		}
	}

	return nil // Not an error if we can't claim - chunk still gets stored locally
}

// generateAndStoreParityChunks generates and stores parity chunks using 10+3 erasure coding
func (ces *CIDEnhancedStorageService) generateAndStoreParityChunks(dataChunks []*ContentBasedChunk, contentCID ContentCID, fileProps FileProperties) error {
	blockSize := ces.cidSystem.blockSize

	for blockIdx := 0; blockIdx < fileProps.BlockCount; blockIdx++ {
		start := blockIdx * blockSize
		end := start + blockSize
		if end > len(dataChunks) {
			end = len(dataChunks)
		}

		// Prepare data for erasure coding
		blockData := make([][]byte, blockSize)
		for i := 0; i < blockSize; i++ {
			if start+i < len(dataChunks) {
				blockData[i] = dataChunks[start+i].Data
			} else {
				blockData[i] = nil // Padding for incomplete blocks
			}
		}

		// Generate parity using erasure coding
		coder, err := ces.erasureCoder.GetCoder(ces.config.Erasure.BaselineParityShards)
		if err != nil {
			return fmt.Errorf("failed to get erasure coder: %w", err)
		}

		parityData, err := coder.Encode(blockData)
		if err != nil {
			return fmt.Errorf("failed to encode block %d: %w", blockIdx, err)
		}

		// Create and store parity chunks
		for i, parity := range parityData {
			if parity != nil {
				parityCID := ces.cidSystem.GenerateChunkCID(parity)
				parityChunk := &ContentBasedChunk{
					CID:      parityCID,
					Data:     parity,
					IsParity: true,
				}

				if err := ces.storeChunkWithPositionClaiming(parityChunk); err != nil {
					ces.logger.Warn().Err(err).
						Str("parity_cid", string(parityCID)).
						Int("block", blockIdx).
						Int("parity_index", i).
						Msg("Failed to store parity chunk")
				}
			}
		}
	}

	return nil
}

// reconstructContentFromCID reconstructs content from CID and streams it
func (ces *CIDEnhancedStorageService) reconstructContentFromCID(cid ContentCID, writer io.Writer) error {
	// Get chunk CIDs for this content
	ctx := context.Background()
	chunkCIDs, err := ces.getChunkCIDsForContent(ctx, cid)
	if err != nil {
		return fmt.Errorf("failed to get chunks for content CID %s: %w", cid, err)
	}
	if len(chunkCIDs) == 0 {
		return fmt.Errorf("no chunks found for content CID: %s", cid)
	}

	// Retrieve chunks in order
	var chunks []*ContentBasedChunk
	for _, chunkCID := range chunkCIDs {
		chunk, err := ces.RetrieveChunk(nil, chunkCID)
		if err != nil {
			return fmt.Errorf("failed to retrieve chunk %s: %w", chunkCID, err)
		}
		chunks = append(chunks, chunk)
	}

	// Write chunks in order to reconstruct file
	for _, chunk := range chunks {
		if _, err := writer.Write(chunk.Data); err != nil {
			return fmt.Errorf("failed to write chunk data: %w", err)
		}
	}

	return nil
}

// getChunkCIDsForContent returns chunk CIDs for a content CID with enhanced discovery
func (ces *CIDEnhancedStorageService) getChunkCIDsForContent(ctx context.Context, cid ContentCID) ([]ChunkCID, error) {
	// Check cache first
	ces.cacheMutex.RLock()
	if chunkCIDs, exists := ces.cidChunkCache[cid]; exists {
		ces.cacheMutex.RUnlock()
		return chunkCIDs, nil
	}
	ces.cacheMutex.RUnlock()

	ces.logger.Debug().
		Str("content_cid", string(cid)).
		Msg("Cache miss - discovering chunks for content")

	var discoveredChunks []ChunkCID

	// Method 1: Scan local chunk store for chunks with matching parent content CID
	localChunks, err := ces.discoverLocalChunks(ctx, cid)
	if err != nil {
		ces.logger.Warn().Err(err).Msg("Failed to discover local chunks")
	} else {
		discoveredChunks = append(discoveredChunks, localChunks...)
	}

	// Method 2: Query network for chunks (if we have less than required for reconstruction)
	if len(discoveredChunks) < ces.config.Erasure.BaselineDataShards {
		networkChunks, err := ces.discoverNetworkChunks(ctx, cid)
		if err != nil {
			ces.logger.Debug().Err(err).Msg("Failed to discover network chunks")
		} else {
			// Merge and deduplicate
			discoveredChunks = ces.mergeChunkCIDs(discoveredChunks, networkChunks)
		}
	}

	// Method 3: Derive expected chunk CIDs if we have metadata about the content
	if len(discoveredChunks) == 0 {
		derivedChunks, err := ces.deriveExpectedChunks(ctx, cid)
		if err != nil {
			ces.logger.Debug().Err(err).Msg("Failed to derive expected chunks")
		} else {
			discoveredChunks = derivedChunks
		}
	}

	// Cache the results if we found any chunks
	if len(discoveredChunks) > 0 {
		ces.cacheMutex.Lock()
		ces.cidChunkCache[cid] = discoveredChunks
		ces.cacheMutex.Unlock()

		ces.logger.Info().
			Str("content_cid", string(cid)).
			Int("discovered_chunks", len(discoveredChunks)).
			Msg("Successfully discovered chunks for content")
	}

	return discoveredChunks, nil
}

// discoverLocalChunks scans local storage for chunks belonging to a content CID
func (ces *CIDEnhancedStorageService) discoverLocalChunks(ctx context.Context, cid ContentCID) ([]ChunkCID, error) {
	var localChunks []ChunkCID

	// List all chunks in local storage
	allChunks, err := ces.chunkStore.List()
	if err != nil {
		return nil, fmt.Errorf("failed to list local chunks: %w", err)
	}

	// Filter chunks that belong to this content
	for _, chunkCID := range allChunks {
		_, err := ces.chunkStore.Retrieve(chunkCID)
		if err != nil {
			continue
		}

		// For now, we'll add all chunks since we don't have parent tracking
		// In practice, we'd need metadata to associate chunks with content
		localChunks = append(localChunks, chunkCID)
	}

	return localChunks, nil
}

// discoverNetworkChunks queries the network for chunks of a content CID
func (ces *CIDEnhancedStorageService) discoverNetworkChunks(ctx context.Context, cid ContentCID) ([]ChunkCID, error) {
	var networkChunks []ChunkCID

	// Use the deterministic placement to find where chunks should be stored
	// For each potential chunk, calculate where it should be and query those nodes

	// Generate potential chunk CIDs based on content structure
	// This is a simplified approach - in practice we'd use DHT or other discovery mechanisms
	potentialChunks := ces.generatePotentialChunkCIDs(cid)

	for _, chunkCID := range potentialChunks {
		// Find nodes that should have this chunk
		nodes, err := ces.FindChunkNodes(chunkCID)
		if err != nil {
			continue
		}

		// Query each node to see if they have the chunk
		for _, node := range nodes {
			if ces.queryNodeForChunk(ctx, node, chunkCID) {
				networkChunks = append(networkChunks, chunkCID)
				break // Found it, move to next chunk
			}
		}
	}

	return networkChunks, nil
}

