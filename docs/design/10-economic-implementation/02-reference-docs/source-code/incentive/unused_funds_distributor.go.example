package incentive

import (
	"context"
	"fmt"
	"sync"
	"time"

	"github.com/rs/zerolog"
)

// UnusedFundsDistributor handles periodic distribution of accumulated unused funds from inactive subscribers
type UnusedFundsDistributor struct {
	mu                    sync.RWMutex
	logger                zerolog.Logger
	config                *Config
	marketPricing         *MarketPricingModel
	
	// Accumulated unused funds from 25% infrastructure pool when no active providers
	unusedFundsPool       float64
	lastDistributionTime  time.Time
	
	// Distribution settings
	distributionInterval  time.Duration // How often to distribute unused funds
	
	// Provider usage tracking for ALL users (subscribers + free users)
	providerUsageAllUsers map[string]*ProviderUsageAllUsers
	
	// Historical tracking
	distributionHistory   []*UnusedFundsDistribution
	maxHistorySize        int
	
	// Control
	started               bool
	stopChan              chan struct{}
	wg                    sync.WaitGroup
}

// ProviderUsageAllUsers tracks provider usage for both paying subscribers AND free users
type ProviderUsageAllUsers struct {
	ProviderID              string    `json:"provider_id"`
	LastUpdateTime          time.Time `json:"last_update_time"`
	
	// Usage from paying subscribers
	SubscriberStorageGBHours  float64 `json:"subscriber_storage_gb_hours"`
	SubscriberBandwidthGB     float64 `json:"subscriber_bandwidth_gb"`
	SubscriberCPUHours        float64 `json:"subscriber_cpu_hours"`
	SubscriberGPUHours        float64 `json:"subscriber_gpu_hours"`
	SubscriberMemoryGBHours   float64 `json:"subscriber_memory_gb_hours"`
	
	// Usage from free users
	FreeUserStorageGBHours    float64 `json:"free_user_storage_gb_hours"`
	FreeUserBandwidthGB       float64 `json:"free_user_bandwidth_gb"`
	FreeUserCPUHours          float64 `json:"free_user_cpu_hours"`
	FreeUserGPUHours          float64 `json:"free_user_gpu_hours"`
	FreeUserMemoryGBHours     float64 `json:"free_user_memory_gb_hours"`
	
	// Total market value (subscribers + free users)
	TotalMarketValue          float64 `json:"total_market_value"`
}

// UnusedFundsDistribution represents a single unused funds distribution event
type UnusedFundsDistribution struct {
	Timestamp             time.Time            `json:"timestamp"`
	TotalAmount           float64              `json:"total_amount"`
	ProviderRewards       map[string]float64   `json:"provider_rewards"`
	DistributionPeriod    string               `json:"distribution_period"`
	TotalProviders        int                  `json:"total_providers"`
	TotalMarketValue      float64              `json:"total_market_value"`
}

// NewUnusedFundsDistributor creates a new unused funds distributor
func NewUnusedFundsDistributor(config *Config, logger zerolog.Logger) *UnusedFundsDistributor {
	return &UnusedFundsDistributor{
		logger:                logger.With().Str("component", "unused_funds_distributor").Logger(),
		config:                config,
		marketPricing:         NewMarketPricingModel(),
		distributionInterval:  24 * time.Hour,  // Daily distribution
		distributionHistory:   make([]*UnusedFundsDistribution, 0),
		maxHistorySize:        30,              // Keep 30 days of history
		providerUsageAllUsers: make(map[string]*ProviderUsageAllUsers),
		stopChan:              make(chan struct{}),
	}
}

// Start begins the unused funds distribution process
func (ufd *UnusedFundsDistributor) Start(ctx context.Context) error {
	ufd.mu.Lock()
	defer ufd.mu.Unlock()
	
	if ufd.started {
		return fmt.Errorf("unused funds distributor already started")
	}
	
	ufd.logger.Info().Msg("Starting unused funds distributor")
	
	// Start distribution worker
	ufd.wg.Add(1)
	go ufd.distributionWorker(ctx)
	
	ufd.started = true
	ufd.logger.Info().
		Dur("interval", ufd.distributionInterval).
		Msg("Unused funds distributor started")
	
	return nil
}

// Stop stops the unused funds distributor
func (ufd *UnusedFundsDistributor) Stop(ctx context.Context) error {
	ufd.mu.Lock()
	defer ufd.mu.Unlock()
	
	if !ufd.started {
		return nil
	}
	
	ufd.logger.Info().Msg("Stopping unused funds distributor")
	
	close(ufd.stopChan)
	ufd.wg.Wait()
	
	ufd.started = false
	ufd.logger.Info().Msg("Unused funds distributor stopped")
	
	return nil
}

// AddUnusedFunds adds funds to the unused funds pool (from inactive subscriber periods)
func (ufd *UnusedFundsDistributor) AddUnusedFunds(amount float64) {
	ufd.mu.Lock()
	defer ufd.mu.Unlock()
	
	ufd.unusedFundsPool += amount
	
	ufd.logger.Debug().
		Float64("amount", amount).
		Float64("total_pool", ufd.unusedFundsPool).
		Msg("Unused funds from inactive subscribers added")
}

// RecordProviderUsageAllUsers records provider usage for both subscribers and free users
func (ufd *UnusedFundsDistributor) RecordProviderUsageAllUsers(
	providerID string,
	subscriberUsage, freeUserUsage ProviderContribution,
) {
	ufd.mu.Lock()
	defer ufd.mu.Unlock()
	
	now := time.Now()
	
	usage, exists := ufd.providerUsageAllUsers[providerID]
	if !exists {
		usage = &ProviderUsageAllUsers{
			ProviderID: providerID,
		}
		ufd.providerUsageAllUsers[providerID] = usage
	}
	
	usage.LastUpdateTime = now
	
	// Record subscriber usage
	usage.SubscriberStorageGBHours = subscriberUsage.StorageGBHours
	usage.SubscriberBandwidthGB = subscriberUsage.BandwidthGB
	usage.SubscriberCPUHours = subscriberUsage.CPUHours
	usage.SubscriberGPUHours = subscriberUsage.GPUHours
	usage.SubscriberMemoryGBHours = subscriberUsage.MemoryGBHours
	
	// Record free user usage
	usage.FreeUserStorageGBHours = freeUserUsage.StorageGBHours
	usage.FreeUserBandwidthGB = freeUserUsage.BandwidthGB
	usage.FreeUserCPUHours = freeUserUsage.CPUHours
	usage.FreeUserGPUHours = freeUserUsage.GPUHours
	usage.FreeUserMemoryGBHours = freeUserUsage.MemoryGBHours
	
	// Calculate total market value (subscribers + free users)
	usage.TotalMarketValue = ufd.calculateTotalMarketValue(usage)
	
	ufd.logger.Debug().
		Str("provider_id", providerID).
		Float64("subscriber_market_value", ufd.calculateSubscriberMarketValue(usage)).
		Float64("free_user_market_value", ufd.calculateFreeUserMarketValue(usage)).
		Float64("total_market_value", usage.TotalMarketValue).
		Msg("Provider usage for all users recorded")
}

// calculateTotalMarketValue calculates total market value including both subscriber and free user contributions
func (ufd *UnusedFundsDistributor) calculateTotalMarketValue(usage *ProviderUsageAllUsers) float64 {
	return ufd.calculateSubscriberMarketValue(usage) + ufd.calculateFreeUserMarketValue(usage)
}

// calculateSubscriberMarketValue calculates market value from subscriber usage only
func (ufd *UnusedFundsDistributor) calculateSubscriberMarketValue(usage *ProviderUsageAllUsers) float64 {
	value := 0.0
	
	// Storage value (subscribers only)
	storageHourlyRate := ufd.marketPricing.BaseRates.StoragePerGBMonth / (30.44 * 24)
	value += usage.SubscriberStorageGBHours * storageHourlyRate
	
	// Bandwidth value (subscribers only)
	value += usage.SubscriberBandwidthGB * ufd.marketPricing.BaseRates.BandwidthPerGB
	
	// CPU value (subscribers only)
	value += usage.SubscriberCPUHours * ufd.marketPricing.BaseRates.ComputePerCPUHour
	
	// GPU value (subscribers only)
	value += usage.SubscriberGPUHours * ufd.marketPricing.BaseRates.GPUComputePerHour
	
	// Memory value (subscribers only)
	value += usage.SubscriberMemoryGBHours * ufd.marketPricing.BaseRates.MemoryPerGBHour
	
	return value
}

// calculateFreeUserMarketValue calculates market value from free user usage
func (ufd *UnusedFundsDistributor) calculateFreeUserMarketValue(usage *ProviderUsageAllUsers) float64 {
	value := 0.0
	
	// Storage value (free users)
	storageHourlyRate := ufd.marketPricing.BaseRates.StoragePerGBMonth / (30.44 * 24)
	value += usage.FreeUserStorageGBHours * storageHourlyRate
	
	// Bandwidth value (free users)
	value += usage.FreeUserBandwidthGB * ufd.marketPricing.BaseRates.BandwidthPerGB
	
	// CPU value (free users)
	value += usage.FreeUserCPUHours * ufd.marketPricing.BaseRates.ComputePerCPUHour
	
	// GPU value (free users)
	value += usage.FreeUserGPUHours * ufd.marketPricing.BaseRates.GPUComputePerHour
	
	// Memory value (free users)
	value += usage.FreeUserMemoryGBHours * ufd.marketPricing.BaseRates.MemoryPerGBHour
	
	return value
}

// distributionWorker runs the periodic unused funds distribution
func (ufd *UnusedFundsDistributor) distributionWorker(ctx context.Context) {
	defer ufd.wg.Done()
	
	ticker := time.NewTicker(ufd.distributionInterval)
	defer ticker.Stop()
	
	for {
		select {
		case <-ctx.Done():
			return
		case <-ufd.stopChan:
			return
		case <-ticker.C:
			ufd.distributeUnusedFunds()
		}
	}
}

// distributeUnusedFunds distributes ALL accumulated unused funds to providers based on (subs+free) market value
func (ufd *UnusedFundsDistributor) distributeUnusedFunds() {
	ufd.mu.Lock()
	defer ufd.mu.Unlock()
	
	if ufd.unusedFundsPool <= 0 {
		ufd.logger.Debug().
			Float64("unused_pool", ufd.unusedFundsPool).
			Msg("No unused funds to distribute")
		return
	}
	
	now := time.Now()
	
	// Calculate total market value from ALL providers (subscribers + free users)
	totalMarketValue := 0.0
	activeProviders := []string{}
	
	for providerID, usage := range ufd.providerUsageAllUsers {
		if usage.TotalMarketValue > 0 && time.Since(usage.LastUpdateTime) < 7*24*time.Hour {
			totalMarketValue += usage.TotalMarketValue
			activeProviders = append(activeProviders, providerID)
		}
	}
	
	if totalMarketValue <= 0 || len(activeProviders) == 0 {
		ufd.logger.Info().
			Float64("unused_pool", ufd.unusedFundsPool).
			Msg("No active providers with market value - keeping unused funds for next period")
		return
	}
	
	// Distribute ALL unused funds (100%) to providers based on total market value ratio
	distribution := &UnusedFundsDistribution{
		Timestamp:        now,
		TotalAmount:      ufd.unusedFundsPool,
		ProviderRewards:  make(map[string]float64),
		DistributionPeriod: fmt.Sprintf("%s to %s", 
			now.Add(-ufd.distributionInterval).Format("2006-01-02"), 
			now.Format("2006-01-02")),
		TotalProviders:   len(activeProviders),
		TotalMarketValue: totalMarketValue,
	}
	
	// Distribute based on market value ratios (subscribers + free users)
	for _, providerID := range activeProviders {
		usage := ufd.providerUsageAllUsers[providerID]
		
		// Calculate provider's share of total market value
		marketValueRatio := usage.TotalMarketValue / totalMarketValue
		providerReward := ufd.unusedFundsPool * marketValueRatio
		
		distribution.ProviderRewards[providerID] = providerReward
		
		ufd.logger.Debug().
			Str("provider_id", providerID).
			Float64("total_market_value", usage.TotalMarketValue).
			Float64("subscriber_value", ufd.calculateSubscriberMarketValue(usage)).
			Float64("free_user_value", ufd.calculateFreeUserMarketValue(usage)).
			Float64("market_ratio", marketValueRatio).
			Float64("reward", providerReward).
			Msg("Unused funds provider reward calculated")
	}
	
	// Add to distribution history
	ufd.distributionHistory = append(ufd.distributionHistory, distribution)
	if len(ufd.distributionHistory) > ufd.maxHistorySize {
		ufd.distributionHistory = ufd.distributionHistory[1:]
	}
	
	// Clear unused funds pool completely (all funds distributed)
	ufd.unusedFundsPool = 0
	ufd.lastDistributionTime = now
	
	ufd.logger.Info().
		Float64("total_distributed", distribution.TotalAmount).
		Int("providers", len(activeProviders)).
		Float64("total_market_value", totalMarketValue).
		Msg("ALL unused funds distributed to providers based on total market value")
}

// GetUnusedFundsPool returns the current unused funds pool amount
func (ufd *UnusedFundsDistributor) GetUnusedFundsPool() float64 {
	ufd.mu.RLock()
	defer ufd.mu.RUnlock()
	
	return ufd.unusedFundsPool
}

// GetProviderUsageAllUsers returns usage data for all providers (subscribers + free users)
func (ufd *UnusedFundsDistributor) GetProviderUsageAllUsers() map[string]*ProviderUsageAllUsers {
	ufd.mu.RLock()
	defer ufd.mu.RUnlock()
	
	result := make(map[string]*ProviderUsageAllUsers)
	for providerID, usage := range ufd.providerUsageAllUsers {
		usageCopy := *usage
		result[providerID] = &usageCopy
	}
	
	return result
}

// GetDistributionHistory returns recent unused funds distribution history
func (ufd *UnusedFundsDistributor) GetDistributionHistory(limit int) []*UnusedFundsDistribution {
	ufd.mu.RLock()
	defer ufd.mu.RUnlock()
	
	if limit <= 0 || limit > len(ufd.distributionHistory) {
		limit = len(ufd.distributionHistory)
	}
	
	start := len(ufd.distributionHistory) - limit
	result := make([]*UnusedFundsDistribution, limit)
	
	for i := 0; i < limit; i++ {
		distribution := ufd.distributionHistory[start+i]
		distCopy := *distribution
		distCopy.ProviderRewards = make(map[string]float64)
		for k, v := range distribution.ProviderRewards {
			distCopy.ProviderRewards[k] = v
		}
		result[i] = &distCopy
	}
	
	return result
}

// GetStats returns unused funds distribution statistics
func (ufd *UnusedFundsDistributor) GetStats() *UnusedFundsStats {
	ufd.mu.RLock()
	defer ufd.mu.RUnlock()
	
	activeProviders := 0
	totalMarketValue := 0.0
	totalSubscriberValue := 0.0
	totalFreeUserValue := 0.0
	
	for _, usage := range ufd.providerUsageAllUsers {
		if usage.TotalMarketValue > 0 && time.Since(usage.LastUpdateTime) < 7*24*time.Hour {
			activeProviders++
			totalMarketValue += usage.TotalMarketValue
			totalSubscriberValue += ufd.calculateSubscriberMarketValue(usage)
			totalFreeUserValue += ufd.calculateFreeUserMarketValue(usage)
		}
	}
	
	var totalDistributedAllTime float64
	for _, distribution := range ufd.distributionHistory {
		totalDistributedAllTime += distribution.TotalAmount
	}
	
	return &UnusedFundsStats{
		CurrentUnusedPool:       ufd.unusedFundsPool,
		ActiveProviders:         activeProviders,
		TotalProviders:          len(ufd.providerUsageAllUsers),
		TotalMarketValue:        totalMarketValue,
		SubscriberMarketValue:   totalSubscriberValue,
		FreeUserMarketValue:     totalFreeUserValue,
		LastDistribution:        ufd.lastDistributionTime,
		TotalDistributedAllTime: totalDistributedAllTime,
		DistributionCount:       len(ufd.distributionHistory),
		NextDistribution:        ufd.lastDistributionTime.Add(ufd.distributionInterval),
	}
}

// UnusedFundsStats represents statistics for unused funds distribution
type UnusedFundsStats struct {
	CurrentUnusedPool       float64   `json:"current_unused_pool"`
	ActiveProviders         int       `json:"active_providers"`
	TotalProviders          int       `json:"total_providers"`
	TotalMarketValue        float64   `json:"total_market_value"`
	SubscriberMarketValue   float64   `json:"subscriber_market_value"`
	FreeUserMarketValue     float64   `json:"free_user_market_value"`
	LastDistribution        time.Time `json:"last_distribution"`
	TotalDistributedAllTime float64   `json:"total_distributed_all_time"`
	DistributionCount       int       `json:"distribution_count"`
	NextDistribution        time.Time `json:"next_distribution"`
}