// PRORATED BILLING METHODS (NEW REAL-TIME SYSTEM)

// AddProratedSubscription adds a new prorated subscription (per-second billing)
func (s *Service) AddProratedSubscription(userID string, tier SubscriptionTier, startTime time.Time) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("incentive service not running")
	}

	if !s.useRealTimeBilling {
		return fmt.Errorf("real-time billing not enabled")
	}

	return s.proratedBilling.AddProratedSubscription(userID, tier, startTime)
}

// CancelProratedSubscription cancels a prorated subscription
func (s *Service) CancelProratedSubscription(userID string) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("incentive service not running")
	}

	if !s.useRealTimeBilling {
		return fmt.Errorf("real-time billing not enabled")
	}

	return s.proratedBilling.CancelProratedSubscription(userID)
}

// GetProratedSubscriptions returns all active prorated subscriptions
func (s *Service) GetProratedSubscriptions() map[string]*ProratedSubscription {
	if !s.started || !s.config.Enabled || !s.useRealTimeBilling {
		return make(map[string]*ProratedSubscription)
	}

	return s.proratedBilling.GetActiveSubscriptions()
}

