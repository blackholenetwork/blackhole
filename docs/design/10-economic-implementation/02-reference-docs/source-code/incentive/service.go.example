// BACKGROUND WORKERS

// rewardCalculationWorker handles automatic reward calculations for completed cycles
func (s *Service) rewardCalculationWorker(ctx context.Context) {
	defer s.wg.Done()

	ticker := time.NewTicker(time.Hour) // Check every hour
	defer ticker.Stop()

	s.logger.Debug().Msg("Reward calculation worker started")

	for {
		select {
		case <-ctx.Done():
			return
		case <-s.stopChan:
			return
		case <-ticker.C:
			s.processCompletedCycles()
		}
	}
}

