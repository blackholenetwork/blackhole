// SetRealTimeBilling enables or disables real-time billing (for testing/migration)
func (s *Service) SetRealTimeBilling(enabled bool) {
	s.mu.Lock()
	defer s.mu.Unlock()

	s.useRealTimeBilling = enabled

	s.logger.Info().
		Bool("real_time_billing", enabled).
		Msg("Real-time billing mode updated")
}
