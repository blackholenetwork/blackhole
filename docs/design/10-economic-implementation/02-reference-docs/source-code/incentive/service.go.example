// GetServiceHealth returns detailed health information as a map
func (s *Service) GetServiceHealth() map[string]interface{} {
	s.mu.RLock()
	defer s.mu.RUnlock()

	health := map[string]interface{}{
		"service":     "incentive",
		"started":     s.started,
		"enabled":     s.config.Enabled,
		"version":     "1.0.0",
		"timestamp":   time.Now(),
	}

	if s.started && s.config.Enabled {
		currentCycle := s.pool.GetCurrentCycle()
		if currentCycle != nil {
			health["current_cycle"] = currentCycle.ID
			health["cycle_status"] = currentCycle.Status
			health["cycle_end"] = currentCycle.EndDate
		}

		health["pool_amount"] = s.pool.GetPoolAmount()
		health["active_subscriptions"] = s.pool.GetActiveSubscriptions()
	}

	return health
}

// ECONOMIC TRACKER INTERFACE IMPLEMENTATION
// These methods implement the EconomicTracker interface from pkg/core

// TrackResourceUsage records resource usage for economic calculations
func (s *Service) TrackResourceUsage(ctx context.Context, event ResourceUsageEvent) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("incentive service not running")
	}

	// Store billing event with full audit trail if persistence is enabled
	if s.persistence != nil && event.IsChargeable {
		billingEvent := s.convertToBillingEvent(event)
		if err := s.persistence.StoreBillingEvent(ctx, billingEvent); err != nil {
			s.logger.Error().
				Err(err).
				Str("user_id", event.UserID).
				Str("provider_id", event.ProviderID).
				Str("resource_type", string(event.ResourceType)).
				Msg("Failed to store billing event")
			// Don't fail the operation, but log the error
		}
	}

	// Convert core.ResourceUsageEvent to our internal tracking
	switch event.ResourceType {
	case "storage":
		// Convert amount based on unit
		dataSize := int64(event.Amount) // Assume bytes
		if event.Unit == "gb" {
			dataSize = int64(event.Amount * 1024 * 1024 * 1024)
		}
		return s.tracker.TrackStorageOperation(
			event.ProviderID,
			event.Operation,
			dataSize,
			time.Hour, // Default duration
			event.UserID,
			event.IsChargeable,
		)
	case "bandwidth":
		// Convert amount based on unit
		bytesTransferred := int64(event.Amount) // Assume bytes
		if event.Unit == "gb" {
			bytesTransferred = int64(event.Amount * 1024 * 1024 * 1024)
		}
		return s.tracker.TrackBandwidthOperation(
			event.ProviderID,
			event.Operation,
			bytesTransferred,
			"downstream", // Default direction
			event.UserID,
			event.IsChargeable,
		)
	case "compute":
		// Assume amount is in CPU-hours
		cpuHours := event.Amount
		return s.tracker.TrackComputeOperation(
			event.ProviderID,
			event.Operation,
			"", // No specific job ID
			event.UserID,
			cpuHours,
			0, // No GPU hours
			cpuHours * 4.0, // Assume 4GB memory per CPU-hour
			event.IsChargeable,
		)
	case "memory":
		// Memory usage typically gets tracked with compute
		memoryGBHours := event.Amount
		return s.tracker.TrackComputeOperation(
			event.ProviderID,
			"memory_"+event.Operation,
			"", // No specific job ID
			event.UserID,
			0, // No CPU hours for pure memory tracking
			0, // No GPU hours
			memoryGBHours,
			event.IsChargeable,
		)
	case "app_platform":
		// Handle app platform usage for real-time app developer rewards
		if s.useRealTimeBilling && s.appDevDistributor != nil {
			// Extract app usage parameters from metadata
			activeUserTime := event.Amount // Amount is in user_seconds
			developerID := event.ProviderID // Developer is the provider
			appID := event.OperationType // App ID stored in OperationType
			appName := ""
			userRetentionRate := 0.8 // Default retention rate
			appRating := 4.0 // Default rating

			// Extract values from metadata if available
			if event.Metadata != nil {
				if name, ok := event.Metadata["app_name"]; ok {
					appName = name
				}
				if retention, ok := event.Metadata["user_retention_rate"]; ok {
					if rate, err := strconv.ParseFloat(retention, 64); err == nil {
						userRetentionRate = rate
					}
				}
				if rating, ok := event.Metadata["app_rating"]; ok {
					if rate, err := strconv.ParseFloat(rating, 64); err == nil {
						appRating = rate
					}
				}
			}

			// Record real-time app usage
			s.RecordAppUsage(
				developerID,
				appID,
				appName,
				activeUserTime,
				userRetentionRate,
				appRating,
			)

			return nil
		}

		// Fall back to legacy tracking
		s.logger.Debug().
			Str("developer_id", event.ProviderID).
			Str("app_id", event.OperationType).
			Float64("active_user_time", event.Amount).
			Msg("App platform usage tracked (legacy mode)")
		return nil
	default:
		s.logger.Warn().
			Str("resource_type", string(event.ResourceType)).
			Str("provider_id", event.ProviderID).
			Msg("Unknown resource type for economic tracking")
		return nil
	}
}

// TrackContentActivity records content-related activity for economic calculations
func (s *Service) TrackContentActivity(ctx context.Context, event ContentActivityEvent) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("incentive service not running")
	}

	// Use real-time content distribution if available
	if s.useRealTimeBilling && s.contentDistributor != nil {
		// Convert view duration to engagement time per content type
		engagementSeconds := event.ViewDuration.Seconds()
		var videoTime, audioTime, documentTime, photoTime float64

		// Distribute engagement time based on content type
		switch event.ContentType {
		case "video":
			videoTime = engagementSeconds
		case "audio":
			audioTime = engagementSeconds
		case "document", "text":
			documentTime = engagementSeconds
		case "photo", "image":
			photoTime = engagementSeconds
		default:
			// Default to video engagement for unknown types
			videoTime = engagementSeconds
		}

		// Record real-time content engagement
		s.RecordContentEngagement(
			event.CreatorID,
			videoTime,
			audioTime,
			documentTime,
			photoTime,
			event.QualityScore,
		)

		return nil
	}

	// Fall back to legacy tracking for compatibility
	viewCount := int64(1) // Assume each activity event represents 1 view
	engagementScore := 1.0 // Default engagement score
	if event.EngagementType == "like" {
		engagementScore = 2.0
	} else if event.EngagementType == "share" {
		engagementScore = 5.0
	}
	return s.tracker.TrackContentContribution(
		event.CreatorID,
		event.ContentID,
		event.ContentType,
		viewCount,
		event.DataConsumed,
		engagementScore,
		event.QualityScore,
	)
}

// ResourceUsageEvent represents resource usage from the core layer
type ResourceUsageEvent struct {
	ResourceType  string            `json:"resource_type"`
	Operation     string            `json:"operation"`
	Amount        float64           `json:"amount"`
	Unit          string            `json:"unit"`
	ProviderID    string            `json:"provider_id"`
	UserID        string            `json:"user_id"`
	IsChargeable  bool              `json:"is_chargeable"`
	OperationType string            `json:"operation_type"`
	ServiceName   string            `json:"service_name"`
	Metadata      map[string]string `json:"metadata"`
}

// ContentActivityEvent represents content activity from the core layer
type ContentActivityEvent struct {
	ContentID      string            `json:"content_id"`
	ContentType    string            `json:"content_type"`
	CreatorID      string            `json:"creator_id"`
	ActivityType   string            `json:"activity_type"`
	ViewerID       string            `json:"viewer_id"`
	DataConsumed   int64             `json:"data_consumed"`
	ViewDuration   time.Duration     `json:"view_duration"`
	EngagementType string            `json:"engagement_type"`
	QualityScore   float64           `json:"quality_score"`
	Metadata       map[string]string `json:"metadata"`
}

// PERSISTENCE LAYER INTEGRATION METHODS

// convertToBillingEvent converts a ResourceUsageEvent to a BillingEvent for persistence
func (s *Service) convertToBillingEvent(event ResourceUsageEvent) *BillingEvent {
	now := time.Now()

	// Calculate cost based on current pricing
	unitCost := s.calculateUnitCost(event.ResourceType, event.Operation)
	totalCost := event.Amount * unitCost

	// Generate transaction ID
	transactionID := fmt.Sprintf("tx_%s_%s_%d", event.UserID[:8], event.ProviderID[:8], now.UnixNano())

	// Get current billing cycle
	currentCycle := s.pool.GetCurrentCycle()
	billingCycleID := ""
	if currentCycle != nil {
		billingCycleID = currentCycle.ID
	}

	// Create billing event
	billingEvent := &BillingEvent{
		TransactionID:    transactionID,
		BillingCycleID:   billingCycleID,
		ResourceType:     event.ResourceType,
		Operation:        event.Operation,
		Amount:           event.Amount,
		Unit:             event.Unit,
		Duration:         0, // TODO: Extract from metadata or calculate
		UserID:           event.UserID,
		ProviderID:       event.ProviderID,
		NodeID:           s.nodeID,
		ServiceName:      event.ServiceName,
		IsChargeable:     event.IsChargeable,
		OperationType:    event.OperationType,
		UnitCost:         unitCost,
		TotalCost:        totalCost,
		Currency:         "USD",
		VerificationProof: "", // TODO: Generate cryptographic proof
		ResourceHash:     "", // TODO: Generate resource hash
		OperationHash:    "", // TODO: Generate operation hash
		RequestedAt:      now,
		StartedAt:        now,
		CompletedAt:      now,
		RegulatoryFlags:  []string{"SOX_COMPLIANT", "GDPR_COMPLIANT"},
		Metadata:         event.Metadata,
	}

	return billingEvent
}

// calculateUnitCost calculates the cost per unit for a given resource type and operation
func (s *Service) calculateUnitCost(resourceType, operation string) float64 {
	// TODO: Implement dynamic pricing based on market conditions
	// For now, use static rates
	switch resourceType {
	case "storage":
		switch operation {
		case "put", "replicate":
			return 0.00005 // $0.05 per GB stored
		case "get", "stream":
			return 0.00001 // $0.01 per GB retrieved
		default:
			return 0.0
		}
	case "bandwidth":
		switch operation {
		case "upload", "download", "stream":
			return 0.00010 // $0.10 per GB transferred
		default:
			return 0.0
		}
	case "compute":
		switch operation {
		case "execute", "ai_inference":
			return 0.50000 // $0.50 per CPU-hour
		case "ml_training":
			return 2.00000 // $2.00 per CPU-hour for ML training
		default:
			return 0.0
		}
	case "memory":
		return 0.10000 // $0.10 per GB-hour
	default:
		return 0.0
	}
}

// PERSISTENCE QUERY METHODS

// QueryUserBillingEvents retrieves billing events for a specific user
func (s *Service) QueryUserBillingEvents(ctx context.Context, userID string, startDate, endDate time.Time) ([]*BillingEvent, error) {
	if s.persistence == nil {
		return nil, fmt.Errorf("persistence layer not available")
	}

	filter := BillingEventFilter{
		UserID:       userID,
		StartDate:    startDate,
		EndDate:      endDate,
		IsChargeable: boolPtr(true),
		SortBy:       "date",
		SortOrder:    "desc",
		Limit:        1000,
	}

	return s.persistence.QueryBillingEvents(ctx, filter)
}

// QueryProviderBillingEvents retrieves billing events for a specific provider
func (s *Service) QueryProviderBillingEvents(ctx context.Context, providerID string, startDate, endDate time.Time) ([]*BillingEvent, error) {
	if s.persistence == nil {
		return nil, fmt.Errorf("persistence layer not available")
	}

	filter := BillingEventFilter{
		ProviderID:   providerID,
		StartDate:    startDate,
		EndDate:      endDate,
		IsChargeable: boolPtr(true),
		SortBy:       "date",
		SortOrder:    "desc",
		Limit:        1000,
	}

	return s.persistence.QueryBillingEvents(ctx, filter)
}

// GenerateUserBill generates a comprehensive billing report for a user
func (s *Service) GenerateUserBill(ctx context.Context, userID, billingCycleID string) (*BillingReport, error) {
	if s.persistence == nil {
		return nil, fmt.Errorf("persistence layer not available")
	}

	return s.persistence.GenerateUserBillingReport(ctx, userID, billingCycleID)
}

// GenerateProviderStatement generates a statement report for a provider
func (s *Service) GenerateProviderStatement(ctx context.Context, providerID, billingCycleID string) (*BillingReport, error) {
	if s.persistence == nil {
		return nil, fmt.Errorf("persistence layer not available")
	}

	return s.persistence.GenerateProviderStatementReport(ctx, providerID, billingCycleID)
}

// QueryAuditTrail retrieves audit trail entries for regulatory compliance
func (s *Service) QueryAuditTrail(ctx context.Context, entityType, entityID string, startDate, endDate time.Time) ([]*AuditTrailEntry, error) {
	if s.persistence == nil {
		return nil, fmt.Errorf("persistence layer not available")
	}

	filter := AuditTrailFilter{
		Entity:          entityType,
		EntityID:        entityID,
		StartDate:       startDate,
		EndDate:         endDate,
		ComplianceLevel: "HIGH",
		SortBy:          "date",
		SortOrder:       "desc",
		Limit:           1000,
	}

	return s.persistence.QueryAuditTrail(ctx, filter)
}

