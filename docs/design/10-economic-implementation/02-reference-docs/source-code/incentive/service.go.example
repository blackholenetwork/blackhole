package incentive

import (
	"context"
	"fmt"
	"strconv"
	"sync"
	"time"

	"github.com/blackholenetwork/blackhole/pkg/core"
	"github.com/blackholenetwork/blackhole/pkg/interfaces"
	"github.com/rs/zerolog"
)

// Service represents the main incentive service
type Service struct {
	*core.BaseService
	mu            sync.RWMutex
	logger        zerolog.Logger
	config        *Config

	// Core components
	pool          *SubscriptionPool // Legacy monthly billing
	tracker       *UsageTracker
	calculator    *RewardCalculator
	contentEconomy *ContentEconomyManager

	// New prorated billing system
	proratedBilling       *ProratedBillingEngine
	infraDistributor      *RealTimeInfrastructureDistributor
	contentDistributor    *RealTimeContentDistributor
	appDevDistributor     *RealTimeAppDeveloperDistributor
	unusedFundsDistributor *UnusedFundsDistributor
	useRealTimeBilling    bool // Flag to switch between legacy and real-time

	// Persistence layer for billing and audit trails
	persistence   *EconomicPersistenceLayer
	nodeID        string

	// Service state
	started       bool
	stopChan      chan struct{}
	wg            sync.WaitGroup
}

// NewService creates a new incentive service
func NewService(config *Config, logger zerolog.Logger) *Service {
	service := &Service{
		BaseService: core.NewBaseService("incentive"),
		logger:     logger.With().Str("component", "incentive_service").Logger(),
		config:     config,
		stopChan:   make(chan struct{}),
	}

	// Initialize components
	service.pool = NewSubscriptionPool(config, logger)
	service.tracker = NewUsageTracker(config, service.pool, logger)
	service.calculator = NewRewardCalculator(config, service.pool, service.tracker, logger)
	service.contentEconomy = NewContentEconomyManager(config, service.pool, logger)

	return service
}

// NewServiceWithPersistence creates a new incentive service with persistence layer
func NewServiceWithPersistence(config *Config, vfs interfaces.VFS, nodeID string, logger zerolog.Logger) *Service {
	service := &Service{
		BaseService: core.NewBaseService("incentive"),
		logger:     logger.With().Str("component", "incentive_service").Logger(),
		config:     config,
		nodeID:     nodeID,
		stopChan:   make(chan struct{}),
		useRealTimeBilling: true, // Enable real-time prorated billing by default
	}

	// Initialize legacy components (for compatibility)
	service.pool = NewSubscriptionPool(config, logger)
	service.tracker = NewUsageTracker(config, service.pool, logger)
	service.calculator = NewRewardCalculator(config, service.pool, service.tracker, logger)
	service.contentEconomy = NewContentEconomyManager(config, service.pool, logger)

	// Initialize new prorated billing system
	service.proratedBilling = NewProratedBillingEngine(config, logger)
	service.infraDistributor = NewRealTimeInfrastructureDistributor(config, logger)
	service.contentDistributor = NewRealTimeContentDistributor(config, logger)
	service.appDevDistributor = NewRealTimeAppDeveloperDistributor(config, logger)
	service.unusedFundsDistributor = NewUnusedFundsDistributor(config, logger)

	// Initialize persistence layer if VFS is provided
	if vfs != nil {
		service.persistence = NewEconomicPersistenceLayer(vfs, nodeID, logger)
		logger.Info().Str("node_id", nodeID).Msg("Economic persistence layer initialized")
	}

	return service
}

// Start starts the incentive service
func (s *Service) Start(ctx context.Context) error {
	s.mu.Lock()
	defer s.mu.Unlock()

	if s.started {
		return fmt.Errorf("incentive service already started")
	}

	if !s.config.Enabled {
		s.logger.Info().Msg("Incentive service disabled in configuration")
		return nil
	}

	s.logger.Info().Msg("Starting incentive service")

	// Validate configuration
	if err := s.config.Validate(); err != nil {
		return fmt.Errorf("invalid configuration: %w", err)
	}

	// Start legacy components (for compatibility)
	if !s.useRealTimeBilling {
		if err := s.pool.Start(ctx); err != nil {
			return fmt.Errorf("failed to start subscription pool: %w", err)
		}
	}

	if err := s.tracker.Start(ctx); err != nil {
		if !s.useRealTimeBilling {
			s.pool.Stop(ctx) // Cleanup on failure
		}
		return fmt.Errorf("failed to start usage tracker: %w", err)
	}

	if err := s.contentEconomy.Start(ctx); err != nil {
		s.tracker.Stop(ctx) // Cleanup on failure
		if !s.useRealTimeBilling {
			s.pool.Stop(ctx)
		}
		return fmt.Errorf("failed to start content economy: %w", err)
	}

	// Start new prorated billing system
	if s.useRealTimeBilling {
		if err := s.proratedBilling.Start(ctx); err != nil {
			s.contentEconomy.Stop(ctx)
			s.tracker.Stop(ctx)
			return fmt.Errorf("failed to start prorated billing: %w", err)
		}

		if err := s.infraDistributor.Start(ctx); err != nil {
			s.proratedBilling.Stop(ctx)
			s.contentEconomy.Stop(ctx)
			s.tracker.Stop(ctx)
			return fmt.Errorf("failed to start infrastructure distributor: %w", err)
		}

		if err := s.contentDistributor.Start(ctx); err != nil {
			s.infraDistributor.Stop(ctx)
			s.proratedBilling.Stop(ctx)
			s.contentEconomy.Stop(ctx)
			s.tracker.Stop(ctx)
			return fmt.Errorf("failed to start content distributor: %w", err)
		}

		if err := s.appDevDistributor.Start(ctx); err != nil {
			s.contentDistributor.Stop(ctx)
			s.infraDistributor.Stop(ctx)
			s.proratedBilling.Stop(ctx)
			s.contentEconomy.Stop(ctx)
			s.tracker.Stop(ctx)
			return fmt.Errorf("failed to start app developer distributor: %w", err)
		}

		if err := s.unusedFundsDistributor.Start(ctx); err != nil {
			s.appDevDistributor.Stop(ctx)
			s.contentDistributor.Stop(ctx)
			s.infraDistributor.Stop(ctx)
			s.proratedBilling.Stop(ctx)
			s.contentEconomy.Stop(ctx)
			s.tracker.Stop(ctx)
			return fmt.Errorf("failed to start unused funds distributor: %w", err)
		}
	}

	s.started = true

	// Start background workers
	if !s.useRealTimeBilling {
		s.wg.Add(1)
		go s.rewardCalculationWorker(ctx)
	} else {
		// Start integration worker for real-time billing
		s.wg.Add(1)
		go s.connectProratedToDistributors(ctx)
	}

	s.logger.Info().
		Float64("content_pct", s.config.MarketPricing.ContentCreatorPercentage*100).
		Float64("network_ops_pct", s.config.MarketPricing.NetworkOpsPercentage*100).
		Float64("app_dev_pct", s.config.MarketPricing.AppDeveloperPercentage*100).
		Float64("infrastructure_pct", s.config.MarketPricing.InfrastructurePercentage*100).
		Bool("real_time_billing", s.useRealTimeBilling).
		Str("pricing_model", "market_based").
		Msg("Incentive service started with updated allocation")

	// Mark service as healthy
	s.SetHealthy()

	return nil
}

// Stop stops the incentive service
func (s *Service) Stop(ctx context.Context) error {
	s.mu.Lock()
	defer s.mu.Unlock()

	if !s.started {
		return nil
	}

	s.logger.Info().Msg("Stopping incentive service")

	close(s.stopChan)
	s.wg.Wait()

	// Stop components
	if err := s.contentEconomy.Stop(ctx); err != nil {
		s.logger.Warn().Err(err).Msg("Error stopping content economy")
	}

	if err := s.tracker.Stop(ctx); err != nil {
		s.logger.Warn().Err(err).Msg("Error stopping usage tracker")
	}

	// Stop real-time billing components
	if s.useRealTimeBilling {
		if err := s.unusedFundsDistributor.Stop(ctx); err != nil {
			s.logger.Warn().Err(err).Msg("Error stopping unused funds distributor")
		}

		if err := s.appDevDistributor.Stop(ctx); err != nil {
			s.logger.Warn().Err(err).Msg("Error stopping app developer distributor")
		}

		if err := s.contentDistributor.Stop(ctx); err != nil {
			s.logger.Warn().Err(err).Msg("Error stopping content distributor")
		}

		if err := s.infraDistributor.Stop(ctx); err != nil {
			s.logger.Warn().Err(err).Msg("Error stopping infrastructure distributor")
		}

		if err := s.proratedBilling.Stop(ctx); err != nil {
			s.logger.Warn().Err(err).Msg("Error stopping prorated billing")
		}
	} else {
		// Stop legacy pool
		if err := s.pool.Stop(ctx); err != nil {
			s.logger.Warn().Err(err).Msg("Error stopping subscription pool")
		}
	}

	s.started = false

	s.logger.Info().Msg("Incentive service stopped")
	return nil
}

// SUBSCRIPTION MANAGEMENT

// AddSubscription adds or updates a user subscription
func (s *Service) AddSubscription(userID string, tier SubscriptionTier) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("incentive service not running")
	}

	var amount float64
	switch tier {
	case TierNormal:
		amount = s.config.TierPricing.Normal
	case TierAdvance:
		amount = s.config.TierPricing.Advance
	case TierUltimate:
		amount = s.config.TierPricing.Ultimate
	case TierFree:
		amount = 0
	default:
		return fmt.Errorf("invalid subscription tier: %s", tier)
	}

	subscription := &Subscription{
		UserID:       userID,
		Tier:         tier,
		MonthlyAmount: amount,
		StartDate:    time.Now(),
		Status:       SubscriptionActive,
		CreatedAt:    time.Now(),
		UpdatedAt:    time.Now(),
	}

	return s.pool.AddSubscription(subscription)
}

// CancelSubscription cancels a user subscription
func (s *Service) CancelSubscription(userID string) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("incentive service not running")
	}

	return s.pool.CancelSubscription(userID)
}

// GetSubscription retrieves a user's subscription
func (s *Service) GetSubscription(userID string) (*Subscription, error) {
	if !s.started || !s.config.Enabled {
		return nil, fmt.Errorf("incentive service not running")
	}

	return s.pool.GetSubscription(userID)
}

