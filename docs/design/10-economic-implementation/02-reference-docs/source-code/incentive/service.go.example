// INTEGRATION METHOD - Connect prorated billing with infrastructure distribution

// connectProratedToDistributors runs periodically to feed all distributors from prorated billing
func (s *Service) connectProratedToDistributors(ctx context.Context) {
	if !s.useRealTimeBilling {
		return
	}

	ticker := time.NewTicker(time.Second)
	defer ticker.Stop()

	for {
		select {
		case <-ctx.Done():
			return
		case <-s.stopChan:
			return
		case <-ticker.C:
			pools := s.proratedBilling.GetPoolAmounts()

			// Feed infrastructure pool to infrastructure distributor
			if infraAmount := pools["infrastructure"]; infraAmount > 0 {
				s.infraDistributor.AddInfrastructureFunds(infraAmount)
			}

			// Feed content pool to content distributor
			if contentAmount := pools["content"]; contentAmount > 0 {
				s.contentDistributor.AddContentFunds(contentAmount)
			}

			// Feed app developer pool to app developer distributor
			if appDevAmount := pools["app_developer"]; appDevAmount > 0 {
				s.appDevDistributor.AddAppDeveloperFunds(appDevAmount)
			}

			// Feed unused funds to unused funds distributor
			if unusedAmount := pools["unused"]; unusedAmount > 0 {
				s.unusedFundsDistributor.AddUnusedFunds(unusedAmount)
			}
		}
	}
}

