package incentive

import (
	"context"
	"crypto/sha256"
	"encoding/hex"
	"encoding/json"
	"fmt"
	"path/filepath"
	"strings"
	"sync"
	"time"

	"github.com/rs/zerolog"
)

// BillingCycleManager handles billing cycle aggregation and reporting
type BillingCycleManager struct {
	persistence *EconomicPersistenceLayer
	logger      zerolog.Logger
	mu          sync.RWMutex

	// Current active cycle
	activeCycle     *BillingCycle
	cycleStartTimer *time.Timer
	cycleEndTimer   *time.Timer

	// Configuration
	cycleDuration   time.Duration // Default: 30 days
	autoGenerate    bool          // Auto-generate monthly cycles
	nodeID          string

	// Aggregation state
	aggregationInProgress bool
	lastAggregation       time.Time
}

// NewBillingCycleManager creates a new billing cycle manager
func NewBillingCycleManager(persistence *EconomicPersistenceLayer, nodeID string, logger zerolog.Logger) *BillingCycleManager {
	return &BillingCycleManager{
		persistence:   persistence,
		logger:        logger.With().Str("component", "billing_cycle_manager").Logger(),
		nodeID:        nodeID,
		cycleDuration: 30 * 24 * time.Hour, // 30 days
		autoGenerate:  true,
	}
}

// StartBillingCycle starts a new billing cycle
func (bcm *BillingCycleManager) StartBillingCycle(ctx context.Context, startDate time.Time) (*BillingCycle, error) {
	bcm.mu.Lock()
	defer bcm.mu.Unlock()

	// End current cycle if active
	if bcm.activeCycle != nil && bcm.activeCycle.Status == CycleStatusActive {
		if _, err := bcm.endCurrentCycle(ctx); err != nil {
			bcm.logger.Error().
				Err(err).
				Str("current_cycle_id", bcm.activeCycle.ID).
				Msg("Failed to end current cycle before starting new one")
		}
	}

	// Create new cycle
	endDate := startDate.Add(bcm.cycleDuration)
	cycleID := fmt.Sprintf("cycle_%s_%d", startDate.Format("2006_01"), startDate.Unix())

	cycle := &BillingCycle{
		ID:              cycleID,
		StartDate:       startDate,
		EndDate:         endDate,
		Status:          CycleStatusActive,
		TotalPoolAmount: 0.0,
		DistributedAmount: 0.0,
		FreeTierSubsidy: 0.0,
		CreatedAt:       time.Now(),
	}

	bcm.activeCycle = cycle

	// Store cycle information
	if err := bcm.storeBillingCycle(ctx, cycle); err != nil {
		return nil, fmt.Errorf("failed to store new billing cycle: %w", err)
	}

	// Set up timers for automatic cycle management
	if bcm.autoGenerate {
		bcm.setupCycleTimers()
	}

	bcm.logger.Info().
		Str("cycle_id", cycle.ID).
		Time("start_date", cycle.StartDate).
		Time("end_date", cycle.EndDate).
		Msg("New billing cycle started")

	return cycle, nil
}

// EndBillingCycle ends the current billing cycle and aggregates results
func (bcm *BillingCycleManager) EndBillingCycle(ctx context.Context) (*CycleAggregateRecord, error) {
	bcm.mu.Lock()
	defer bcm.mu.Unlock()

	if bcm.activeCycle == nil {
		return nil, fmt.Errorf("no active billing cycle to end")
	}

	return bcm.endCurrentCycle(ctx)
}

// endCurrentCycle internal method to end the current cycle
func (bcm *BillingCycleManager) endCurrentCycle(ctx context.Context) (*CycleAggregateRecord, error) {
	if bcm.activeCycle == nil {
		return nil, fmt.Errorf("no active cycle")
	}

	bcm.logger.Info().
		Str("cycle_id", bcm.activeCycle.ID).
		Msg("Ending billing cycle and starting aggregation")

	// Update cycle status
	bcm.activeCycle.Status = CycleStatusCalculating
	bcm.activeCycle.CompletedAt = timePtr(time.Now())

	// Store updated cycle
	if err := bcm.storeBillingCycle(ctx, bcm.activeCycle); err != nil {
		bcm.logger.Error().
			Err(err).
			Str("cycle_id", bcm.activeCycle.ID).
			Msg("Failed to update cycle status")
	}

	// Aggregate billing data for the cycle
	aggregate, err := bcm.aggregateCycleData(ctx, bcm.activeCycle)
	if err != nil {
		bcm.activeCycle.Status = CycleStatusFailed
		bcm.storeBillingCycle(ctx, bcm.activeCycle)
		return nil, fmt.Errorf("failed to aggregate cycle data: %w", err)
	}

	// Update cycle status to completed
	bcm.activeCycle.Status = CycleStatusCompleted
	bcm.activeCycle.TotalPoolAmount = aggregate.TotalPoolAmount
	bcm.activeCycle.DistributedAmount = aggregate.DistributedAmount
	bcm.activeCycle.FreeTierSubsidy = aggregate.FreeTierSubsidy

	// Store final cycle state
	if err := bcm.storeBillingCycle(ctx, bcm.activeCycle); err != nil {
		bcm.logger.Error().
			Err(err).
			Str("cycle_id", bcm.activeCycle.ID).
			Msg("Failed to store final cycle state")
	}

	// Store cycle aggregate
	if err := bcm.storeCycleAggregate(ctx, aggregate); err != nil {
		bcm.logger.Error().
			Err(err).
			Str("cycle_id", aggregate.CycleID).
			Msg("Failed to store cycle aggregate")
	}

	bcm.logger.Info().
		Str("cycle_id", bcm.activeCycle.ID).
		Float64("total_pool", aggregate.TotalPoolAmount).
		Float64("distributed", aggregate.DistributedAmount).
		Int64("event_count", aggregate.EventCount).
		Msg("Billing cycle completed successfully")

	// Clear active cycle
	completedCycle := bcm.activeCycle
	bcm.activeCycle = nil

	// Auto-start next cycle if enabled
	if bcm.autoGenerate {
		nextStartDate := completedCycle.EndDate
		if _, err := bcm.StartBillingCycle(ctx, nextStartDate); err != nil {
			bcm.logger.Error().
				Err(err).
				Time("next_start", nextStartDate).
				Msg("Failed to auto-start next billing cycle")
		}
	}

	return aggregate, nil
}

// aggregateCycleData aggregates all billing events for a completed cycle
func (bcm *BillingCycleManager) aggregateCycleData(ctx context.Context, cycle *BillingCycle) (*CycleAggregateRecord, error) {
	bcm.aggregationInProgress = true
	defer func() { bcm.aggregationInProgress = false }()

	// Query all billing events for this cycle
	filter := BillingEventFilter{
		BillingCycleID: cycle.ID,
		StartDate:      cycle.StartDate,
		EndDate:        cycle.EndDate,
		IsChargeable:   boolPtr(true),
		SortBy:         "date",
		SortOrder:      "asc",
	}

	events, err := bcm.persistence.QueryBillingEvents(ctx, filter)
	if err != nil {
		return nil, fmt.Errorf("failed to query billing events: %w", err)
	}

	bcm.logger.Info().
		Str("cycle_id", cycle.ID).
		Int("event_count", len(events)).
		Msg("Aggregating billing events for cycle")

	// Initialize aggregation data
	aggregate := &CycleAggregateRecord{
		CycleID:           cycle.ID,
		StartDate:         cycle.StartDate,
		EndDate:           cycle.EndDate,
		Status:            "completed",
		ProviderTotals:    make(map[string]*ProviderCycleTotals),
		TotalPoolAmount:   0.0,
		DistributedAmount: 0.0,
		FreeTierSubsidy:   0.0,
		EventCount:        int64(len(events)),
		CreatedAt:         cycle.CreatedAt,
		CompletedAt:       cycle.CompletedAt,
		LastUpdated:       time.Now(),
	}

	// Aggregate by provider
	for _, event := range events {
		// Update total pool amount
		aggregate.TotalPoolAmount += event.TotalCost

		// Get or create provider totals
		providerTotals, exists := aggregate.ProviderTotals[event.ProviderID]
		if !exists {
			providerTotals = &ProviderCycleTotals{
				ProviderID:      event.ProviderID,
				StorageGBHours:  0.0,
				BandwidthGB:     0.0,
				ComputeCPUHours: 0.0,
				ComputeGPUHours: 0.0,
				MemoryGBHours:   0.0,
				ContentPoints:   0.0,
				NetworkOpsUnits: 0.0,
				TotalReward:     0.0,
				RewardBreakdown: make(map[string]float64),
				EventCounts:     make(map[string]int64),
			}
			aggregate.ProviderTotals[event.ProviderID] = providerTotals
		}

		// Aggregate by resource type
		switch event.ResourceType {
		case "storage":
			if event.Unit == "gb" {
				// Assume storage is billed per hour, calculate GB-hours
				hours := float64(event.Duration) / float64(time.Hour)
				if hours == 0 {
					hours = 1.0 // Default to 1 hour if duration not specified
				}
				providerTotals.StorageGBHours += event.Amount * hours
			} else {
				// Convert bytes to GB
				gbAmount := event.Amount / (1024 * 1024 * 1024)
				providerTotals.StorageGBHours += gbAmount
			}

		case "bandwidth":
			if event.Unit == "gb" {
				providerTotals.BandwidthGB += event.Amount
			} else {
				// Convert bytes to GB
				gbAmount := event.Amount / (1024 * 1024 * 1024)
				providerTotals.BandwidthGB += gbAmount
			}

		case "compute":
			if event.Unit == "cpu_hours" {
				providerTotals.ComputeCPUHours += event.Amount
			} else if event.Unit == "gpu_hours" {
				providerTotals.ComputeGPUHours += event.Amount
			}

		case "memory":
			if event.Unit == "gb" || event.Unit == "gb_hours" {
				providerTotals.MemoryGBHours += event.Amount
			}
		}

		// Track reward (simplified - actual reward calculation would be more complex)
		providerTotals.TotalReward += event.TotalCost
		providerTotals.RewardBreakdown[event.ResourceType] += event.TotalCost

		// Count events by resource type
		providerTotals.EventCounts[event.ResourceType]++
	}

	// Calculate total distributed amount
	for _, providerTotals := range aggregate.ProviderTotals {
		aggregate.DistributedAmount += providerTotals.TotalReward

		// Generate verification hash for provider totals
		providerTotals.VerificationHash = bcm.generateProviderTotalsHash(providerTotals)
	}

	// Calculate free tier subsidy (simplified)
	aggregate.FreeTierSubsidy = aggregate.TotalPoolAmount * 0.1 // 10% for free tier

	// Generate aggregate hash for integrity
	aggregate.AggregateHash = bcm.generateAggregateHash(aggregate)

	bcm.lastAggregation = time.Now()

	return aggregate, nil
}

// GetCurrentCycle returns the currently active billing cycle
func (bcm *BillingCycleManager) GetCurrentCycle() *BillingCycle {
	bcm.mu.RLock()
	defer bcm.mu.RUnlock()

	return bcm.activeCycle
}

// GetCycleAggregates retrieves aggregated data for a specific cycle
func (bcm *BillingCycleManager) GetCycleAggregates(ctx context.Context, cycleID string) (*CycleAggregateRecord, error) {
	// Try to read from VFS storage
	aggregatePath := filepath.Join(bcm.persistence.cycleAggregatesPath, fmt.Sprintf("%s.json", cycleID))

	data, err := bcm.persistence.vfs.ReadFile(ctx, aggregatePath)
	if err != nil {
		return nil, fmt.Errorf("failed to read cycle aggregate: %w", err)
	}

	var aggregate CycleAggregateRecord
	if err := json.Unmarshal(data, &aggregate); err != nil {
		return nil, fmt.Errorf("failed to parse cycle aggregate: %w", err)
	}

	return &aggregate, nil
}

// ListBillingCycles lists all billing cycles
func (bcm *BillingCycleManager) ListBillingCycles(ctx context.Context) ([]*BillingCycle, error) {
	cycles := make([]*BillingCycle, 0)

	// List files in the cycles directory
	cyclesPath := filepath.Join(bcm.persistence.cycleAggregatesPath, "../cycles/")
	files, err := bcm.persistence.vfs.ListDir(ctx, cyclesPath)
	if err != nil {
		return cycles, nil // Return empty list if directory doesn't exist
	}

	for _, file := range files {
		if !strings.HasSuffix(file.Path, ".json") {
			continue
		}

		data, err := bcm.persistence.vfs.ReadFile(ctx, file.Path)
		if err != nil {
			bcm.logger.Warn().
				Err(err).
				Str("file_path", file.Path).
				Msg("Failed to read billing cycle file")
			continue
		}

		var cycle BillingCycle
		if err := json.Unmarshal(data, &cycle); err != nil {
			bcm.logger.Warn().
				Err(err).
				Str("file_path", file.Path).
				Msg("Failed to parse billing cycle")
			continue
		}

		cycles = append(cycles, &cycle)
	}

	return cycles, nil
}

// Helper methods

func (bcm *BillingCycleManager) setupCycleTimers() {
	if bcm.activeCycle == nil {
		return
	}

	// Set timer to automatically end the cycle
	timeUntilEnd := time.Until(bcm.activeCycle.EndDate)
	if timeUntilEnd > 0 {
		bcm.cycleEndTimer = time.AfterFunc(timeUntilEnd, func() {
			ctx := context.Background()
			if _, err := bcm.EndBillingCycle(ctx); err != nil {
				bcm.logger.Error().
					Err(err).
					Str("cycle_id", bcm.activeCycle.ID).
					Msg("Failed to auto-end billing cycle")
			}
		})
	}
}

func (bcm *BillingCycleManager) storeBillingCycle(ctx context.Context, cycle *BillingCycle) error {
	data, err := json.MarshalIndent(cycle, "", "  ")
	if err != nil {
		return fmt.Errorf("failed to marshal billing cycle: %w", err)
	}

	metadata := map[string]string{
		"cycle_id":     cycle.ID,
		"status":       string(cycle.Status),
		"start_date":   cycle.StartDate.Format(time.RFC3339),
		"end_date":     cycle.EndDate.Format(time.RFC3339),
		"created_at":   cycle.CreatedAt.Format(time.RFC3339),
		"node_id":      bcm.nodeID,
		"compliance":   "regulatory",
	}

	if cycle.CompletedAt != nil {
		metadata["completed_at"] = cycle.CompletedAt.Format(time.RFC3339)
	}

	// Store in cycles directory
	cyclePath := filepath.Join(bcm.persistence.cycleAggregatesPath, "../cycles/", fmt.Sprintf("%s.json", cycle.ID))

	return bcm.persistence.vfs.WriteFile(ctx, cyclePath, data, metadata)
}

func (bcm *BillingCycleManager) storeCycleAggregate(ctx context.Context, aggregate *CycleAggregateRecord) error {
	data, err := json.MarshalIndent(aggregate, "", "  ")
	if err != nil {
		return fmt.Errorf("failed to marshal cycle aggregate: %w", err)
	}

	metadata := map[string]string{
		"cycle_id":           aggregate.CycleID,
		"status":             aggregate.Status,
		"event_count":        fmt.Sprintf("%d", aggregate.EventCount),
		"total_pool_amount":  fmt.Sprintf("%.6f", aggregate.TotalPoolAmount),
		"distributed_amount": fmt.Sprintf("%.6f", aggregate.DistributedAmount),
		"provider_count":     fmt.Sprintf("%d", len(aggregate.ProviderTotals)),
		"aggregate_hash":     aggregate.AggregateHash,
		"created_at":         aggregate.CreatedAt.Format(time.RFC3339),
		"last_updated":       aggregate.LastUpdated.Format(time.RFC3339),
		"node_id":            bcm.nodeID,
		"compliance":         "regulatory",
	}

	if aggregate.CompletedAt != nil {
		metadata["completed_at"] = aggregate.CompletedAt.Format(time.RFC3339)
	}

	aggregatePath := filepath.Join(bcm.persistence.cycleAggregatesPath, fmt.Sprintf("%s.json", aggregate.CycleID))

	return bcm.persistence.vfs.WriteFile(ctx, aggregatePath, data, metadata)
}

func (bcm *BillingCycleManager) generateProviderTotalsHash(totals *ProviderCycleTotals) string {
	hashData := fmt.Sprintf("%s|%.6f|%.6f|%.6f|%.6f|%.6f|%.6f|%.6f|%.6f",
		totals.ProviderID,
		totals.StorageGBHours,
		totals.BandwidthGB,
		totals.ComputeCPUHours,
		totals.ComputeGPUHours,
		totals.MemoryGBHours,
		totals.ContentPoints,
		totals.NetworkOpsUnits,
		totals.TotalReward,
	)

	hash := sha256.Sum256([]byte(hashData))
	return hex.EncodeToString(hash[:])
}

func (bcm *BillingCycleManager) generateAggregateHash(aggregate *CycleAggregateRecord) string {
	hashData := fmt.Sprintf("%s|%s|%d|%.6f|%.6f|%.6f|%s",
		aggregate.CycleID,
		aggregate.Status,
		aggregate.EventCount,
		aggregate.TotalPoolAmount,
		aggregate.DistributedAmount,
		aggregate.FreeTierSubsidy,
		aggregate.LastUpdated.Format(time.RFC3339Nano),
	)

	hash := sha256.Sum256([]byte(hashData))
	return hex.EncodeToString(hash[:])
}

// Utility functions
func timePtr(t time.Time) *time.Time {
	return &t
}
