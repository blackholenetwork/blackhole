package incentive

import (
	"fmt"
	"time"
)

// MarketPricingModel implements market-based resource pricing using industry standard rates
type MarketPricingModel struct {
	// Base market rates (industry standard pricing)
	BaseRates MarketRates `json:"base_rates"`
	
	// Pricing configuration
	Config MarketPricingConfig `json:"config"`
}

// MarketRates defines industry standard pricing for each resource type
type MarketRates struct {
	// Storage pricing (per GB per month)
	StoragePerGBMonth   float64 `json:"storage_per_gb_month"`   // $0.10/GB/month (AWS S3 standard)
	
	// Bandwidth pricing (per GB transferred)
	BandwidthPerGB      float64 `json:"bandwidth_per_gb"`       // $0.09/GB (AWS data transfer)
	
	// Compute pricing (per CPU-hour)
	ComputePerCPUHour   float64 `json:"compute_per_cpu_hour"`   // $0.05/CPU-hour (AWS EC2 t3.medium rate)
	
	// Memory pricing (per GB-hour)
	MemoryPerGBHour     float64 `json:"memory_per_gb_hour"`     // $0.0125/GB-hour (AWS EC2 memory rate)
	
	// Storage operations (per 1000 operations)
	StorageReadPer1K    float64 `json:"storage_read_per_1k"`    // $0.0004/1K reads (AWS S3)
	StorageWritePer1K   float64 `json:"storage_write_per_1k"`   // $0.005/1K writes (AWS S3)
	
	// Content delivery (per GB)
	ContentDeliveryPerGB float64 `json:"content_delivery_per_gb"` // $0.085/GB (AWS CloudFront)
	
	// GPU compute (per GPU-hour)
	GPUComputePerHour   float64 `json:"gpu_compute_per_hour"`   // $2.50/GPU-hour (AWS p3.2xlarge rate)
}

// MarketPricingConfig defines how market pricing is applied
type MarketPricingConfig struct {
	// Fixed allocation percentages
	ContentCreatorPercentage float64 `json:"content_creator_percentage"`  // 70% fixed for content creators
	NetworkOpsPercentage     float64 `json:"network_ops_percentage"`      // 2.5% fixed for network operations
	AppDeveloperPercentage   float64 `json:"app_developer_percentage"`    // 2.5% fixed for app developers
	InfrastructurePercentage float64 `json:"infrastructure_percentage"`   // 25% for infrastructure (market-based)
	
	// Market-based multipliers for the infrastructure portion
	ProviderEfficiencyBonus  float64 `json:"provider_efficiency_bonus"`   // +20% bonus for infrastructure providers
}

// ResourceUsageCost represents the cost calculation for a user's resource usage
type ResourceUsageCost struct {
	UserID           string                   `json:"user_id"`
	BillingCycleID   string                   `json:"billing_cycle_id"`
	
	// Detailed usage breakdown
	StorageUsage     StorageUsageDetail       `json:"storage_usage"`
	BandwidthUsage   BandwidthUsageDetail     `json:"bandwidth_usage"`
	ComputeUsage     ComputeUsageDetail       `json:"compute_usage"`
	ContentUsage     ContentUsageDetail       `json:"content_usage"`
	
	// Cost calculations
	TotalMarketCost  float64                  `json:"total_market_cost"`  // What it would cost at market rates
	SubscriptionPaid float64                  `json:"subscription_paid"`  // What user actually paid
	CostRatio        float64                  `json:"cost_ratio"`         // subscription_paid / market_cost
	
	CalculatedAt     time.Time                `json:"calculated_at"`
}

// StorageUsageDetail breaks down storage usage and costs
type StorageUsageDetail struct {
	TotalGBHours      float64 `json:"total_gb_hours"`       // GB stored * hours
	ReadOperations    int64   `json:"read_operations"`      // Number of read ops
	WriteOperations   int64   `json:"write_operations"`     // Number of write ops
	
	StorageCost       float64 `json:"storage_cost"`         // GB-hours * rate
	ReadCost          float64 `json:"read_cost"`            // Read ops * rate
	WriteCost         float64 `json:"write_cost"`           // Write ops * rate
	TotalCost         float64 `json:"total_cost"`           // Sum of all storage costs
}

// BandwidthUsageDetail breaks down bandwidth usage and costs
type BandwidthUsageDetail struct {
	TotalGBTransferred float64 `json:"total_gb_transferred"` // Total GB transferred
	ContentDeliveryGB  float64 `json:"content_delivery_gb"`  // GB for content delivery
	DataTransferGB     float64 `json:"data_transfer_gb"`     // GB for general data transfer
	
	DataTransferCost   float64 `json:"data_transfer_cost"`   // Data transfer * rate
	ContentDeliveryCost float64 `json:"content_delivery_cost"` // Content delivery * rate
	TotalCost          float64 `json:"total_cost"`           // Sum of bandwidth costs
}

// ComputeUsageDetail breaks down compute usage and costs
type ComputeUsageDetail struct {
	CPUHours          float64 `json:"cpu_hours"`            // CPU hours used
	GPUHours          float64 `json:"gpu_hours"`            // GPU hours used
	MemoryGBHours     float64 `json:"memory_gb_hours"`      // Memory GB-hours
	
	CPUCost           float64 `json:"cpu_cost"`             // CPU hours * rate
	GPUCost           float64 `json:"gpu_cost"`             // GPU hours * rate
	MemoryCost        float64 `json:"memory_cost"`          // Memory GB-hours * rate
	TotalCost         float64 `json:"total_cost"`           // Sum of compute costs
}

// ContentUsageDetail breaks down content consumption and creator rewards
type ContentUsageDetail struct {
	ContentViewHours  float64 `json:"content_view_hours"`   // Hours of content consumed
	ContentCreators   map[string]float64 `json:"content_creators"` // creatorID -> hours viewed
	
	ContentCost       float64 `json:"content_cost"`         // Content viewing cost
	CreatorRewards    float64 `json:"creator_rewards"`      // Premium for creators
	TotalCost         float64 `json:"total_cost"`           // Content + creator rewards
}

// DefaultMarketRates returns industry standard pricing rates
func DefaultMarketRates() MarketRates {
	return MarketRates{
		// Based on AWS pricing (as of 2024)
		StoragePerGBMonth:    0.023,  // $0.023/GB/month (S3 Standard)
		BandwidthPerGB:       0.09,   // $0.09/GB (Data Transfer Out)
		ComputePerCPUHour:    0.0464, // $0.0464/CPU-hour (t3.medium)
		MemoryPerGBHour:      0.0058, // $0.0058/GB-hour (t3.medium memory)
		StorageReadPer1K:     0.0004, // $0.0004/1K reads (S3 GET)
		StorageWritePer1K:    0.005,  // $0.005/1K writes (S3 PUT)
		ContentDeliveryPerGB: 0.085,  // $0.085/GB (CloudFront)
		GPUComputePerHour:    2.50,   // $2.50/GPU-hour (p3.2xlarge)
	}
}

// DefaultMarketPricingConfig returns default market pricing configuration
func DefaultMarketPricingConfig() MarketPricingConfig {
	return MarketPricingConfig{
		ContentCreatorPercentage: 0.70,   // 70% fixed for content creators
		NetworkOpsPercentage:     0.025,  // 2.5% fixed for network operations
		AppDeveloperPercentage:   0.025,  // 2.5% fixed for app developers  
		InfrastructurePercentage: 0.25,   // 25% for infrastructure (market-based ratios)
		ProviderEfficiencyBonus:  0.20,   // 20% bonus for infrastructure providers
	}
}

// NewMarketPricingModel creates a new market-based pricing model
func NewMarketPricingModel() *MarketPricingModel {
	return &MarketPricingModel{
		BaseRates: DefaultMarketRates(),
		Config:    DefaultMarketPricingConfig(),
	}
}

// CalculateUserCost calculates total market cost for a user's resource usage
func (mpm *MarketPricingModel) CalculateUserCost(usage UserResourceUsage) ResourceUsageCost {
	cost := ResourceUsageCost{
		UserID:         usage.UserID,
		BillingCycleID: usage.BillingCycleID,
		CalculatedAt:   time.Now(),
	}
	
	// Calculate storage costs
	cost.StorageUsage = StorageUsageDetail{
		TotalGBHours:    usage.StorageGBHours,
		ReadOperations:  usage.StorageReads,
		WriteOperations: usage.StorageWrites,
		StorageCost:     usage.StorageGBHours * mpm.BaseRates.StoragePerGBMonth,
		ReadCost:        float64(usage.StorageReads) / 1000.0 * mpm.BaseRates.StorageReadPer1K,
		WriteCost:       float64(usage.StorageWrites) / 1000.0 * mpm.BaseRates.StorageWritePer1K,
	}
	cost.StorageUsage.TotalCost = cost.StorageUsage.StorageCost + cost.StorageUsage.ReadCost + cost.StorageUsage.WriteCost
	
	// Calculate bandwidth costs
	cost.BandwidthUsage = BandwidthUsageDetail{
		TotalGBTransferred:  usage.BandwidthGB,
		ContentDeliveryGB:   usage.ContentDeliveryGB,
		DataTransferGB:      usage.BandwidthGB - usage.ContentDeliveryGB,
		DataTransferCost:    (usage.BandwidthGB - usage.ContentDeliveryGB) * mpm.BaseRates.BandwidthPerGB,
		ContentDeliveryCost: usage.ContentDeliveryGB * mpm.BaseRates.ContentDeliveryPerGB,
	}
	cost.BandwidthUsage.TotalCost = cost.BandwidthUsage.DataTransferCost + cost.BandwidthUsage.ContentDeliveryCost
	
	// Calculate compute costs
	cost.ComputeUsage = ComputeUsageDetail{
		CPUHours:      usage.CPUHours,
		GPUHours:      usage.GPUHours,
		MemoryGBHours: usage.MemoryGBHours,
		CPUCost:       usage.CPUHours * mpm.BaseRates.ComputePerCPUHour,
		GPUCost:       usage.GPUHours * mpm.BaseRates.GPUComputePerHour,
		MemoryCost:    usage.MemoryGBHours * mpm.BaseRates.MemoryPerGBHour,
	}
	cost.ComputeUsage.TotalCost = cost.ComputeUsage.CPUCost + cost.ComputeUsage.GPUCost + cost.ComputeUsage.MemoryCost
	
	// Calculate content costs (content gets separate fixed allocation, not market-based)
	contentBaseCost := usage.ContentViewHours * mpm.BaseRates.ContentDeliveryPerGB // Content delivery rate
	cost.ContentUsage = ContentUsageDetail{
		ContentViewHours: usage.ContentViewHours,
		ContentCreators:  usage.ContentCreators,
		ContentCost:      contentBaseCost,
		CreatorRewards:   0, // Content creators get 70% fixed allocation, not market-based premium
	}
	cost.ContentUsage.TotalCost = cost.ContentUsage.ContentCost
	
	// Calculate total market cost
	cost.TotalMarketCost = cost.StorageUsage.TotalCost + cost.BandwidthUsage.TotalCost + 
		cost.ComputeUsage.TotalCost + cost.ContentUsage.TotalCost
	
	// Set subscription amount
	cost.SubscriptionPaid = usage.SubscriptionAmount
	
	// Calculate cost ratio
	if cost.TotalMarketCost > 0 {
		cost.CostRatio = cost.SubscriptionPaid / cost.TotalMarketCost
	} else {
		cost.CostRatio = 1.0 // If no usage, ratio is 1:1
	}
	
	return cost
}

// CalculateProviderRewards calculates how much each provider should receive based on market rates
func (mpm *MarketPricingModel) CalculateProviderRewards(totalPool float64, providerContributions map[string]ProviderContribution) map[string]float64 {
	rewards := make(map[string]float64)
	
	// Calculate total market value of all contributions
	totalMarketValue := 0.0
	providerMarketValues := make(map[string]float64)
	
	for providerID, contribution := range providerContributions {
		marketValue := mpm.calculateContributionMarketValue(contribution)
		providerMarketValues[providerID] = marketValue
		totalMarketValue += marketValue
	}
	
	// If no contributions, return empty rewards
	if totalMarketValue == 0 {
		return rewards
	}
	
	// Calculate infrastructure pool (29% of total)
	infrastructurePool := totalPool * mpm.Config.InfrastructurePercentage
	
	// Distribute infrastructure pool based on market value ratios
	for providerID, marketValue := range providerMarketValues {
		// Calculate base reward proportional to market value contribution of infrastructure portion
		baseReward := (marketValue / totalMarketValue) * infrastructurePool
		
		// Apply efficiency bonus
		bonusReward := baseReward * mpm.Config.ProviderEfficiencyBonus
		rewards[providerID] = baseReward + bonusReward
	}
	
	return rewards
}

// calculateContributionMarketValue calculates the market value of a provider's contribution
func (mpm *MarketPricingModel) calculateContributionMarketValue(contribution ProviderContribution) float64 {
	value := 0.0
	
	// Storage contribution value
	value += contribution.StorageGBHours * mpm.BaseRates.StoragePerGBMonth
	value += float64(contribution.StorageReads) / 1000.0 * mpm.BaseRates.StorageReadPer1K
	value += float64(contribution.StorageWrites) / 1000.0 * mpm.BaseRates.StorageWritePer1K
	
	// Bandwidth contribution value
	value += contribution.BandwidthGB * mpm.BaseRates.BandwidthPerGB
	value += contribution.ContentDeliveryGB * mpm.BaseRates.ContentDeliveryPerGB
	
	// Compute contribution value
	value += contribution.CPUHours * mpm.BaseRates.ComputePerCPUHour
	value += contribution.GPUHours * mpm.BaseRates.GPUComputePerHour
	value += contribution.MemoryGBHours * mpm.BaseRates.MemoryPerGBHour
	
	return value
}

// UserResourceUsage represents a user's resource consumption for a billing cycle
type UserResourceUsage struct {
	UserID             string             `json:"user_id"`
	BillingCycleID     string             `json:"billing_cycle_id"`
	SubscriptionAmount float64            `json:"subscription_amount"`
	
	// Storage usage
	StorageGBHours     float64            `json:"storage_gb_hours"`
	StorageReads       int64              `json:"storage_reads"`
	StorageWrites      int64              `json:"storage_writes"`
	
	// Bandwidth usage
	BandwidthGB        float64            `json:"bandwidth_gb"`
	ContentDeliveryGB  float64            `json:"content_delivery_gb"`
	
	// Compute usage
	CPUHours           float64            `json:"cpu_hours"`
	GPUHours           float64            `json:"gpu_hours"`
	MemoryGBHours      float64            `json:"memory_gb_hours"`
	
	// Content usage
	ContentViewHours   float64            `json:"content_view_hours"`
	ContentCreators    map[string]float64 `json:"content_creators"` // creatorID -> hours
}

// ProviderContribution represents a provider's resource contributions for a billing cycle
type ProviderContribution struct {
	ProviderID         string  `json:"provider_id"`
	BillingCycleID     string  `json:"billing_cycle_id"`
	
	// Storage contributions
	StorageGBHours     float64 `json:"storage_gb_hours"`
	StorageReads       int64   `json:"storage_reads"`
	StorageWrites      int64   `json:"storage_writes"`
	
	// Bandwidth contributions
	BandwidthGB        float64 `json:"bandwidth_gb"`
	ContentDeliveryGB  float64 `json:"content_delivery_gb"`
	
	// Compute contributions
	CPUHours           float64 `json:"cpu_hours"`
	GPUHours           float64 `json:"gpu_hours"`
	MemoryGBHours      float64 `json:"memory_gb_hours"`
}

// ExampleDistributionScenario demonstrates the 70/1/29 distribution with market ratios
func ExampleDistributionScenario() {
	model := NewMarketPricingModel()
	
	// Example: $30,000 total subscription pool for the month
	totalPool := 30000.0
	
	// Fixed allocations
	contentCreatorPool := totalPool * model.Config.ContentCreatorPercentage  // $21,000 (70%)
	networkOpsPool := totalPool * model.Config.NetworkOpsPercentage          // $300 (1%)
	infrastructurePool := totalPool * model.Config.InfrastructurePercentage  // $8,700 (29%)
	
	fmt.Printf("Distribution Example ($%.0f total pool):\n", totalPool)
	fmt.Printf("• Content Creators: $%.0f (%.0f%% fixed)\n", contentCreatorPool, model.Config.ContentCreatorPercentage*100)
	fmt.Printf("• Network Operations: $%.0f (%.0f%% fixed)\n", networkOpsPool, model.Config.NetworkOpsPercentage*100)
	fmt.Printf("• Infrastructure: $%.0f (%.0f%% market-based ratios)\n", infrastructurePool, model.Config.InfrastructurePercentage*100)
	
	// Example provider contributions for infrastructure portion
	providerContributions := map[string]ProviderContribution{
		"storage_provider_alice": {
			ProviderID:         "alice",
			StorageGBHours:     100000.0, // 100GB for 1000 hours
			StorageReads:       50000,    // 50K reads
			StorageWrites:      10000,    // 10K writes
		},
		"bandwidth_provider_bob": {
			ProviderID:         "bob", 
			BandwidthGB:        5000.0,   // 5TB bandwidth
			ContentDeliveryGB:  2000.0,   // 2TB content delivery
		},
		"compute_provider_charlie": {
			ProviderID:         "charlie",
			CPUHours:           1000.0,   // 1000 CPU hours
			MemoryGBHours:      4000.0,   // 4GB for 1000 hours
		},
	}
	
	// Calculate market-based rewards for infrastructure portion
	infrastructureRewards := model.CalculateProviderRewards(infrastructurePool, providerContributions)
	
	fmt.Printf("\nInfrastructure Distribution (Market-Based Ratios):\n")
	for providerID, reward := range infrastructureRewards {
		fmt.Printf("• %s: $%.2f\n", providerID, reward)
	}
	
	fmt.Printf("\nNote: The $%.0f infrastructure pool is distributed based on actual market rates\n", infrastructurePool)
	fmt.Printf("for storage ($%.4f/GB/month), bandwidth ($%.2f/GB), compute ($%.4f/CPU-hour)\n", 
		model.BaseRates.StoragePerGBMonth, model.BaseRates.BandwidthPerGB, model.BaseRates.ComputePerCPUHour)
}

// ValidateMarketRates validates that market rates are reasonable
func (mpm *MarketPricingModel) ValidateMarketRates() error {
	rates := mpm.BaseRates
	
	if rates.StoragePerGBMonth <= 0 || rates.StoragePerGBMonth > 1.0 {
		return fmt.Errorf("storage rate $%.4f outside reasonable range (0, $1.00]", rates.StoragePerGBMonth)
	}
	
	if rates.BandwidthPerGB <= 0 || rates.BandwidthPerGB > 1.0 {
		return fmt.Errorf("bandwidth rate $%.4f outside reasonable range (0, $1.00]", rates.BandwidthPerGB)
	}
	
	if rates.ComputePerCPUHour <= 0 || rates.ComputePerCPUHour > 10.0 {
		return fmt.Errorf("compute rate $%.4f outside reasonable range (0, $10.00]", rates.ComputePerCPUHour)
	}
	
	return nil
}

// UpdateMarketRates allows updating market rates based on current industry pricing
func (mpm *MarketPricingModel) UpdateMarketRates(newRates MarketRates) error {
	// Temporarily set new rates for validation
	oldRates := mpm.BaseRates
	mpm.BaseRates = newRates
	
	// Validate new rates
	if err := mpm.ValidateMarketRates(); err != nil {
		// Restore old rates if validation fails
		mpm.BaseRates = oldRates
		return fmt.Errorf("invalid market rates: %w", err)
	}
	
	return nil
}