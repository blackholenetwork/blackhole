package incentive

import (
	"context"
	"fmt"
	"sync"
	"time"

	"github.com/rs/zerolog"
)

// SubscriptionPool manages the collection and distribution of subscription funds
type SubscriptionPool struct {
	mu                 sync.RWMutex
	logger             zerolog.Logger
	config             *Config
	
	// Current billing cycle
	currentCycle       *BillingCycle
	
	// Subscription management
	subscriptions      map[string]*Subscription  // userID -> subscription
	
	// Contribution tracking
	contributions      map[string][]*UsageContribution // cycleID -> contributions
	networkTotals      map[string]*NetworkContribution  // cycleID -> network totals
	
	// Reward management
	calculations       map[string]*RewardCalculation    // cycleID -> calculation
	
	// Internal state
	started            bool
	stopChan           chan struct{}
	wg                 sync.WaitGroup
}

// NewSubscriptionPool creates a new subscription pool manager
func NewSubscriptionPool(config *Config, logger zerolog.Logger) *SubscriptionPool {
	return &SubscriptionPool{
		logger:        logger.With().Str("component", "subscription_pool").Logger(),
		config:        config,
		subscriptions: make(map[string]*Subscription),
		contributions: make(map[string][]*UsageContribution),
		networkTotals: make(map[string]*NetworkContribution),
		calculations:  make(map[string]*RewardCalculation),
		stopChan:      make(chan struct{}),
	}
}

// Start begins the subscription pool management
func (sp *SubscriptionPool) Start(ctx context.Context) error {
	sp.mu.Lock()
	defer sp.mu.Unlock()
	
	if sp.started {
		return fmt.Errorf("subscription pool already started")
	}
	
	sp.logger.Info().Msg("Starting subscription pool")
	
	// Initialize current billing cycle if none exists
	if sp.currentCycle == nil {
		if err := sp.startNewBillingCycle(); err != nil {
			return fmt.Errorf("failed to start initial billing cycle: %w", err)
		}
	}
	
	sp.started = true
	
	// Start background workers
	sp.wg.Add(1)
	go sp.billingCycleManager(ctx)
	
	sp.logger.Info().
		Str("cycle_id", sp.currentCycle.ID).
		Time("cycle_end", sp.currentCycle.EndDate).
		Msg("Subscription pool started")
	
	return nil
}

// Stop stops the subscription pool management
func (sp *SubscriptionPool) Stop(ctx context.Context) error {
	sp.mu.Lock()
	defer sp.mu.Unlock()
	
	if !sp.started {
		return nil
	}
	
	sp.logger.Info().Msg("Stopping subscription pool")
	
	close(sp.stopChan)
	sp.wg.Wait()
	
	sp.started = false
	
	sp.logger.Info().Msg("Subscription pool stopped")
	return nil
}

// AddSubscription adds or updates a user subscription
func (sp *SubscriptionPool) AddSubscription(subscription *Subscription) error {
	sp.mu.Lock()
	defer sp.mu.Unlock()
	
	subscription.UpdatedAt = time.Now()
	sp.subscriptions[subscription.UserID] = subscription
	
	sp.logger.Info().
		Str("user_id", subscription.UserID).
		Str("tier", string(subscription.Tier)).
		Float64("amount", subscription.MonthlyAmount).
		Msg("Subscription added")
	
	return nil
}

// CancelSubscription cancels a user subscription
func (sp *SubscriptionPool) CancelSubscription(userID string) error {
	sp.mu.Lock()
	defer sp.mu.Unlock()
	
	subscription, exists := sp.subscriptions[userID]
	if !exists {
		return fmt.Errorf("subscription not found for user: %s", userID)
	}
	
	subscription.Status = SubscriptionCancelled
	subscription.UpdatedAt = time.Now()
	endDate := time.Now()
	subscription.EndDate = &endDate
	
	sp.logger.Info().
		Str("user_id", userID).
		Msg("Subscription cancelled")
	
	return nil
}

// GetSubscription retrieves a user's subscription
func (sp *SubscriptionPool) GetSubscription(userID string) (*Subscription, error) {
	sp.mu.RLock()
	defer sp.mu.RUnlock()
	
	subscription, exists := sp.subscriptions[userID]
	if !exists {
		return nil, fmt.Errorf("subscription not found for user: %s", userID)
	}
	
	// Return a copy to prevent external modification
	sub := *subscription
	return &sub, nil
}

// GetCurrentCycle returns the current billing cycle
func (sp *SubscriptionPool) GetCurrentCycle() *BillingCycle {
	sp.mu.RLock()
	defer sp.mu.RUnlock()
	
	if sp.currentCycle == nil {
		return nil
	}
	
	// Return a copy
	cycle := *sp.currentCycle
	return &cycle
}

// GetPoolAmount returns the current monthly pool amount
func (sp *SubscriptionPool) GetPoolAmount() float64 {
	sp.mu.RLock()
	defer sp.mu.RUnlock()
	
	var total float64
	for _, subscription := range sp.subscriptions {
		if subscription.Status == SubscriptionActive {
			total += subscription.MonthlyAmount
		}
	}
	
	return total
}

// GetActiveSubscriptions returns count of active subscriptions by tier
func (sp *SubscriptionPool) GetActiveSubscriptions() map[SubscriptionTier]int {
	sp.mu.RLock()
	defer sp.mu.RUnlock()
	
	counts := make(map[SubscriptionTier]int)
	for _, subscription := range sp.subscriptions {
		if subscription.Status == SubscriptionActive {
			counts[subscription.Tier]++
		}
	}
	
	return counts
}

// startNewBillingCycle creates and starts a new billing cycle
func (sp *SubscriptionPool) startNewBillingCycle() error {
	now := time.Now()
	cycleID := fmt.Sprintf("cycle_%d", now.Unix())
	
	sp.currentCycle = &BillingCycle{
		ID:              cycleID,
		StartDate:       now,
		EndDate:         now.Add(sp.config.BillingInterval),
		Status:          CycleStatusActive,
		TotalPoolAmount: 0,
		CreatedAt:       now,
	}
	
	// Initialize network contribution tracking for this cycle
	sp.networkTotals[cycleID] = &NetworkContribution{
		BillingCycleID: cycleID,
		Totals:         make(map[ResourceType]float64),
		ProviderCount:  make(map[ResourceType]int),
		LastUpdated:    now,
	}
	
	sp.logger.Info().
		Str("cycle_id", cycleID).
		Time("start_date", sp.currentCycle.StartDate).
		Time("end_date", sp.currentCycle.EndDate).
		Msg("New billing cycle started")
	
	return nil
}

// billingCycleManager manages billing cycle transitions
func (sp *SubscriptionPool) billingCycleManager(ctx context.Context) {
	defer sp.wg.Done()
	
	ticker := time.NewTicker(time.Hour) // Check every hour
	defer ticker.Stop()
	
	for {
		select {
		case <-ctx.Done():
			return
		case <-sp.stopChan:
			return
		case <-ticker.C:
			sp.checkCycleTransition()
		}
	}
}

// checkCycleTransition checks if current cycle should end and start calculation
func (sp *SubscriptionPool) checkCycleTransition() {
	sp.mu.Lock()
	defer sp.mu.Unlock()
	
	if sp.currentCycle == nil || sp.currentCycle.Status != CycleStatusActive {
		return
	}
	
	now := time.Now()
	if now.After(sp.currentCycle.EndDate) {
		sp.logger.Info().
			Str("cycle_id", sp.currentCycle.ID).
			Msg("Billing cycle ended, starting calculation")
		
		// Calculate final pool amount
		sp.currentCycle.TotalPoolAmount = sp.GetPoolAmount()
		sp.currentCycle.Status = CycleStatusCalculating
		
		// Schedule reward calculation after delay
		go sp.scheduleRewardCalculation(sp.currentCycle.ID)
		
		// Start new cycle
		if err := sp.startNewBillingCycle(); err != nil {
			sp.logger.Error().
				Err(err).
				Msg("Failed to start new billing cycle")
		}
	}
}

// scheduleRewardCalculation schedules reward calculation for a completed cycle
func (sp *SubscriptionPool) scheduleRewardCalculation(cycleID string) {
	time.Sleep(sp.config.CalculationDelay)
	
	sp.mu.Lock()
	defer sp.mu.Unlock()
	
	sp.logger.Info().
		Str("cycle_id", cycleID).
		Msg("Starting reward calculation")
	
	// This will be implemented in the next file (calculation.go)
	// For now, just log the event
	sp.logger.Info().
		Str("cycle_id", cycleID).
		Msg("Reward calculation scheduled")
}

// GetStats returns subscription pool statistics
func (sp *SubscriptionPool) GetStats() *IncentiveStats {
	sp.mu.RLock()
	defer sp.mu.RUnlock()
	
	activeCount := 0
	for _, sub := range sp.subscriptions {
		if sub.Status == SubscriptionActive {
			activeCount++
		}
	}
	
	// Count unique providers from current cycle
	providerCount := 0
	if sp.currentCycle != nil {
		providers := make(map[string]bool)
		for _, contrib := range sp.contributions[sp.currentCycle.ID] {
			providers[contrib.ProviderID] = true
		}
		providerCount = len(providers)
	}
	
	// Count content creators separately
	creatorCount := 0
	if sp.currentCycle != nil {
		// This would need to be implemented to track creators separately
		// For now, we'll leave it at 0
	}
	
	stats := &IncentiveStats{
		ActiveSubscriptions:  activeCount,
		TotalProviders:       providerCount,
		TotalCreators:        creatorCount,
		CurrentCycle:         sp.currentCycle,
		MonthlyPoolAmount:    sp.GetPoolAmount(),
		AverageProviderReward: 0, // Will be calculated from historical data
		AverageCreatorReward:  0, // Will be calculated from historical data
		ResourceDistribution: map[ResourceType]float64{
			ResourceStorage:   sp.config.MarketPricing.InfrastructurePercentage * 0.35, // ~10% of 29%
			ResourceBandwidth: sp.config.MarketPricing.InfrastructurePercentage * 0.40, // ~12% of 29%
			ResourceCompute:   sp.config.MarketPricing.InfrastructurePercentage * 0.25, // ~7% of 29%
			ResourceContent:   sp.config.MarketPricing.ContentCreatorPercentage, // 70%
			ResourceNetworkOps: sp.config.MarketPricing.NetworkOpsPercentage, // 1%
		},
	}
	
	return stats
}