	return s.storage.GetStats(ctx)
}

// HandleWebhook handles payment provider webhooks
func (s *Service) HandleWebhook(ctx context.Context, payload []byte, signature string) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("contract service not running")
	}

	event, err := s.paymentProcessor.HandleWebhook(ctx, payload, signature)
	if err != nil {
		return fmt.Errorf("failed to process webhook: %w", err)
	}

	s.logger.Info().
		Str("event_id", event.ID).
		Str("event_type", event.Type).
		Str("payment_id", event.PaymentID).
		Msg("Processed webhook event")

	// Handle specific event types
	switch event.Type {
	case "payment.completed":
		return s.handlePaymentCompletedWebhook(ctx, event)
	case "payment.failed":
		return s.handlePaymentFailedWebhook(ctx, event)
	case "subscription.cancelled":
		return s.handleSubscriptionCancelledWebhook(ctx, event)
	default:
		s.logger.Debug().
			Str("event_type", event.Type).
			Msg("Unhandled webhook event type")
	}

	return nil
}

// processPayment processes a payment through the payment processor
func (s *Service) processPayment(ctx context.Context, payment *Payment) error {
	payment.AttemptCount++
	payment.LastAttemptAt = &payment.UpdatedAt

	// Store payment attempt
	if payment.AttemptCount == 1 {
		if err := s.storage.CreatePayment(ctx, payment); err != nil {
			return fmt.Errorf("failed to create payment: %w", err)
		}
	} else {
		if err := s.storage.UpdatePayment(ctx, payment); err != nil {
			return fmt.Errorf("failed to update payment: %w", err)
		}
	}

	// Process payment
	result, err := s.paymentProcessor.ProcessPayment(ctx, payment)
	if err != nil {
		payment.Status = PaymentFailed
		payment.FailureReason = err.Error()
		s.storage.UpdatePayment(ctx, payment)
		return fmt.Errorf("payment processing failed: %w", err)
	}

	// Update payment with result
	payment.Status = result.Status
	payment.ExternalPaymentID = result.ExternalPaymentID
	payment.TransactionID = result.TransactionID

	if result.Success {
		now := time.Now()
		payment.ProcessedAt = &now
		payment.Status = PaymentCompleted
	} else {
		payment.FailureReason = result.FailureReason
		payment.Status = PaymentFailed

		// Schedule retry if within retry limits
		if payment.AttemptCount < s.config.PaymentRetryAttempts {
			nextRetry := time.Now().Add(s.config.PaymentRetryInterval)
			payment.NextRetryAt = &nextRetry
		}
	}

	payment.UpdatedAt = time.Now()

	// Store updated payment
	if err := s.storage.UpdatePayment(ctx, payment); err != nil {
		return fmt.Errorf("failed to update payment: %w", err)
	}

	s.logger.Info().
		Str("payment_id", payment.ID).
		Bool("success", result.Success).
		Int("attempt", payment.AttemptCount).
		Str("status", string(payment.Status)).
		Msg("Processed payment")

	return nil
}

// Helper functions

func generateChangeID() string {
	return fmt.Sprintf("chg_%d", time.Now().UnixNano())
}

func (s *Service) determineChangeType(fromTier, toTier SubscriptionTier, fromAmount, toAmount float64) string {
	if toAmount > fromAmount {
		return "upgrade"
	} else if toAmount < fromAmount {
		return "downgrade"
	}
	return "change"
}

func (s *Service) calculateProration(subscription *Subscription, fromAmount, toAmount float64) float64 {
	// Calculate remaining days in billing cycle
	now := time.Now()
	totalDays := subscription.EndDate.Sub(subscription.StartDate).Hours() / 24
	remainingDays := subscription.EndDate.Sub(now).Hours() / 24

	if remainingDays <= 0 {
		return 0
	}

	// Calculate proration
	dailyDifference := (toAmount - fromAmount) / totalDays
	return dailyDifference * remainingDays
}

func (s *Service) handlePaymentCompletedWebhook(ctx context.Context, event *WebhookEvent) error {
	payment, err := s.storage.GetPayment(ctx, event.PaymentID)
	if err != nil {
		return fmt.Errorf("payment not found: %w", err)
	}

	payment.Status = PaymentCompleted
	now := time.Now()
	payment.ProcessedAt = &now
	payment.UpdatedAt = now

	if err := s.storage.UpdatePayment(ctx, payment); err != nil {
		return fmt.Errorf("failed to update payment: %w", err)
	}

	// Update subscription
	subscription, err := s.storage.GetSubscription(ctx, payment.SubscriptionID)
	if err != nil {
		return fmt.Errorf("subscription not found: %w", err)
	}

	subscription.LastPaymentDate = &now
	subscription.LastPaymentAmount = payment.Amount
	subscription.Status = SubscriptionActive
	subscription.UpdatedAt = now

	if err := s.storage.UpdateSubscription(ctx, subscription); err != nil {
		return fmt.Errorf("failed to update subscription: %w", err)
	}

	// Notify other services
	if s.incentiveNotifier != nil {
		go s.incentiveNotifier.OnPaymentCompleted(ctx, subscription, payment)
	}

	if s.notifier != nil {
		go s.notifier.SendPaymentSuccessNotification(ctx, subscription, payment)
	}

	return nil
}

func (s *Service) handlePaymentFailedWebhook(ctx context.Context, event *WebhookEvent) error {
	payment, err := s.storage.GetPayment(ctx, event.PaymentID)
	if err != nil {
		return fmt.Errorf("payment not found: %w", err)
	}

	payment.Status = PaymentFailed
	payment.UpdatedAt = time.Now()

	if err := s.storage.UpdatePayment(ctx, payment); err != nil {
		return fmt.Errorf("failed to update payment: %w", err)
	}

	// Get subscription for notification
	subscription, err := s.storage.GetSubscription(ctx, payment.SubscriptionID)
	if err != nil {
		return fmt.Errorf("subscription not found: %w", err)
	}

	if s.notifier != nil {
		go s.notifier.SendPaymentFailureNotification(ctx, subscription, payment)
	}

	return nil
}

func (s *Service) handleSubscriptionCancelledWebhook(ctx context.Context, event *WebhookEvent) error {
	subscription, err := s.storage.GetSubscription(ctx, event.SubscriptionID)
	if err != nil {
		return fmt.Errorf("subscription not found: %w", err)
	}

	subscription.Status = SubscriptionCancelled
	now := time.Now()
	subscription.CancelledAt = &now
	subscription.UpdatedAt = now

	if err := s.storage.UpdateSubscription(ctx, subscription); err != nil {
		return fmt.Errorf("failed to update subscription: %w", err)
	}

	// Notify other services
	if s.incentiveNotifier != nil {
		go s.incentiveNotifier.OnSubscriptionCancelled(ctx, subscription)
	}

	if s.authNotifier != nil {
		go s.authNotifier.OnSubscriptionStatusChanged(ctx, subscription.UserID, subscription)
	}

	return nil
}
