package contract

import (
	"context"
	"fmt"
	"time"
)

// GetSubscription retrieves a subscription by ID
func (s *Service) GetSubscription(ctx context.Context, id string) (*Subscription, error) {
	if !s.started || !s.config.Enabled {
		return nil, fmt.Errorf("contract service not running")
	}

	return s.storage.GetSubscription(ctx, id)
}

// GetSubscriptionByUserID retrieves a user's subscription
func (s *Service) GetSubscriptionByUserID(ctx context.Context, userID string) (*Subscription, error) {
	if !s.started || !s.config.Enabled {
		return nil, fmt.Errorf("contract service not running")
	}

	return s.storage.GetSubscriptionByUserID(ctx, userID)
}

// UpdateSubscription updates an existing subscription
func (s *Service) UpdateSubscription(ctx context.Context, subscriptionID string, req SubscriptionUpdateRequest) (*Subscription, error) {
	if !s.started || !s.config.Enabled {
		return nil, fmt.Errorf("contract service not running")
	}

	// Get existing subscription
	subscription, err := s.storage.GetSubscription(ctx, subscriptionID)
	if err != nil {
		return nil, fmt.Errorf("subscription not found: %w", err)
	}

	// Track changes
	change := &SubscriptionChange{
		ID:             generateChangeID(),
		SubscriptionID: subscription.ID,
		UserID:         subscription.UserID,
		FromTier:       subscription.Tier,
		FromAmount:     subscription.MonthlyAmount,
		RequestedAt:    time.Now(),
		EffectiveAt:    time.Now(),
		Reason:         req.Reason,
		Metadata:       req.Metadata,
		CreatedAt:      time.Now(),
		UpdatedAt:      time.Now(),
	}

	// Apply effective date if specified
	if req.EffectiveAt != nil {
		change.EffectiveAt = *req.EffectiveAt
	}

	// Update tier if specified
	if req.Tier != nil {
		tierConfig, err := s.getTierConfig(*req.Tier, req.CustomAmount)
		if err != nil {
			return nil, fmt.Errorf("invalid tier configuration: %w", err)
		}

		change.ChangeType = s.determineChangeType(subscription.Tier, *req.Tier, subscription.MonthlyAmount, tierConfig.MonthlyPrice)
		change.ToTier = *req.Tier
		change.ToAmount = tierConfig.MonthlyPrice

		subscription.Tier = *req.Tier
		subscription.MonthlyAmount = tierConfig.MonthlyPrice
		subscription.ResourceLimits = tierConfig.ResourceLimits
		subscription.APIRateLimits = tierConfig.APIRateLimits
		subscription.Features = tierConfig.Features

		// Calculate proration if upgrade/downgrade
		if change.ChangeType == "upgrade" || change.ChangeType == "downgrade" {
			change.ProrationAmount = s.calculateProration(subscription, change.FromAmount, change.ToAmount)
		}
	}

	// Update payment method if specified
	if req.PaymentMethodID != nil {
		subscription.PaymentMethodID = *req.PaymentMethodID
	}

	// Update metadata
	if req.Metadata != nil {
		for k, v := range req.Metadata {
			subscription.Metadata[k] = v
		}
	}

	subscription.UpdatedAt = time.Now()

	// Store changes
	if err := s.storage.CreateSubscriptionChange(ctx, change); err != nil {
		return nil, fmt.Errorf("failed to create subscription change: %w", err)
	}

	if err := s.storage.UpdateSubscription(ctx, subscription); err != nil {
		return nil, fmt.Errorf("failed to update subscription: %w", err)
	}

	// Notify other services
	if s.incentiveNotifier != nil {
		go s.incentiveNotifier.OnSubscriptionUpdated(ctx, subscription)
	}

	if s.authNotifier != nil && req.Tier != nil {
		go s.authNotifier.OnSubscriptionTierChanged(ctx, subscription.UserID, change.FromTier, change.ToTier)
	}

	s.logger.Info().
		Str("subscription_id", subscription.ID).
		Str("change_type", change.ChangeType).
		Str("from_tier", string(change.FromTier)).
		Str("to_tier", string(change.ToTier)).
		Float64("proration", change.ProrationAmount).
		Msg("Updated subscription")

	return subscription, nil
}

// CancelSubscription cancels a subscription
func (s *Service) CancelSubscription(ctx context.Context, subscriptionID, reason string) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("contract service not running")
	}

	// Get subscription
	subscription, err := s.storage.GetSubscription(ctx, subscriptionID)
	if err != nil {
		return fmt.Errorf("subscription not found: %w", err)
	}

	// Check if already cancelled
	if subscription.Status == SubscriptionCancelled {
		return fmt.Errorf("subscription already cancelled")
	}

	// Update subscription status
	now := time.Now()
	subscription.Status = SubscriptionCancelled
	subscription.CancellationReason = reason
	subscription.CancelledAt = &now
	subscription.UpdatedAt = now

	// Record change
	change := &SubscriptionChange{
		ID:             generateChangeID(),
		SubscriptionID: subscription.ID,
		UserID:         subscription.UserID,
		ChangeType:     "cancel",
		FromTier:       subscription.Tier,
		ToTier:         subscription.Tier,
		FromAmount:     subscription.MonthlyAmount,
		ToAmount:       0,
		RequestedAt:    now,
		EffectiveAt:    now,
		Reason:         reason,
		Metadata:       make(map[string]string),
		CreatedAt:      now,
		UpdatedAt:      now,
	}

	// Store changes
	if err := s.storage.CreateSubscriptionChange(ctx, change); err != nil {
		s.logger.Error().Err(err).Msg("Failed to create subscription change for cancellation")
	}

	if err := s.storage.UpdateSubscription(ctx, subscription); err != nil {
		return fmt.Errorf("failed to update subscription: %w", err)
	}

	// Cancel with payment provider
	if err := s.paymentProcessor.CancelSubscription(ctx, subscription.ID); err != nil {
		s.logger.Error().
			Err(err).
			Str("subscription_id", subscription.ID).
			Msg("Failed to cancel subscription with payment provider")
	}

	// Notify other services
	if s.incentiveNotifier != nil {
		go s.incentiveNotifier.OnSubscriptionCancelled(ctx, subscription)
	}

	if s.authNotifier != nil {
		go s.authNotifier.OnSubscriptionStatusChanged(ctx, subscription.UserID, subscription)
	}

	if s.notifier != nil {
		go s.notifier.SendSubscriptionCancelledNotification(ctx, subscription)
	}

	s.logger.Info().
		Str("subscription_id", subscription.ID).
		Str("user_id", subscription.UserID).
		Str("reason", reason).
		Msg("Cancelled subscription")

	return nil
}

// CreatePaymentMethod creates a new payment method
func (s *Service) CreatePaymentMethod(ctx context.Context, req PaymentMethodRequest) (*PaymentMethod, error) {
	if !s.started || !s.config.Enabled {
		return nil, fmt.Errorf("contract service not running")
	}

	// Create payment method with provider
	paymentMethod, err := s.paymentProcessor.CreatePaymentMethod(ctx, req)
	if err != nil {
		return nil, fmt.Errorf("failed to create payment method with provider: %w", err)
	}

	// Store payment method
	if err := s.storage.CreatePaymentMethod(ctx, paymentMethod); err != nil {
		return nil, fmt.Errorf("failed to store payment method: %w", err)
	}

	s.logger.Info().
		Str("payment_method_id", paymentMethod.ID).
		Str("user_id", paymentMethod.UserID).
		Str("type", paymentMethod.Type).
		Msg("Created payment method")

	return paymentMethod, nil
}

// GetPaymentMethods retrieves payment methods for a user
func (s *Service) GetPaymentMethods(ctx context.Context, userID string) ([]*PaymentMethod, error) {
	if !s.started || !s.config.Enabled {
		return nil, fmt.Errorf("contract service not running")
	}

	return s.storage.ListPaymentMethods(ctx, userID)
}

// DeletePaymentMethod deletes a payment method
func (s *Service) DeletePaymentMethod(ctx context.Context, paymentMethodID string) error {
	if !s.started || !s.config.Enabled {
		return fmt.Errorf("contract service not running")
	}

	// Delete from provider
	if err := s.paymentProcessor.DeletePaymentMethod(ctx, paymentMethodID); err != nil {
		s.logger.Error().
			Err(err).
			Str("payment_method_id", paymentMethodID).
			Msg("Failed to delete payment method from provider")
	}

	// Delete from storage
	if err := s.storage.DeletePaymentMethod(ctx, paymentMethodID); err != nil {
		return fmt.Errorf("failed to delete payment method: %w", err)
	}

	s.logger.Info().
		Str("payment_method_id", paymentMethodID).
		Msg("Deleted payment method")

	return nil
}

