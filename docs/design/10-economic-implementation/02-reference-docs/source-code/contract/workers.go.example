package contract

import (
	"context"
	"time"
)

// billingWorker handles recurring billing and subscription management
func (s *Service) billingWorker(ctx context.Context) {
	defer s.wg.Done()
	
	// Check for billing tasks every hour
	ticker := time.NewTicker(time.Hour)
	defer ticker.Stop()
	
	s.logger.Debug().Msg("Billing worker started")
	
	for {
		select {
		case <-ctx.Done():
			return
		case <-s.stopChan:
			return
		case <-ticker.C:
			s.processBillingTasks(ctx)
		}
	}
}

// notificationWorker handles sending notifications for subscription events
func (s *Service) notificationWorker(ctx context.Context) {
	defer s.wg.Done()
	
	// Check for notifications every 6 hours
	ticker := time.NewTicker(6 * time.Hour)
	defer ticker.Stop()
	
	s.logger.Debug().Msg("Notification worker started")
	
	for {
		select {
		case <-ctx.Done():
			return
		case <-s.stopChan:
			return
		case <-ticker.C:
			s.processNotifications(ctx)
		}
	}
}

// statsWorker updates service statistics periodically
func (s *Service) statsWorker(ctx context.Context) {
	defer s.wg.Done()
	
	// Update stats every 15 minutes
	ticker := time.NewTicker(15 * time.Minute)
	defer ticker.Stop()
	
	s.logger.Debug().Msg("Stats worker started")
	
	for {
		select {
		case <-ctx.Done():
			return
		case <-s.stopChan:
			return
		case <-ticker.C:
			s.updateStats(ctx)
		}
	}
}

// processBillingTasks handles recurring billing, trial expirations, and payment retries
func (s *Service) processBillingTasks(ctx context.Context) {
	now := time.Now()
	
	// Get subscriptions that need billing
	filters := SubscriptionFilters{
		Status: SubscriptionActive,
		Limit:  1000, // Process in batches
	}
	
	subscriptions, err := s.storage.ListSubscriptions(ctx, filters)
	if err != nil {
		s.logger.Error().Err(err).Msg("Failed to list subscriptions for billing")
		return
	}
	
	processed := 0
	
	for _, subscription := range subscriptions {
		// Process trial expirations
		if subscription.IsTrialPeriod && subscription.TrialEndDate != nil && now.After(*subscription.TrialEndDate) {
			s.processTrialExpiration(ctx, subscription)
			processed++
			continue
		}
		
		// Process subscription renewals
		if now.After(subscription.NextBillingDate) && subscription.MonthlyAmount > 0 {
			s.processSubscriptionRenewal(ctx, subscription)
			processed++
		}
		
		// Check for subscription expiration (grace period)
		graceExpiry := subscription.NextBillingDate.Add(s.config.GracePeriod)
		if now.After(graceExpiry) && subscription.Status == SubscriptionActive {
			s.processSubscriptionExpiration(ctx, subscription)
			processed++
		}
	}
	
	// Get failed payments that need retry
	paymentFilters := PaymentFilters{
		Status: PaymentFailed,
		Limit:  500,
	}
	
	payments, err := s.storage.ListPayments(ctx, paymentFilters)
	if err != nil {
		s.logger.Error().Err(err).Msg("Failed to list failed payments for retry")
		return
	}
	
	for _, payment := range payments {
		if payment.NextRetryAt != nil && now.After(*payment.NextRetryAt) && payment.AttemptCount < s.config.PaymentRetryAttempts {
			s.retryPayment(ctx, payment)
			processed++
		}
	}
	
	if processed > 0 {
		s.logger.Info().
			Int("processed", processed).
			Msg("Processed billing tasks")
	}
}

// processTrialExpiration handles trial period expiration
func (s *Service) processTrialExpiration(ctx context.Context, subscription *Subscription) {
	s.logger.Info().
		Str("subscription_id", subscription.ID).
		Str("user_id", subscription.UserID).
		Msg("Processing trial expiration")
	
	// End trial period
	subscription.IsTrialPeriod = false
	subscription.TrialEndDate = nil
	
	// If subscription has no cost, keep it active
	if subscription.MonthlyAmount == 0 {
		subscription.Status = SubscriptionActive
		subscription.UpdatedAt = time.Now()
		s.storage.UpdateSubscription(ctx, subscription)
		return
	}
	
	// Create first paid billing cycle
	now := time.Now()
	subscription.NextBillingDate = now.Add(subscription.BillingCycle)
	subscription.EndDate = subscription.NextBillingDate
	
	// Create payment for first billing cycle
	payment := &Payment{
		ID:                 generatePaymentID(),
		SubscriptionID:     subscription.ID,
		UserID:             subscription.UserID,
		Amount:             subscription.MonthlyAmount,
		Currency:           subscription.Currency,
		Status:             PaymentPending,
		PaymentProvider:    s.paymentProcessor.GetProviderName(),
		PaymentMethodID:    subscription.PaymentMethodID,
		BillingPeriodStart: now,
		BillingPeriodEnd:   subscription.NextBillingDate,
		AttemptCount:       0,
		Metadata:           make(map[string]string),
		CreatedAt:          now,
		UpdatedAt:          now,
	}
	
	// Process payment
	if err := s.processPayment(ctx, payment); err != nil {
		s.logger.Error().
			Err(err).
			Str("subscription_id", subscription.ID).
			Msg("Failed to process trial-to-paid conversion payment")
		
		subscription.Status = SubscriptionSuspended
	} else {
		subscription.Status = SubscriptionActive
		subscription.LastPaymentDate = &payment.CreatedAt
		subscription.LastPaymentAmount = payment.Amount
	}
	
	subscription.UpdatedAt = time.Now()
	s.storage.UpdateSubscription(ctx, subscription)
	
	// Notify incentive service of subscription change
	if s.incentiveNotifier != nil {
		go s.incentiveNotifier.OnSubscriptionUpdated(ctx, subscription)
	}
}

// processSubscriptionRenewal handles recurring billing for active subscriptions
func (s *Service) processSubscriptionRenewal(ctx context.Context, subscription *Subscription) {
	s.logger.Info().
		Str("subscription_id", subscription.ID).
		Str("user_id", subscription.UserID).
		Float64("amount", subscription.MonthlyAmount).
		Msg("Processing subscription renewal")
	
	now := time.Now()
	
	// Create payment for next billing cycle
	payment := &Payment{
		ID:                 generatePaymentID(),
		SubscriptionID:     subscription.ID,
		UserID:             subscription.UserID,
		Amount:             subscription.MonthlyAmount,
		Currency:           subscription.Currency,
		Status:             PaymentPending,
		PaymentProvider:    s.paymentProcessor.GetProviderName(),
		PaymentMethodID:    subscription.PaymentMethodID,
		BillingPeriodStart: subscription.NextBillingDate,
		BillingPeriodEnd:   subscription.NextBillingDate.Add(subscription.BillingCycle),
		AttemptCount:       0,
		Metadata:           make(map[string]string),
		CreatedAt:          now,
		UpdatedAt:          now,
	}
	
	// Process payment
	if err := s.processPayment(ctx, payment); err != nil {
		s.logger.Error().
			Err(err).
			Str("subscription_id", subscription.ID).
			Msg("Failed to process subscription renewal payment")
		// Don't change subscription status here - let grace period handle it
		return
	}
	
	// Update subscription for next billing cycle
	subscription.NextBillingDate = payment.BillingPeriodEnd
	subscription.EndDate = payment.BillingPeriodEnd
	subscription.LastPaymentDate = &payment.CreatedAt
	subscription.LastPaymentAmount = payment.Amount
	subscription.UpdatedAt = now
	
	s.storage.UpdateSubscription(ctx, subscription)
	
	// Notify incentive service of payment
	if s.incentiveNotifier != nil {
		go s.incentiveNotifier.OnPaymentCompleted(ctx, subscription, payment)
	}
	
	// Send payment success notification
	if s.notifier != nil {
		go s.notifier.SendPaymentSuccessNotification(ctx, subscription, payment)
	}
}

// processSubscriptionExpiration handles subscriptions that have exceeded the grace period
func (s *Service) processSubscriptionExpiration(ctx context.Context, subscription *Subscription) {
	s.logger.Info().
		Str("subscription_id", subscription.ID).
		Str("user_id", subscription.UserID).
		Msg("Processing subscription expiration")
	
	subscription.Status = SubscriptionExpired
	subscription.UpdatedAt = time.Now()
	
	s.storage.UpdateSubscription(ctx, subscription)
	
	// Notify other services
	if s.incentiveNotifier != nil {
		go s.incentiveNotifier.OnSubscriptionCancelled(ctx, subscription)
	}
	
	if s.authNotifier != nil {
		go s.authNotifier.OnSubscriptionStatusChanged(ctx, subscription.UserID, subscription)
	}
}

// retryPayment retries a failed payment
func (s *Service) retryPayment(ctx context.Context, payment *Payment) {
	s.logger.Info().
		Str("payment_id", payment.ID).
		Int("attempt", payment.AttemptCount+1).
		Msg("Retrying failed payment")
	
	if err := s.processPayment(ctx, payment); err != nil {
		s.logger.Error().
			Err(err).
			Str("payment_id", payment.ID).
			Msg("Payment retry failed")
		
		// If this was the last retry attempt, suspend subscription
		if payment.AttemptCount >= s.config.PaymentRetryAttempts {
			subscription, err := s.storage.GetSubscription(ctx, payment.SubscriptionID)
			if err == nil {
				subscription.Status = SubscriptionSuspended
				subscription.UpdatedAt = time.Now()
				s.storage.UpdateSubscription(ctx, subscription)
				
				// Notify authorization service
				if s.authNotifier != nil {
					go s.authNotifier.OnSubscriptionStatusChanged(ctx, subscription.UserID, subscription)
				}
			}
		}
	}
}

// processNotifications handles sending expiration warnings and renewal reminders
func (s *Service) processNotifications(ctx context.Context) {
	if s.notifier == nil || !s.config.NotificationSettings.Enabled {
		return
	}
	
	now := time.Now()
	
	// Get active subscriptions
	filters := SubscriptionFilters{
		Status: SubscriptionActive,
		Limit:  1000,
	}
	
	subscriptions, err := s.storage.ListSubscriptions(ctx, filters)
	if err != nil {
		s.logger.Error().Err(err).Msg("Failed to list subscriptions for notifications")
		return
	}
	
	for _, subscription := range subscriptions {
		// Send expiration warnings
		for _, days := range s.config.NotificationSettings.ExpirationWarningDays {
			warningDate := subscription.NextBillingDate.AddDate(0, 0, -days)
			if now.After(warningDate) && now.Before(warningDate.Add(24*time.Hour)) {
				go s.notifier.SendExpirationWarning(ctx, subscription, days)
			}
		}
		
		// Send renewal reminders
		for _, days := range s.config.NotificationSettings.RenewalReminderDays {
			reminderDate := subscription.NextBillingDate.AddDate(0, 0, -days)
			if now.After(reminderDate) && now.Before(reminderDate.Add(24*time.Hour)) {
				go s.notifier.SendRenewalReminder(ctx, subscription, days)
			}
		}
	}
}

// updateStats calculates and caches service statistics
func (s *Service) updateStats(ctx context.Context) {
	stats, err := s.storage.GetStats(ctx)
	if err != nil {
		s.logger.Error().Err(err).Msg("Failed to update contract stats")
		return
	}
	
	s.mu.Lock()
	s.stats = stats
	s.lastStatsUpdate = time.Now()
	s.mu.Unlock()
	
	s.logger.Debug().
		Int("total_subscriptions", stats.TotalSubscriptions).
		Int("active_subscriptions", stats.ActiveSubscriptions).
		Float64("monthly_revenue", stats.MonthlyRecurringRevenue).
		Msg("Updated contract statistics")
}

// GetServiceHealth returns detailed health status of the contract service
func (s *Service) GetServiceHealth() map[string]interface{} {
	s.mu.RLock()
	defer s.mu.RUnlock()
	
	health := map[string]interface{}{
		"service":             "contract",
		"started":             s.started,
		"enabled":             s.config.Enabled,
		"version":             "1.0.0",
		"timestamp":           time.Now(),
		"payment_provider":    s.paymentProcessor.GetProviderName(),
		"last_stats_update":   s.lastStatsUpdate,
	}
	
	if s.started && s.config.Enabled {
		health["active_subscriptions"] = s.stats.ActiveSubscriptions
		health["total_subscriptions"] = s.stats.TotalSubscriptions
		health["monthly_revenue"] = s.stats.MonthlyRecurringRevenue
		health["payment_success_rate"] = s.stats.PaymentSuccessRate
	}
	
	return health
}