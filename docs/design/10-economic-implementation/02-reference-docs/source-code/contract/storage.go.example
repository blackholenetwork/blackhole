package contract

import (
	"context"
	"fmt"
	"sort"
	"sync"
	"time"
)

// MemoryStorage provides an in-memory implementation of SubscriptionStorage
type MemoryStorage struct {
	mu                    sync.RWMutex
	subscriptions         map[string]*Subscription
	subscriptionsByUser   map[string]string // userID -> subscriptionID
	payments              map[string]*Payment
	paymentMethods        map[string]*PaymentMethod
	paymentMethodsByUser  map[string][]string // userID -> []paymentMethodID
	invoices              map[string]*Invoice
	subscriptionChanges   map[string][]*SubscriptionChange // subscriptionID -> []changes
	usageRecords          map[string][]*UsageRecord       // subscriptionID -> []records
}

// NewMemoryStorage creates a new in-memory storage implementation
func NewMemoryStorage() *MemoryStorage {
	return &MemoryStorage{
		subscriptions:        make(map[string]*Subscription),
		subscriptionsByUser:  make(map[string]string),
		payments:             make(map[string]*Payment),
		paymentMethods:       make(map[string]*PaymentMethod),
		paymentMethodsByUser: make(map[string][]string),
		invoices:             make(map[string]*Invoice),
		subscriptionChanges:  make(map[string][]*SubscriptionChange),
		usageRecords:         make(map[string][]*UsageRecord),
	}
}

// Subscription operations

func (ms *MemoryStorage) CreateSubscription(ctx context.Context, subscription *Subscription) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	if _, exists := ms.subscriptions[subscription.ID]; exists {
		return fmt.Errorf("subscription already exists: %s", subscription.ID)
	}
	
	// Check for existing active subscription for user
	if existingID, exists := ms.subscriptionsByUser[subscription.UserID]; exists {
		if existing := ms.subscriptions[existingID]; existing != nil && existing.Status == SubscriptionActive {
			return fmt.Errorf("user already has an active subscription")
		}
	}
	
	ms.subscriptions[subscription.ID] = subscription
	ms.subscriptionsByUser[subscription.UserID] = subscription.ID
	
	return nil
}

func (ms *MemoryStorage) GetSubscription(ctx context.Context, id string) (*Subscription, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	subscription, exists := ms.subscriptions[id]
	if !exists {
		return nil, fmt.Errorf("subscription not found: %s", id)
	}
	
	// Return a copy to prevent external modifications
	return copySubscription(subscription), nil
}

func (ms *MemoryStorage) GetSubscriptionByUserID(ctx context.Context, userID string) (*Subscription, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	subscriptionID, exists := ms.subscriptionsByUser[userID]
	if !exists {
		return nil, fmt.Errorf("no subscription found for user: %s", userID)
	}
	
	subscription, exists := ms.subscriptions[subscriptionID]
	if !exists {
		return nil, fmt.Errorf("subscription not found: %s", subscriptionID)
	}
	
	return copySubscription(subscription), nil
}

func (ms *MemoryStorage) UpdateSubscription(ctx context.Context, subscription *Subscription) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	if _, exists := ms.subscriptions[subscription.ID]; !exists {
		return fmt.Errorf("subscription not found: %s", subscription.ID)
	}
	
	ms.subscriptions[subscription.ID] = subscription
	return nil
}

func (ms *MemoryStorage) DeleteSubscription(ctx context.Context, id string) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	subscription, exists := ms.subscriptions[id]
	if !exists {
		return fmt.Errorf("subscription not found: %s", id)
	}
	
	delete(ms.subscriptions, id)
	delete(ms.subscriptionsByUser, subscription.UserID)
	
	return nil
}

func (ms *MemoryStorage) ListSubscriptions(ctx context.Context, filters SubscriptionFilters) ([]*Subscription, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	var result []*Subscription
	
	for _, subscription := range ms.subscriptions {
		if ms.matchesSubscriptionFilters(subscription, filters) {
			result = append(result, copySubscription(subscription))
		}
	}
	
	// Sort by creation date (newest first)
	sort.Slice(result, func(i, j int) bool {
		return result[i].CreatedAt.After(result[j].CreatedAt)
	})
	
	// Apply pagination
	if filters.Offset > 0 {
		if filters.Offset >= len(result) {
			return []*Subscription{}, nil
		}
		result = result[filters.Offset:]
	}
	
	if filters.Limit > 0 && filters.Limit < len(result) {
		result = result[:filters.Limit]
	}
	
	return result, nil
}

// Payment operations

func (ms *MemoryStorage) CreatePayment(ctx context.Context, payment *Payment) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	if _, exists := ms.payments[payment.ID]; exists {
		return fmt.Errorf("payment already exists: %s", payment.ID)
	}
	
	ms.payments[payment.ID] = payment
	return nil
}

func (ms *MemoryStorage) GetPayment(ctx context.Context, id string) (*Payment, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	payment, exists := ms.payments[id]
	if !exists {
		return nil, fmt.Errorf("payment not found: %s", id)
	}
	
	return copyPayment(payment), nil
}

func (ms *MemoryStorage) UpdatePayment(ctx context.Context, payment *Payment) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	if _, exists := ms.payments[payment.ID]; !exists {
		return fmt.Errorf("payment not found: %s", payment.ID)
	}
	
	ms.payments[payment.ID] = payment
	return nil
}

func (ms *MemoryStorage) ListPayments(ctx context.Context, filters PaymentFilters) ([]*Payment, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	var result []*Payment
	
	for _, payment := range ms.payments {
		if ms.matchesPaymentFilters(payment, filters) {
			result = append(result, copyPayment(payment))
		}
	}
	
	// Sort by creation date (newest first)
	sort.Slice(result, func(i, j int) bool {
		return result[i].CreatedAt.After(result[j].CreatedAt)
	})
	
	// Apply pagination
	if filters.Offset > 0 {
		if filters.Offset >= len(result) {
			return []*Payment{}, nil
		}
		result = result[filters.Offset:]
	}
	
	if filters.Limit > 0 && filters.Limit < len(result) {
		result = result[:filters.Limit]
	}
	
	return result, nil
}

// Payment method operations

func (ms *MemoryStorage) CreatePaymentMethod(ctx context.Context, method *PaymentMethod) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	if _, exists := ms.paymentMethods[method.ID]; exists {
		return fmt.Errorf("payment method already exists: %s", method.ID)
	}
	
	ms.paymentMethods[method.ID] = method
	ms.paymentMethodsByUser[method.UserID] = append(ms.paymentMethodsByUser[method.UserID], method.ID)
	
	return nil
}

func (ms *MemoryStorage) GetPaymentMethod(ctx context.Context, id string) (*PaymentMethod, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	method, exists := ms.paymentMethods[id]
	if !exists {
		return nil, fmt.Errorf("payment method not found: %s", id)
	}
	
	return copyPaymentMethod(method), nil
}

func (ms *MemoryStorage) ListPaymentMethods(ctx context.Context, userID string) ([]*PaymentMethod, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	methodIDs := ms.paymentMethodsByUser[userID]
	var result []*PaymentMethod
	
	for _, methodID := range methodIDs {
		if method, exists := ms.paymentMethods[methodID]; exists {
			result = append(result, copyPaymentMethod(method))
		}
	}
	
	return result, nil
}

func (ms *MemoryStorage) UpdatePaymentMethod(ctx context.Context, method *PaymentMethod) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	if _, exists := ms.paymentMethods[method.ID]; !exists {
		return fmt.Errorf("payment method not found: %s", method.ID)
	}
	
	ms.paymentMethods[method.ID] = method
	return nil
}

func (ms *MemoryStorage) DeletePaymentMethod(ctx context.Context, id string) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	method, exists := ms.paymentMethods[id]
	if !exists {
		return fmt.Errorf("payment method not found: %s", id)
	}
	
	delete(ms.paymentMethods, id)
	
	// Remove from user's list
	methodIDs := ms.paymentMethodsByUser[method.UserID]
	for i, methodID := range methodIDs {
		if methodID == id {
			ms.paymentMethodsByUser[method.UserID] = append(methodIDs[:i], methodIDs[i+1:]...)
			break
		}
	}
	
	return nil
}

// Invoice operations (simplified for now)

func (ms *MemoryStorage) CreateInvoice(ctx context.Context, invoice *Invoice) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	ms.invoices[invoice.ID] = invoice
	return nil
}

func (ms *MemoryStorage) GetInvoice(ctx context.Context, id string) (*Invoice, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	invoice, exists := ms.invoices[id]
	if !exists {
		return nil, fmt.Errorf("invoice not found: %s", id)
	}
	
	return copyInvoice(invoice), nil
}

func (ms *MemoryStorage) ListInvoices(ctx context.Context, filters InvoiceFilters) ([]*Invoice, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	var result []*Invoice
	
	for _, invoice := range ms.invoices {
		if ms.matchesInvoiceFilters(invoice, filters) {
			result = append(result, copyInvoice(invoice))
		}
	}
	
	return result, nil
}

func (ms *MemoryStorage) UpdateInvoice(ctx context.Context, invoice *Invoice) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	ms.invoices[invoice.ID] = invoice
	return nil
}

// Change tracking operations

func (ms *MemoryStorage) CreateSubscriptionChange(ctx context.Context, change *SubscriptionChange) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	ms.subscriptionChanges[change.SubscriptionID] = append(ms.subscriptionChanges[change.SubscriptionID], change)
	return nil
}

func (ms *MemoryStorage) ListSubscriptionChanges(ctx context.Context, subscriptionID string) ([]*SubscriptionChange, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	changes := ms.subscriptionChanges[subscriptionID]
	result := make([]*SubscriptionChange, len(changes))
	copy(result, changes)
	
	return result, nil
}

// Usage tracking operations

func (ms *MemoryStorage) CreateUsageRecord(ctx context.Context, record *UsageRecord) error {
	ms.mu.Lock()
	defer ms.mu.Unlock()
	
	ms.usageRecords[record.SubscriptionID] = append(ms.usageRecords[record.SubscriptionID], record)
	return nil
}

func (ms *MemoryStorage) GetUsageRecords(ctx context.Context, subscriptionID string, start, end time.Time) ([]*UsageRecord, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	allRecords := ms.usageRecords[subscriptionID]
	var result []*UsageRecord
	
	for _, record := range allRecords {
		if record.RecordedAt.After(start) && record.RecordedAt.Before(end) {
			result = append(result, record)
		}
	}
	
	return result, nil
}

// Statistics operations

func (ms *MemoryStorage) GetStats(ctx context.Context) (*ContractStats, error) {
	ms.mu.RLock()
	defer ms.mu.RUnlock()
	
	stats := &ContractStats{
		SubscriptionsByTier: make(map[SubscriptionTier]int),
		RevenueByTier:       make(map[SubscriptionTier]float64),
		LastUpdated:         time.Now(),
	}
	
	// Calculate subscription statistics
	for _, subscription := range ms.subscriptions {
		stats.TotalSubscriptions++
		stats.SubscriptionsByTier[subscription.Tier]++
		stats.RevenueByTier[subscription.Tier] += subscription.MonthlyAmount
		
		switch subscription.Status {
		case SubscriptionActive:
			stats.ActiveSubscriptions++
			stats.MonthlyRecurringRevenue += subscription.MonthlyAmount
		case SubscriptionTrial:
			stats.TrialSubscriptions++
		case SubscriptionCancelled:
			stats.CancelledSubscriptions++
		}
	}
	
	// Calculate payment statistics
	totalPayments := 0
	successfulPayments := 0
	
	for _, payment := range ms.payments {
		totalPayments++
		if payment.Status == PaymentCompleted {
			successfulPayments++
			stats.TotalRevenue += payment.Amount
		}
	}
	
	if totalPayments > 0 {
		stats.PaymentSuccessRate = float64(successfulPayments) / float64(totalPayments)
	}
	
	if stats.ActiveSubscriptions > 0 {
		stats.AverageRevenuePerUser = stats.MonthlyRecurringRevenue / float64(stats.ActiveSubscriptions)
	}
	
	return stats, nil
}

// Helper methods for filtering and copying

func (ms *MemoryStorage) matchesSubscriptionFilters(subscription *Subscription, filters SubscriptionFilters) bool {
	if filters.UserID != "" && subscription.UserID != filters.UserID {
		return false
	}
	if filters.Status != "" && subscription.Status != filters.Status {
		return false
	}
	if filters.Tier != "" && subscription.Tier != filters.Tier {
		return false
	}
	if filters.StartDate != nil && subscription.CreatedAt.Before(*filters.StartDate) {
		return false
	}
	if filters.EndDate != nil && subscription.CreatedAt.After(*filters.EndDate) {
		return false
	}
	return true
}

func (ms *MemoryStorage) matchesPaymentFilters(payment *Payment, filters PaymentFilters) bool {
	if filters.SubscriptionID != "" && payment.SubscriptionID != filters.SubscriptionID {
		return false
	}
	if filters.UserID != "" && payment.UserID != filters.UserID {
		return false
	}
	if filters.Status != "" && payment.Status != filters.Status {
		return false
	}
	if filters.StartDate != nil && payment.CreatedAt.Before(*filters.StartDate) {
		return false
	}
	if filters.EndDate != nil && payment.CreatedAt.After(*filters.EndDate) {
		return false
	}
	return true
}

func (ms *MemoryStorage) matchesInvoiceFilters(invoice *Invoice, filters InvoiceFilters) bool {
	if filters.SubscriptionID != "" && invoice.SubscriptionID != filters.SubscriptionID {
		return false
	}
	if filters.UserID != "" && invoice.UserID != filters.UserID {
		return false
	}
	if filters.Status != "" && invoice.Status != filters.Status {
		return false
	}
	return true
}

// Copy functions to prevent external modifications

func copySubscription(s *Subscription) *Subscription {
	result := *s
	if s.Metadata != nil {
		result.Metadata = make(map[string]string)
		for k, v := range s.Metadata {
			result.Metadata[k] = v
		}
	}
	if s.Features != nil {
		result.Features = make([]string, len(s.Features))
		copy(result.Features, s.Features)
	}
	return &result
}

func copyPayment(p *Payment) *Payment {
	copy := *p
	if p.Metadata != nil {
		copy.Metadata = make(map[string]string)
		for k, v := range p.Metadata {
			copy.Metadata[k] = v
		}
	}
	return &copy
}

func copyPaymentMethod(pm *PaymentMethod) *PaymentMethod {
	copy := *pm
	if pm.Metadata != nil {
		copy.Metadata = make(map[string]string)
		for k, v := range pm.Metadata {
			copy.Metadata[k] = v
		}
	}
	return &copy
}

func copyInvoice(i *Invoice) *Invoice {
	result := *i
	if i.Metadata != nil {
		result.Metadata = make(map[string]string)
		for k, v := range i.Metadata {
			result.Metadata[k] = v
		}
	}
	if i.LineItems != nil {
		result.LineItems = make([]InvoiceLineItem, len(i.LineItems))
		copy(result.LineItems, i.LineItems)
	}
	return &result
}