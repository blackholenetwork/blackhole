// Helper function to build network overview
func (s *server) buildNetworkOverview(incentiveService *incentive.Service) *NetworkOverview {
	if incentiveService == nil {
		return &NetworkOverview{
			TotalActiveUsers:     0,
			TotalSubscribers:     0,
			TotalProviders:       0,
			TotalContentCreators: 0,
			TotalAppDevelopers:   0,
			CurrentRevenueRate:   0,
			TotalDistributedToday: 0,
			ActiveDistribution: &ActiveDistributionBreakdown{
				ContentPool:        0,
				NetworkOpsPool:     0,
				AppDeveloperPool:   0,
				InfrastructurePool: 0,
				UnusedFunds:        0,
			},
		}
	}

	// Get pool amounts
	poolAmounts := incentiveService.GetPoolAmounts()
	currentRevenueRate := incentiveService.GetCurrentRevenueRate()

	// Get statistics
	contentStats := incentiveService.GetRealTimeContentStats()
	appDevStats := incentiveService.GetRealTimeAppDeveloperStats()
	infraStats := incentiveService.GetRealTimeInfrastructureStats()

	return &NetworkOverview{
		TotalActiveUsers:     0, // TODO: Calculate from all services
		TotalSubscribers:     len(incentiveService.GetProratedSubscriptions()),
		TotalProviders:       len(incentiveService.GetActiveProviders()),
		TotalContentCreators: contentStats.ActiveCreators,
		TotalAppDevelopers:   appDevStats.ActiveDevelopers,
		CurrentRevenueRate:   currentRevenueRate,
		TotalDistributedToday: contentStats.TotalDistributedToday + appDevStats.TotalDistributedToday + infraStats.TotalDistributedToday,
		ActiveDistribution: &ActiveDistributionBreakdown{
			ContentPool:        poolAmounts["content"],
			NetworkOpsPool:     poolAmounts["network_ops"],
			AppDeveloperPool:   poolAmounts["app_developer"],
			InfrastructurePool: poolAmounts["infrastructure"],
			UnusedFunds:        poolAmounts["unused"],
		},
	}
}

// Calculation helper functions (placeholder implementations)
func (s *server) calculateDailyRewards(creatorID string, distributions []*ContentDistribution) float64 {
	today := time.Now().Truncate(24 * time.Hour)
	total := 0.0
	for _, dist := range distributions {
		if dist.Timestamp.After(today) {
			if reward, exists := dist.CreatorRewards[creatorID]; exists {
				total += reward
			}
		}
	}
	return total
}

func (s *server) calculateWeeklyRewards(creatorID string, distributions []*ContentDistribution) float64 {
	weekAgo := time.Now().AddDate(0, 0, -7)
	total := 0.0
	for _, dist := range distributions {
		if dist.Timestamp.After(weekAgo) {
			if reward, exists := dist.CreatorRewards[creatorID]; exists {
				total += reward
			}
		}
	}
	return total
}

func (s *server) calculateMonthlyRewards(creatorID string, distributions []*ContentDistribution) float64 {
	monthAgo := time.Now().AddDate(0, -1, 0)
	total := 0.0
	for _, dist := range distributions {
		if dist.Timestamp.After(monthAgo) {
			if reward, exists := dist.CreatorRewards[creatorID]; exists {
				total += reward
			}
		}
	}
	return total
}

func (s *server) calculatePoolShare(creatorID string, totalEngagementValue float64) float64 {
	// This would calculate current pool share percentage
	// Placeholder implementation
	return 0.0
}

func (s *server) calculateAverageRewardPerSecond(distributions []*ContentDistributionSummary) float64 {
	if len(distributions) == 0 {
		return 0.0
	}
	total := 0.0
	for _, dist := range distributions {
		total += dist.CreatorReward
	}
	return total / float64(len(distributions))
}

// Similar calculation functions for app developers and providers
func (s *server) calculateDailyAppRewards(developerID string, distributions []*AppDeveloperDistribution) float64 {
	today := time.Now().Truncate(24 * time.Hour)
	total := 0.0
	for _, dist := range distributions {
		if dist.Timestamp.After(today) {
			if reward, exists := dist.DeveloperRewards[developerID]; exists {
				total += reward
			}
		}
	}
	return total
}

