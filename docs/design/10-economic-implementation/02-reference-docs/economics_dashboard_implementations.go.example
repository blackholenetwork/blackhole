// handleSubscriberDashboard returns subscriber dashboard data
func (s *server) handleSubscriberDashboard(c *fiber.Ctx) error {
	userDID := c.Params("did")
	if userDID == "" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
			"error": "User DID is required",
		})
	}

	// Get authenticated user from context
	authenticatedUserID := c.Locals("user_id")
	if authenticatedUserID == nil {
		return c.Status(fiber.StatusUnauthorized).JSON(fiber.Map{
			"error": "Authentication required",
		})
	}

	// Check if user can access this dashboard (either their own or they have admin rights)
	if !s.canAccessUserDashboard(c, userDID) {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
			"error": "Access denied to this user's dashboard",
		})
	}

	// Get incentive service
	incentiveService := s.getIncentiveService()
	if incentiveService == nil {
		return c.Status(fiber.StatusServiceUnavailable).JSON(fiber.Map{
			"error": "Incentive service not available",
		})
	}

	// Get subscription information
	subscription, err := incentiveService.GetSubscription(userDID)
	if err != nil {
		return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
			"error": "Subscription not found",
		})
	}

	// Get prorated subscription if using real-time billing
	proratedSubscriptions := incentiveService.GetProratedSubscriptions()
	var proratedSub *ProratedSubscription
	if sub, exists := proratedSubscriptions[userDID]; exists {
		proratedSub = sub
	}

	// Get pool amounts for distribution breakdown
	// poolAmounts := incentiveService.GetPoolAmounts()
	currentRevenueRate := incentiveService.GetCurrentRevenueRate()

	// Get prorated billing stats
	// billingStats := incentiveService.GetProratedBillingStats()

	// Build subscriber dashboard
	dashboard := &SubscriberDashboard{
		UserID:   userDID,
		UserType: "subscriber",

		// Subscription Information
		SubscriptionTier:     string(subscription.Tier),
		MonthlyAmount:        subscription.MonthlyAmount,
		StartDate:            subscription.StartDate,
		Status:               string(subscription.Status),
		RevenuePerSecond:     currentRevenueRate,
		TotalSecondsActive:   0,
		TotalAmountGenerated: 0,

		// Current Usage (placeholder - would integrate with actual usage tracking)
		CurrentUsage: &SubscriberUsageStats{
			StorageUsed:         0, // TODO: Integrate with storage service
			BandwidthUsed:       0, // TODO: Integrate with bandwidth service
			ComputeHours:        0, // TODO: Integrate with compute service
			ContentConsumed:     0, // TODO: Integrate with content tracking
			AppsUsed:            0, // TODO: Integrate with app tracking
			MonthlyStorageOps:   0,
			MonthlyContentViews: 0,
			MonthlyAppSessions:  0,
		},

		// Revenue Distribution Breakdown
		DistributionBreakdown: &RevenueDistribution{
			ContentCreators:         70.0,
			NetworkOperations:       2.5,
			AppDevelopers:           2.5,
			InfrastructureProviders: 25.0,
			MonthlyAmounts: &RevenueAmounts{
				Total:                   subscription.MonthlyAmount,
				ContentCreators:         subscription.MonthlyAmount * 0.70,
				NetworkOperations:       subscription.MonthlyAmount * 0.025,
				AppDevelopers:           subscription.MonthlyAmount * 0.025,
				InfrastructureProviders: subscription.MonthlyAmount * 0.25,
			},
		},

		// Network Stats
		NetworkStats: s.buildNetworkOverview(incentiveService),

		LastUpdated: time.Now(),
	}

	// Add prorated subscription data if available
	if proratedSub != nil {
		dashboard.TotalSecondsActive = proratedSub.TotalSecondsActive
		dashboard.TotalAmountGenerated = proratedSub.TotalAmountGenerated
		dashboard.RevenuePerSecond = proratedSub.RevenuePerSecond
	}

	return c.JSON(dashboard)
}

// handleContentCreatorDashboard returns content creator dashboard data
func (s *server) handleContentCreatorDashboard(c *fiber.Ctx) error {
	creatorDID := c.Params("did")
	if creatorDID == "" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
			"error": "Creator DID is required",
		})
	}

	// Check authentication and access
	if !s.canAccessUserDashboard(c, creatorDID) {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
			"error": "Access denied to this creator's dashboard",
		})
	}

	incentiveService := s.getIncentiveService()
	if incentiveService == nil {
		return c.Status(fiber.StatusServiceUnavailable).JSON(fiber.Map{
			"error": "Incentive service not available",
		})
	}

	// Get active creators
	activeCreators := incentiveService.GetActiveCreators()
	var creatorEngagement *ContentEngagementRealTime
	if engagement, exists := activeCreators[creatorDID]; exists {
		creatorEngagement = engagement
	}

	// Get creator rewards
	creatorRewards := incentiveService.GetCreatorRewardsRealTime()
	totalRewards := creatorRewards[creatorDID]

	// Get content distribution statistics
	contentStats := incentiveService.GetRealTimeContentStats()

	// Get recent distribution history
	distributionHistory := incentiveService.GetContentDistributionHistory(10)

	// Build recent distributions summary
	var recentDistributions []*ContentDistributionSummary
	for _, dist := range distributionHistory {
		if reward, exists := dist.CreatorRewards[creatorDID]; exists {
			summary := &ContentDistributionSummary{
				Timestamp:       dist.Timestamp,
				PoolAmount:      dist.ContentPoolAmount,
				CreatorReward:   reward,
				SharePercentage: (reward / dist.ContentPoolAmount) * 100,
				EngagementValue: 0, // Would need to track individual engagement value
			}
			recentDistributions = append(recentDistributions, summary)
		}
	}

	// Build dashboard
	dashboard := &ContentCreatorDashboard{
		CreatorID: creatorDID,
		UserType:  "content_creator",

		// Current Engagement
		CurrentEngagement: &ContentEngagementStats{
			VideoWatchTime:       0,
			AudioListenTime:      0,
			DocumentReadTime:     0,
			PhotoViewTime:        0,
			TotalEngagementValue: 0,
			QualityMultiplier:    1.0,
			IsActive:            false,
		},

		// Reward Stats
		RewardStats: &ContentRewardStats{
			AccumulatedRewards:     totalRewards,
			TotalRewardsToday:      s.calculateDailyRewards(creatorDID, distributionHistory),
			TotalRewardsThisWeek:   s.calculateWeeklyRewards(creatorDID, distributionHistory),
			TotalRewardsThisMonth:  s.calculateMonthlyRewards(creatorDID, distributionHistory),
			CurrentPoolShare:       s.calculatePoolShare(creatorDID, contentStats.TotalEngagementValue),
			AverageRewardPerSecond: s.calculateAverageRewardPerSecond(recentDistributions),
		},

		// Content Performance (placeholder)
		ContentPerformance: &ContentPerformanceStats{
			TotalContentPieces:    0, // TODO: Integrate with content service
			ActiveContentPieces:   0,
			TopContentType:        "video",
			AverageEngagementTime: 0,
			TotalViews:            0,
			QualityScore:          1.0,
		},

		RecentDistributions: recentDistributions,
		LastUpdated:         time.Now(),
	}

	// Add current engagement data if available
	if creatorEngagement != nil {
		dashboard.CurrentEngagement = &ContentEngagementStats{
			VideoWatchTime:       creatorEngagement.VideoWatchTimePerSecond,
			AudioListenTime:      creatorEngagement.AudioListenTimePerSecond,
			DocumentReadTime:     creatorEngagement.DocumentReadTimePerSecond,
			PhotoViewTime:        creatorEngagement.PhotoViewTimePerSecond,
			TotalEngagementValue: creatorEngagement.TotalEngagementValue,
			QualityMultiplier:    creatorEngagement.QualityMultiplier,
			IsActive:            creatorEngagement.IsActive,
		}
	}

	return c.JSON(dashboard)
}

// handleAppDeveloperDashboard returns app developer dashboard data
func (s *server) handleAppDeveloperDashboard(c *fiber.Ctx) error {
	developerDID := c.Params("did")
	if developerDID == "" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
			"error": "Developer DID is required",
		})
	}

	// Check authentication and access
	if !s.canAccessUserDashboard(c, developerDID) {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
			"error": "Access denied to this developer's dashboard",
		})
	}

	incentiveService := s.getIncentiveService()
	if incentiveService == nil {
		return c.Status(fiber.StatusServiceUnavailable).JSON(fiber.Map{
			"error": "Incentive service not available",
		})
	}

	// Get active apps
	activeApps := incentiveService.GetActiveApps()
	var developerUsage *AppUsageRealTime
	// Find app usage for this developer
	for _, app := range activeApps {
		if app.DeveloperID == developerDID {
			developerUsage = app
			break
		}
	}

	// Get developer rewards
	developerRewards := incentiveService.GetAppDeveloperRewardsRealTime()
	totalRewards := developerRewards[developerDID]

	// Get app developer statistics
	appDevStats := incentiveService.GetRealTimeAppDeveloperStats()

	// Get recent distribution history
	distributionHistory := incentiveService.GetAppDeveloperDistributionHistory(10)

	// Build recent distributions summary
	var recentDistributions []*AppDeveloperDistributionSummary
	for _, dist := range distributionHistory {
		if reward, exists := dist.DeveloperRewards[developerDID]; exists {
			summary := &AppDeveloperDistributionSummary{
				Timestamp:       dist.Timestamp,
				PoolAmount:      dist.AppDeveloperAmount,
				DeveloperReward: reward,
				SharePercentage: (reward / dist.AppDeveloperAmount) * 100,
				UsageValue:      0, // Would need to track individual usage value
			}
			recentDistributions = append(recentDistributions, summary)
		}
	}

	// Build dashboard
	dashboard := &AppDeveloperDashboard{
		DeveloperID: developerDID,
		UserType:    "app_developer",

		// Current Usage
		CurrentUsage: &AppUsageStats{
			ActiveUserTime:    0,
			UserRetentionRate: 0.8,
			AppRating:         4.0,
			QualityMultiplier: 1.0,
			TotalUsageValue:   0,
			IsActive:          false,
		},

		// Reward Stats
		RewardStats: &AppDeveloperRewardStats{
			AccumulatedRewards:     totalRewards,
			TotalRewardsToday:      s.calculateDailyAppRewards(developerDID, distributionHistory),
			TotalRewardsThisWeek:   s.calculateWeeklyAppRewards(developerDID, distributionHistory),
			TotalRewardsThisMonth:  s.calculateMonthlyAppRewards(developerDID, distributionHistory),
			CurrentPoolShare:       s.calculateAppPoolShare(developerDID, appDevStats.TotalUsageValue),
			AverageRewardPerSecond: s.calculateAverageAppRewardPerSecond(recentDistributions),
		},

		// App Performance
		AppPerformance: &AppPerformanceStats{
			TotalApps:          s.countDeveloperApps(developerDID, activeApps),
			ActiveApps:         s.countActiveDeveloperApps(developerDID, activeApps),
			TotalUsers:         0, // TODO: Integrate with app service
			AverageSessionTime: 0,
			TotalSessions:      0,
			AverageRating:      4.0,
			AverageRetention:   0.8,
		},

		RecentDistributions: recentDistributions,
		LastUpdated:         time.Now(),
	}

	// Add current usage data if available
	if developerUsage != nil {
		dashboard.CurrentUsage = &AppUsageStats{
			ActiveUserTime:    developerUsage.ActiveUserTimePerSecond,
			UserRetentionRate: developerUsage.UserRetentionRate,
			AppRating:         developerUsage.AppRating,
			QualityMultiplier: developerUsage.QualityMultiplier,
			TotalUsageValue:   developerUsage.TotalUsageValue,
			IsActive:          developerUsage.IsActive,
		}
	}

	return c.JSON(dashboard)
}

// handleProviderDashboard returns infrastructure provider dashboard data
func (s *server) handleProviderDashboard(c *fiber.Ctx) error {
	providerDID := c.Params("did")
	if providerDID == "" {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
			"error": "Provider DID is required",
		})
	}

	// Check authentication and access
	if !s.canAccessUserDashboard(c, providerDID) {
		return c.Status(fiber.StatusForbidden).JSON(fiber.Map{
			"error": "Access denied to this provider's dashboard",
		})
	}

	incentiveService := s.getIncentiveService()
	if incentiveService == nil {
		return c.Status(fiber.StatusServiceUnavailable).JSON(fiber.Map{
			"error": "Incentive service not available",
		})
	}

	// Get active providers
	activeProviders := incentiveService.GetActiveProviders()
	var providerUsage *RealTimeProviderUsage
	if usage, exists := activeProviders[providerDID]; exists {
		providerUsage = usage
	}

	// Get provider rewards
	providerRewards := incentiveService.GetProviderRewardsRealTime()
	totalRewards := providerRewards[providerDID]

	// Get infrastructure statistics
	infraStats := incentiveService.GetRealTimeInfrastructureStats()

	// Get recent distribution history
	distributionHistory := incentiveService.GetDistributionHistory(10)

	// Build recent distributions summary
	var recentDistributions []*ProviderDistributionSummary
	for _, dist := range distributionHistory {
		if reward, exists := dist.ProviderRewards[providerDID]; exists {
			summary := &ProviderDistributionSummary{
				Timestamp:       dist.Timestamp,
				PoolAmount:      dist.InfrastructureAmount,
				ProviderReward:  reward,
				SharePercentage: (reward / dist.InfrastructureAmount) * 100,
				MarketValue:     0, // Would need to track individual market value
			}
			recentDistributions = append(recentDistributions, summary)
		}
	}

	// Build dashboard
	dashboard := &ProviderDashboard{
		ProviderID: providerDID,
		UserType:   "provider",

		// Current Usage
		CurrentUsage: &ProviderUsageStats{
			StorageGBHours:       0,
			BandwidthGBPerSecond: 0,
			CPUHours:             0,
			GPUHours:             0,
			MemoryGBHours:        0,
			MarketValuePerSecond: 0,
			IsActive:             false,
		},

		// Reward Stats
		RewardStats: &ProviderRewardStats{
			AccumulatedRewards:     totalRewards,
			TotalRewardsToday:      s.calculateDailyProviderRewards(providerDID, distributionHistory),
			TotalRewardsThisWeek:   s.calculateWeeklyProviderRewards(providerDID, distributionHistory),
			TotalRewardsThisMonth:  s.calculateMonthlyProviderRewards(providerDID, distributionHistory),
			CurrentPoolShare:       s.calculateProviderPoolShare(providerDID, infraStats.TotalMarketValuePerSecond),
			AverageRewardPerSecond: s.calculateAverageProviderRewardPerSecond(recentDistributions),
		},

		// Resource Performance (placeholder)
		ResourcePerformance: &ResourcePerformanceStats{
			TotalStorageProvided:   0, // TODO: Integrate with storage service
			TotalBandwidthProvided: 0, // TODO: Integrate with bandwidth service
			TotalComputeHours:      0, // TODO: Integrate with compute service
			UptimePercentage:       99.5,
			TotalOperations:        0,
			SuccessRate:            99.8,
		},

		RecentDistributions: recentDistributions,
		LastUpdated:         time.Now(),
	}

	// Add current usage data if available
	if providerUsage != nil {
		dashboard.CurrentUsage = &ProviderUsageStats{
			StorageGBHours:       providerUsage.StorageGBHoursPerSecond,
			BandwidthGBPerSecond: providerUsage.BandwidthGBPerSecond,
			CPUHours:             providerUsage.CPUHoursPerSecond,
			GPUHours:             providerUsage.GPUHoursPerSecond,
			MemoryGBHours:        providerUsage.MemoryGBHoursPerSecond,
			MarketValuePerSecond: providerUsage.MarketValuePerSecond,
			IsActive:             providerUsage.IsActive,
		}
	}

	return c.JSON(dashboard)
}

