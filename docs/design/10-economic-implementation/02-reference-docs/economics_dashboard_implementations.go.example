func (s *server) calculateAverageAppRewardPerSecond(distributions []*AppDeveloperDistributionSummary) float64 {
	if len(distributions) == 0 {
		return 0.0
	}
	total := 0.0
	for _, dist := range distributions {
		total += dist.DeveloperReward
	}
	return total / float64(len(distributions))
}

func (s *server) countDeveloperApps(developerID string, activeApps map[string]*AppUsageRealTime) int {
	count := 0
	for _, app := range activeApps {
		if app.DeveloperID == developerID {
			count++
		}
	}
	return count
}

func (s *server) countActiveDeveloperApps(developerID string, activeApps map[string]*AppUsageRealTime) int {
	count := 0
	for _, app := range activeApps {
		if app.DeveloperID == developerID && app.IsActive {
			count++
		}
	}
	return count
}

// Provider calculation functions
func (s *server) calculateDailyProviderRewards(providerID string, distributions []*RealTimeDistribution) float64 {
	today := time.Now().Truncate(24 * time.Hour)
	total := 0.0
	for _, dist := range distributions {
		if dist.Timestamp.After(today) {
			if reward, exists := dist.ProviderRewards[providerID]; exists {
				total += reward
			}
		}
	}
	return total
}

func (s *server) calculateWeeklyProviderRewards(providerID string, distributions []*RealTimeDistribution) float64 {
	weekAgo := time.Now().AddDate(0, 0, -7)
	total := 0.0
	for _, dist := range distributions {
		if dist.Timestamp.After(weekAgo) {
			if reward, exists := dist.ProviderRewards[providerID]; exists {
				total += reward
			}
		}
	}
	return total
}

func (s *server) calculateMonthlyProviderRewards(providerID string, distributions []*RealTimeDistribution) float64 {
	monthAgo := time.Now().AddDate(0, -1, 0)
	total := 0.0
	for _, dist := range distributions {
		if dist.Timestamp.After(monthAgo) {
			if reward, exists := dist.ProviderRewards[providerID]; exists {
				total += reward
			}
		}
	}
	return total
}

func (s *server) calculateProviderPoolShare(providerID string, totalMarketValue float64) float64 {
	return 0.0 // Placeholder
}

func (s *server) calculateAverageProviderRewardPerSecond(distributions []*ProviderDistributionSummary) float64 {
	if len(distributions) == 0 {
		return 0.0
	}
	total := 0.0
	for _, dist := range distributions {
		total += dist.ProviderReward
	}
	return total / float64(len(distributions))
}

// Type aliases for better readability - these reference the actual incentive service types
type (
	ProratedSubscription         = incentive.ProratedSubscription
	ProratedBillingStats         = incentive.ProratedBillingStats
	ContentEngagementRealTime    = incentive.ContentEngagementRealTime
	RealTimeContentStats         = incentive.RealTimeContentStats
	ContentDistribution          = incentive.ContentDistribution
	AppUsageRealTime             = incentive.AppUsageRealTime
	RealTimeAppDeveloperStats    = incentive.RealTimeAppDeveloperStats
	AppDeveloperDistribution     = incentive.AppDeveloperDistribution
	RealTimeProviderUsage        = incentive.RealTimeProviderUsage
	RealTimeInfrastructureStats  = incentive.RealTimeInfrastructureStats
	RealTimeDistribution         = incentive.RealTimeDistribution
	Subscription                 = incentive.Subscription
)

// canAccessUserDashboard checks if the authenticated user can access the requested user's dashboard
func (s *server) canAccessUserDashboard(c *fiber.Ctx, targetDID string) bool {
	// Get authenticated user DID from context
	authenticatedUserID := c.Locals("user_id")
	if authenticatedUserID == nil {
		return false
	}

	authenticatedDID, ok := authenticatedUserID.(string)
	if !ok {
		return false
	}

	// Users can always access their own dashboard
	if authenticatedDID == targetDID {
		return true
	}

	// Check if user has admin privileges (this would be determined by the auth service)
	userRole := c.Locals("user_role")
	if userRole != nil {
		if role, ok := userRole.(string); ok && (role == "admin" || role == "moderator") {
			return true
		}
	}

	// For now, only allow access to own dashboard
	return false
}

// handlePersonalDashboard returns the authenticated user's dashboard based on their type
func (s *server) handlePersonalDashboard(c *fiber.Ctx) error {
	// Get authenticated user DID from context
	authenticatedUserID := c.Locals("user_id")
	if authenticatedUserID == nil {
		return c.Status(fiber.StatusUnauthorized).JSON(fiber.Map{
			"error": "Authentication required",
		})
	}

	userDID, ok := authenticatedUserID.(string)
	if !ok {
		return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
			"error": "Invalid user DID format",
		})
	}

	// Determine user type and redirect to appropriate dashboard
	userType := s.determineUserType(userDID)

	switch userType {
	case "subscriber":
		// Set the DID parameter and call subscriber dashboard
		c.Params("did", userDID)
		return s.handleSubscriberDashboard(c)
	case "content_creator":
		c.Params("did", userDID)
		return s.handleContentCreatorDashboard(c)
	case "app_developer":
		c.Params("did", userDID)
		return s.handleAppDeveloperDashboard(c)
	case "provider":
		c.Params("did", userDID)
		return s.handleProviderDashboard(c)
	case "free_user":
		c.Params("did", userDID)
		return s.handleFreeUserDashboard(c)
	default:
		// Default to free user dashboard
		c.Params("did", userDID)
		return s.handleFreeUserDashboard(c)
	}
}

// determineUserType determines the user type based on their DID and activity
func (s *server) determineUserType(userDID string) string {
	incentiveService := s.getIncentiveService()
	if incentiveService == nil {
		return "free_user"
	}

	// Check if user has a subscription
	if subscription, err := incentiveService.GetSubscription(userDID); err == nil && subscription != nil {
		return "subscriber"
	}

	// Check if user is an active content creator
	activeCreators := incentiveService.GetActiveCreators()
	if _, exists := activeCreators[userDID]; exists {
		return "content_creator"
	}

	// Check if user is an app developer
	activeApps := incentiveService.GetActiveApps()
	for _, app := range activeApps {
		if app.DeveloperID == userDID {
			return "app_developer"
		}
	}

	// Check if user is an infrastructure provider
	activeProviders := incentiveService.GetActiveProviders()
	if _, exists := activeProviders[userDID]; exists {
		return "provider"
	}

	// Default to free user
	return "free_user"
}
