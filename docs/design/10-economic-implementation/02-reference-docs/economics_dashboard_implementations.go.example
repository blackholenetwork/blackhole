// handleNetworkOverview returns network overview data
func (s *server) handleNetworkOverview(c *fiber.Ctx) error {
	incentiveService := s.getIncentiveService()
	if incentiveService == nil {
		return c.Status(fiber.StatusServiceUnavailable).JSON(fiber.Map{
			"error": "Incentive service not available",
		})
	}

	overview := s.buildNetworkOverview(incentiveService)
	return c.JSON(overview)
}

// Helper function to get incentive service
func (s *server) getIncentiveService() *incentive.Service {
	// Check if orchestrator is available and get incentive service
	if s.orchestrator != nil {
		// Try to get the incentive service from orchestrator
		// In a real implementation, this would be:
		// if orchestrator, ok := s.orchestrator.(core.ServiceOrchestrator); ok {
		//     return orchestrator.GetService("incentive").(*incentive.Service)
		// }
