func BenchmarkPlugin_Start(b *testing.B) {
	ctx := context.Background()
	config := plugin.Config{}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		p := New()
		_ = p.Init(ctx, config)
		_ = p.Start(ctx)
		_ = p.Stop(ctx)
	}
}
